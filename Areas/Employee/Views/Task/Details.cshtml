@model DocumentTracking
@using eProtokoll.Models
@{
    ViewData["Title"] = "Detaje - Task";
}

<div class="container-fluid">
    <!-- Back Button -->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Kthehu tek Lista
            </a>
        </div>
    </div>

    <!-- Document Info Card -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-text"></i>
                        Informacioni i Dokumentit
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless mb-0">
                                <tr>
                                    <td class="text-muted" style="width: 40%">
                                        <i class="bi bi-hash"></i> Protokolli:
                                    </td>
                                    <td><strong>@Model.Document.ProtocolNumber</strong></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">
                                        <i class="bi bi-calendar3"></i> Data:
                                    </td>
                                    <td>@Model.Document.ProtocolDate.ToString("dd/MM/yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">
                                        <i class="bi bi-folder"></i> Lloji:
                                    </td>
                                    <td>
                                        @switch (Model.Document.DocumentType)
                                        {
                                            case DocumentType.Incoming:
                                                <span class="badge bg-info">📥 Hyrës</span>
                                                break;
                                            case DocumentType.Outgoing:
                                                <span class="badge bg-warning text-dark">📤 Dalës</span>
                                                break;
                                            case DocumentType.Internal:
                                                <span class="badge bg-secondary">🔄 Brendshëm</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted">
                                        <i class="bi bi-flag"></i> Prioriteti:
                                    </td>
                                    <td>
                                        @switch (Model.Document.Priority)
                                        {
                                            case Priority.Urgent:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-lightning-charge-fill"></i> URGENT
                                                </span>
                                                break;
                                            case Priority.High:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-circle-fill"></i> High
                                                </span>
                                                break;
                                            case Priority.Normal:
                                                <span class="badge bg-info">Normal</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">Low</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless mb-0">
                                <tr>
                                    <td class="text-muted" style="width: 40%">
                                        <i class="bi bi-tag"></i> Lloji i Task:
                                    </td>
                                    <td>
                                        @switch (Model.ActionType)
                                        {
                                            case ActionType.ForInformation:
                                                <span class="badge bg-info">
                                                    <i class="bi bi-info-circle"></i> Për Njoftim
                                                </span>
                                                break;
                                            case ActionType.ForResponse:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-pencil"></i> Për Përgjigje
                                                </span>
                                                break;
                                            case ActionType.ForAction:
                                                <span class="badge bg-primary">
                                                    <i class="bi bi-lightning"></i> Për Veprim
                                                </span>
                                                break;
                                            case ActionType.ForApproval:
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check2"></i> Për Miratim
                                                </span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@Model.ActionType</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted">
                                        <i class="bi bi-circle-fill"></i> Statusi:
                                    </td>
                                    <td>
                                        @switch (Model.Status)
                                        {
                                            case TrackingStatus.Assigned:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-inbox"></i> Të re
                                                </span>
                                                break;
                                            case TrackingStatus.Accepted:
                                                <span class="badge bg-info">
                                                    <i class="bi bi-hand-thumbs-up"></i> Pranuar
                                                </span>
                                                break;
                                            case TrackingStatus.InProgress:
                                                <span class="badge bg-primary">
                                                    <i class="bi bi-arrow-repeat"></i> Në proces
                                                </span>
                                                break;
                                            case TrackingStatus.Completed:
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Përfunduar
                                                </span>
                                                break;
                                            case TrackingStatus.Rejected:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle"></i> Refuzuar
                                                </span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@Model.Status</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                                @if (Model.HasDeadline && Model.DueDate.HasValue)
                                {
                                    var isOverdue = Model.DueDate.Value < DateTime.Now;
                                    var daysLeft = (Model.DueDate.Value - DateTime.Now).Days;

                                    <tr>
                                        <td class="text-muted">
                                            <i class="bi bi-alarm"></i> Afati:
                                        </td>
                                        <td>
                                            @if (isOverdue)
                                            {
                                                <span class="text-danger fw-bold">
                                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                                    @Model.DueDate.Value.ToString("dd/MM/yyyy HH:mm")
                                                    <br />
                                                    <small>Overdue!</small>
                                                </span>
                                            }
                                            else if (daysLeft <= 2)
                                            {
                                                <span class="text-warning fw-bold">
                                                    <i class="bi bi-clock-fill"></i>
                                                    @Model.DueDate.Value.ToString("dd/MM/yyyy HH:mm")
                                                    <br />
                                                    <small>@daysLeft ditë të mbetura</small>
                                                </span>
                                            }
                                            else
                                            {
                                                <span>
                                                    <i class="bi bi-calendar-check"></i>
                                                    @Model.DueDate.Value.ToString("dd/MM/yyyy HH:mm")
                                                    <br />
                                                    <small class="text-muted">@daysLeft ditë të mbetura</small>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                                <tr>
                                    <td class="text-muted">
                                        <i class="bi bi-person"></i> Caktuar nga:
                                    </td>
                                    <td>
                                        @if (Model.AssignedByUser != null)
                                        {
                                            <strong>@Model.AssignedByUser.FirstName @Model.AssignedByUser.LastName</strong>
                                        }
                                        <br />
                                        <small class="text-muted">@Model.AssignedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <hr />

                    <!-- Subject & Content -->
                    <div class="mb-3">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-card-text"></i> Subjekti:
                        </h6>
                        <p class="mb-0">@Model.Document.Subject</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Document.Content))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted mb-2">
                                <i class="bi bi-file-text"></i> Përmbajtja:
                            </h6>
                            <p class="mb-0">@Model.Document.Content</p>
                        </div>
                    }

                    <!-- Instructions -->
                    <div class="alert alert-info border-0">
                        <h6 class="alert-heading">
                            <i class="bi bi-clipboard-check"></i> Udhëzimet:
                        </h6>
                        <p class="mb-0">@Model.Instructions</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="alert alert-secondary border-0">
                            <h6 class="alert-heading">
                                <i class="bi bi-sticky"></i> Shënime:
                            </h6>
                            <p class="mb-0">@Model.Notes</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-lightning-charge"></i> Veprime
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == TrackingStatus.Assigned)
                    {
                        @if (Model.ActionType == ActionType.ForInformation)
                        {
                            <!-- ForInformation - Mark as Read -->
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i>
                                Ky dokument është vetëm për njoftim. Pasi ta lexoni, shënojeni si të lexuar.
                            </div>
                            <form asp-action="MarkAsRead" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.TrackingId" />
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="bi bi-check2-circle"></i> Shëno si të Lexuar
                                </button>
                            </form>
                        }
                        else
                        {
                            <!-- ForResponse/ForAction - Accept/Reject -->
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                Ky task kërkon përgjigjen tuaj. Pranojeni ose refuzojeni task-in.
                            </div>
                            <form asp-action="Accept" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.TrackingId" />
                                <button type="submit" class="btn btn-success btn-lg me-2">
                                    <i class="bi bi-check2-circle"></i> Pranoje Task-in
                                </button>
                            </form>
                            <button class="btn btn-danger btn-lg" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="bi bi-x-circle"></i> Refuzoje Task-in
                            </button>
                        }
                    }
                    else if (Model.Status == TrackingStatus.Accepted || Model.Status == TrackingStatus.InProgress)
                    {
                        <!-- Accepted/InProgress - Download & Response -->
                        <div class="alert alert-primary">
                            <i class="bi bi-info-circle"></i>
                            Task-i është i pranuar. Shkarkoni dokumentin dhe vazhdoni me procesin.
                        </div>

                        <a asp-action="Download" asp-route-id="@Model.TrackingId"
                           class="btn btn-primary btn-lg me-2">
                            <i class="bi bi-download"></i> Shkarko Dokumentin Origjinal
                        </a>

                        @if (Model.ActionType == ActionType.ForResponse)
                        {
                            <a asp-controller="Response" asp-action="Create"
                               asp-route-trackingId="@Model.TrackingId"
                               class="btn btn-warning btn-lg">
                                <i class="bi bi-upload"></i> Ngarko Përgjigjen
                            </a>

                            <hr class="my-4" />

                            <div class="alert alert-light border">
                                <h6 class="alert-heading">
                                    <i class="bi bi-lightbulb"></i> Workflow për Përgjigje:
                                </h6>
                                <ol class="mb-0 small">
                                    <li>Shkarkoni dokumentin origjinal (button më sipër)</li>
                                    <li>Hartoni përgjigjen në <strong>Microsoft Word</strong> (offline)</li>
                                    <li>Printoni dokumentin e hartuar</li>
                                    <li>Merrni <strong>firmën dhe vulën</strong> nga menaxheri</li>
                                    <li>Skanoni dokumentin e firmosur në <strong>PDF</strong></li>
                                    <li>Ngarkoni PDF-në në sistem (button "Ngarko Përgjigjen")</li>
                                </ol>
                            </div>
                        }
                    }
                    else if (Model.Status == TrackingStatus.Completed)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            Task-i është përfunduar me sukses.
                            @if (Model.CompletedDate.HasValue)
                            {
                                <br />
                                <small>Përfunduar më: @Model.CompletedDate.Value.ToString("dd/MM/yyyy HH:mm")</small>
                            }
                        </div>
                    }
                    else if (Model.Status == TrackingStatus.Rejected)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle"></i>
                            Ju keni refuzuar këtë task.
                            @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                            {
                                <br />
                                <strong>Arsyeja:</strong>
 
                                @Model.RejectionReason
                            }
                            @if (Model.RejectedDate.HasValue)
                            {
                                <br />
                                <small>Refuzuar më: @Model.RejectedDate.Value.ToString("dd/MM/yyyy HH:mm")</small>
                            }
                        </div>
                    }

                    <!-- Always show Back to List -->
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-arrow-left"></i> Kthehu tek Lista
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Timeline -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history"></i> Kronologjia e Task-it
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="timeline">
                        <li class="timeline-item">
                            <div class="timeline-marker bg-primary"></div>
                            <div class="timeline-content">
                                <h6 class="mb-1">
                                    <i class="bi bi-plus-circle"></i> Task i Krijuar
                                </h6>
                                <p class="mb-0 text-muted small">
                                    @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                    @if (Model.AssignedByUser != null)
                                    {
                                        <text><br />Nga: @Model.AssignedByUser.FirstName @Model.AssignedByUser.LastName</text>
                                    }
                                </p>
                            </div>
                        </li>

                        @if (Model.IsRead && Model.ReadDate.HasValue)
                        {
                            <li class="timeline-item">
                                <div class="timeline-marker bg-info"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">
                                        <i class="bi bi-eye"></i> I Lexuar
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @Model.ReadDate.Value.ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                </div>
                            </li>
                        }

                        @if (Model.IsAccepted && Model.AcceptedDate.HasValue)
                        {
                            <li class="timeline-item">
                                <div class="timeline-marker bg-success"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">
                                        <i class="bi bi-hand-thumbs-up"></i> I Pranuar
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @Model.AcceptedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                </div>
                            </li>
                        }

                        @if (Model.IsInProgress && Model.StartedDate.HasValue)
                        {
                            <li class="timeline-item">
                                <div class="timeline-marker bg-primary"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">
                                        <i class="bi bi-arrow-repeat"></i> Në Proces
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @Model.StartedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                </div>
                            </li>
                        }

                        @if (Model.IsCompleted && Model.CompletedDate.HasValue)
                        {
                            <li class="timeline-item">
                                <div class="timeline-marker bg-success"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">
                                        <i class="bi bi-check-circle"></i> I Përfunduar
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @Model.CompletedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                        @if (!string.IsNullOrWhiteSpace(Model.CompletionComment))
                                        {
                                            <text><br />Koment: @Model.CompletionComment</text>
                                        }
                                    </p>
                                </div>
                            </li>
                        }

                        @if (Model.IsRejected && Model.RejectedDate.HasValue)
                        {
                            <li class="timeline-item">
                                <div class="timeline-marker bg-danger"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">
                                        <i class="bi bi-x-circle"></i> I Refuzuar
                                    </h6>
                                    <p class="mb-0 text-muted small">
                                        @Model.RejectedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                        @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                                        {
                                            <text><br />Arsyeja: @Model.RejectionReason</text>
                                        }
                                    </p>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.TrackingId" />

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-x-circle"></i> Refuzo Task-in
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        <strong>Task:</strong> @Model.Document.Subject
                    </p>
                    <div class="mb-3">
                        <label for="reason" class="form-label">
                            Arsyeja e Refuzimit <span class="text-danger">*</span>
                        </label>
                        <textarea name="reason" id="reason" class="form-control" rows="4"
                                  placeholder="Shkruaj arsyen e refuzimit..." required></textarea>
                        <div class="form-text">
                            Shpjego arsyen pse po e refuzon këtë task.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x"></i> Anulo
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-check2"></i> Konfirmo Refuzimin
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 12px;
        }

        .timeline {
            list-style: none;
            padding-left: 0;
            position: relative;
        }

            .timeline::before {
                content: '';
                position: absolute;
                left: 8px;
                top: 0;
                bottom: 0;
                width: 2px;
                background: #dee2e6;
            }

        .timeline-item {
            position: relative;
            padding-left: 35px;
            padding-bottom: 20px;
        }

            .timeline-item:last-child {
                padding-bottom: 0;
            }

        .timeline-marker {
            position: absolute;
            left: 0;
            top: 4px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 3px solid #fff;
            box-shadow: 0 0 0 2px #dee2e6;
        }

        .timeline-content h6 {
            font-size: 0.95rem;
            color: #495057;
        }

        .alert {
            border-radius: 8px;
        }

        .btn-lg {
            padding: 0.75rem 1.5rem;
            font-size: 1.1rem;
        }
    </style>
}