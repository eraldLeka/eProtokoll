@model List<DocumentTracking>
@using eProtokoll.Models
@{
    ViewData["Title"] = "Task-et e Mia";
    var filter = ViewBag.CurrentFilter as string ?? "all";
}

<div class="container-fluid">
    <!-- Filter Buttons -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="btn-group w-100" role="group">
                <a asp-action="Index" asp-route-filter="all"
                   class="btn @(filter == "all" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-list-ul"></i> Të Gjitha
                </a>
                <a asp-action="Index" asp-route-filter="pending"
                   class="btn @(filter == "pending" ? "btn-warning" : "btn-outline-warning")">
                    <i class="bi bi-inbox"></i> Të Reja
                </a>
                <a asp-action="Index" asp-route-filter="inprogress"
                   class="btn @(filter == "inprogress" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-arrow-repeat"></i> Në Proces
                </a>
                <a asp-action="Index" asp-route-filter="overdue"
                   class="btn @(filter == "overdue" ? "btn-danger" : "btn-outline-danger")">
                    <i class="bi bi-exclamation-triangle"></i> Të Vonuara
                </a>
                <a asp-action="Index" asp-route-filter="completed"
                   class="btn @(filter == "completed" ? "btn-success" : "btn-outline-success")">
                    <i class="bi bi-check-circle"></i> Përfunduar
                </a>
            </div>
        </div>
    </div>

    <!-- Tasks Table -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-task me-2"></i>
                        @switch (filter)
                        {
                            case "pending":
                                <text>Task Të Reja</text>
                                ; break;
                            case "inprogress":

                                <text>Task Në Proces</text>
                                ; break;
                            case "overdue":

                                <text>Task Të Vonuara</text>
                                ; break;
                            case "completed":

                                <text>Task Të Përfunduara</text>
                                ; break;
                            default:

                                <text>Të Gjitha Task-et</text>
                                ; break;
                        }
                        <span class="badge bg-secondary ms-2">@Model.Count</span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 10%">Protokolli</th>
                                        <th style="width: 30%">Subjekti</th>
                                        <th style="width: 10%">Lloji</th>
                                        <th style="width: 10%">Prioriteti</th>
                                        <th style="width: 10%">Afati</th>
                                        <th style="width: 10%">Statusi</th>
                                        <th style="width: 20%" class="text-end">Veprime</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model)
                                    {
                                        <tr class="@(task.HasDeadline && task.DueDate < DateTime.Now && task.Status != TrackingStatus.Completed ? "table-danger" : "")">
                                            <td>
                                                <strong>@task.Document.ProtocolNumber</strong>
                                                <br />
                                                <small class="text-muted">
                                                    @switch (task.Document.DocumentType)
                                                    {
                                                        case DocumentType.Incoming:
                                                            <text>📥 Hyrës</text>
                                                            ; break;
                                                        case DocumentType.Outgoing:

                                                            <text>📤 Dalës</text>
                                                            ; break;
                                                        case DocumentType.Internal:

                                                            <text>🔄 Brendshëm</text>
                                                            ; break;
                                                    }
                                                </small>
                                            </td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 350px" title="@task.Document.Subject">
                                                    @task.Document.Subject
                                                </div>
                                                @if (task.AssignedByUser != null)
                                                {
                                                    <small class="text-muted">
                                                        <i class="bi bi-person"></i>
                                                        Nga: @task.AssignedByUser.FirstName @task.AssignedByUser.LastName
                                                    </small>
                                                }
                                            </td>
                                            <td>
                                                @switch (task.ActionType)
                                                {
                                                    case ActionType.ForInformation:
                                                        <span class="badge bg-info">
                                                            <i class="bi bi-info-circle"></i> Njoftim
                                                        </span>
                                                        break;
                                                    case ActionType.ForResponse:
                                                        <span class="badge bg-warning text-dark">
                                                            <i class="bi bi-pencil"></i> Përgjigje
                                                        </span>
                                                        break;
                                                    case ActionType.ForAction:
                                                        <span class="badge bg-primary">
                                                            <i class="bi bi-lightning"></i> Veprim
                                                        </span>
                                                        break;
                                                    case ActionType.ForApproval:
                                                        <span class="badge bg-success">
                                                            <i class="bi bi-check2"></i> Miratim
                                                        </span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@task.ActionType</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @switch (task.Priority)
                                                {
                                                    case Priority.Urgent:
                                                        <span class="badge bg-danger">
                                                            <i class="bi bi-lightning-charge-fill"></i> URGENT
                                                        </span>
                                                        break;
                                                    case Priority.High:
                                                        <span class="badge bg-warning text-dark">
                                                            <i class="bi bi-exclamation-circle-fill"></i> High
                                                        </span>
                                                        break;
                                                    case Priority.Normal:
                                                        <span class="badge bg-info">Normal</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">Low</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (task.HasDeadline && task.DueDate.HasValue)
                                                {
                                                    var isOverdue = task.DueDate.Value < DateTime.Now;
                                                    var daysLeft = (task.DueDate.Value - DateTime.Now).Days;

                                                    if (isOverdue)
                                                    {
                                                        <span class="text-danger fw-bold">
                                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                                            @task.DueDate.Value.ToString("dd/MM/yyyy")
                                                        </span>
                                                    }
                                                    else if (daysLeft <= 2)
                                                    {
                                                        <span class="text-warning fw-bold">
                                                            <i class="bi bi-clock-fill"></i>
                                                            @task.DueDate.Value.ToString("dd/MM/yyyy")
                                                            <br />
                                                            <small>@daysLeft ditë</small>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            <i class="bi bi-calendar-check"></i>
                                                            @task.DueDate.Value.ToString("dd/MM/yyyy")
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (task.Status)
                                                {
                                                    case TrackingStatus.Assigned:
                                                        <span class="badge bg-warning text-dark">
                                                            <i class="bi bi-inbox"></i> Të re
                                                        </span>
                                                        break;
                                                    case TrackingStatus.Accepted:
                                                        <span class="badge bg-info">
                                                            <i class="bi bi-hand-thumbs-up"></i> Pranuar
                                                        </span>
                                                        break;
                                                    case TrackingStatus.InProgress:
                                                        <span class="badge bg-primary">
                                                            <i class="bi bi-arrow-repeat"></i> Në proces
                                                        </span>
                                                        break;
                                                    case TrackingStatus.Completed:
                                                        <span class="badge bg-success">
                                                            <i class="bi bi-check-circle"></i> Përfunduar
                                                        </span>
                                                        break;
                                                    case TrackingStatus.Rejected:
                                                        <span class="badge bg-danger">
                                                            <i class="bi bi-x-circle"></i> Refuzuar
                                                        </span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@task.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-end">
                                                <!-- INLINE ACTIONS - Conditional based on Status & ActionType -->
                                                @if (task.Status == TrackingStatus.Assigned)
                                                {
                                                    @if (task.ActionType == ActionType.ForInformation)
                                                    {
                                                        <!-- Quick action për ForInformation -->
                                                        <form asp-action="MarkAsRead" method="post" style="display:inline;">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@task.TrackingId" />
                                                            <button type="submit" class="btn btn-sm btn-success" title="Shëno si të lexuar">
                                                                <i class="bi bi-check2"></i> Lexuar
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <!-- Accept/Reject për ForResponse & Others -->
                                                        <form asp-action="Accept" method="post" style="display:inline;">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@task.TrackingId" />
                                                            <button type="submit" class="btn btn-sm btn-success" title="Pranoje task-in">
                                                                <i class="bi bi-check2"></i> Pranoje
                                                            </button>
                                                        </form>
                                                        <button class="btn btn-sm btn-danger"
                                                                onclick="openRejectModal(@task.TrackingId, '@task.Document.Subject')"
                                                                title="Refuzoje task-in">
                                                            <i class="bi bi-x"></i> Refuzoje
                                                        </button>
                                                    }
                                                }
                                                else if (task.Status == TrackingStatus.Accepted || task.Status == TrackingStatus.InProgress)
                                                {
                                                    <!-- Download button -->
                                                    <a asp-action="Download" asp-route-id="@task.TrackingId"
                                                       class="btn btn-sm btn-primary" title="Shkarko dokumentin">
                                                        <i class="bi bi-download"></i> Shkarko
                                                    </a>

                                                    <!-- Response button (if ForResponse) -->
                                                    @if (task.ActionType == ActionType.ForResponse)
                                                    {
                                                        <a asp-controller="Response" asp-action="Create"
                                                           asp-route-trackingId="@task.TrackingId"
                                                           class="btn btn-sm btn-warning" title="Ngarko përgjigjen">
                                                            <i class="bi bi-upload"></i> Përgjigje
                                                        </a>
                                                    }
                                                }

                                                <!-- Details link (always available) -->
                                                <a asp-action="Details" asp-route-id="@task.TrackingId"
                                                   class="btn btn-sm btn-outline-secondary" title="Detaje">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3 mb-1">
                                @switch (filter)
                                {
                                    case "pending":
                                        <text>Nuk ka task të reja.</text>
                                        ; break;
                                    case "inprogress":

                                        <text>Nuk ka task në proces.</text>
                                        ; break;
                                    case "overdue":

                                        <text>Nuk ka task të vonuara.</text>
                                        ; break;
                                    case "completed":

                                        <text>Nuk ka task të përfunduara.</text>
                                        ; break;
                                    default:

                                        <text>Nuk ka task për momentin.</text>
                                        ; break;
                                }
                            </p>
                            <small class="text-muted">Task-et e reja do të shfaqen këtu kur t'ju caktohen nga menaxheri.</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="rejectTaskId" />

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-x-circle"></i> Refuzo Task-in
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        <strong>Task:</strong> <span id="rejectTaskSubject"></span>
                    </p>
                    <div class="mb-3">
                        <label for="reason" class="form-label">
                            Arsyeja e Refuzimit <span class="text-danger">*</span>
                        </label>
                        <textarea name="reason" id="reason" class="form-control" rows="4"
                                  placeholder="Shkruaj arsyen e refuzimit..." required></textarea>
                        <div class="form-text">
                            Shpjego arsyen pse po e refuzon këtë task.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x"></i> Anulo
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-check2"></i> Konfirmo Refuzimin
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRejectModal(taskId, taskSubject) {
            document.getElementById('rejectTaskId').value = taskId;
            document.getElementById('rejectTaskSubject').textContent = taskSubject;
            document.getElementById('reason').value = '';
            var modal = new bootstrap.Modal(document.getElementById('rejectModal'));
            modal.show();
        }
    </script>
}

@section Styles {
    <style>
        .table tbody tr {
            transition: background-color .2s;
        }

            .table tbody tr:hover {
                background-color: rgba(13, 110, 253, .05);
            }

        .table-danger {
            background-color: rgba(220, 53, 69, .1) !important;
        }

            .table-danger:hover {
                background-color: rgba(220, 53, 69, .15) !important;
            }

        .badge {
            font-weight: 500;
            padding: .35em .65em;
        }

        .btn-group {
            box-shadow: 0 .125rem .25rem rgba(0, 0, 0, .075);
        }

        .card {
            border-radius: 12px;
        }

        .text-truncate {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>
}