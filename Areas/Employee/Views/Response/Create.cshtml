@{
    ViewData["Title"] = "Ngarko Përgjigjen";
    var tracking = ViewBag.Tracking as DocumentTracking;
}

<div class="container-fluid">
    <!-- Back Button -->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-controller="Task" asp-action="Details" asp-route-id="@tracking.TrackingId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Kthehu
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Original Document Info -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-text"></i> Dokumenti Origjinal
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td class="text-muted" style="width: 30%">Protokolli:</td>
                            <td><strong>@tracking.Document.ProtocolNumber</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Subjekti:</td>
                            <td>@tracking.Document.Subject</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Prioriteti:</td>
                            <td>
                                @switch (tracking.Document.Priority)
                                {
                                    case Priority.Urgent:
                                        <span class="badge bg-danger">URGENT</span>
                                        break;
                                    case Priority.High:
                                        <span class="badge bg-warning text-dark">High</span>
                                        break;
                                    default:
                                        <span class="badge bg-info">Normal</span>
                                        break;
                                }
                            </td>
                        </tr>
                    </table>
                    <a asp-controller="Task" asp-action="Download" asp-route-id="@tracking.TrackingId"
                       class="btn btn-sm btn-outline-primary mt-2">
                        <i class="bi bi-download"></i> Shkarko Origjinalin
                    </a>
                </div>
            </div>

            <!-- Upload Form -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-upload"></i> Ngarko Përgjigjen e Firmosur
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="trackingId" value="@tracking.TrackingId" />

                        <div class="mb-3">
                            <label for="responseSubject" class="form-label">
                                Subjekti i Përgjigjes <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="responseSubject" id="responseSubject"
                                   class="form-control" required
                                   placeholder="Përgjigje për: @tracking.Document.Subject" />
                        </div>

                        <div class="mb-3">
                            <label for="responseNotes" class="form-label">Shënime (opsionale)</label>
                            <textarea name="responseNotes" id="responseNotes"
                                      class="form-control" rows="3"
                                      placeholder="Shënime shtesë për përgjigjen..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="scannedPdf" class="form-label">
                                PDF e Firmosur <span class="text-danger">*</span>
                            </label>
                            <input type="file" name="scannedPdf" id="scannedPdf"
                                   class="form-control" accept=".pdf" required />
                            <div class="form-text">
                                <i class="bi bi-info-circle"></i>
                                Dokument i printuar, i firmosur, i vulosur dhe i skanuar në PDF (max 10MB)
                            </div>
                        </div>

                        <div class="alert alert-info border-0">
                            <h6 class="alert-heading">
                                <i class="bi bi-lightbulb"></i> Workflow:
                            </h6>
                            <ol class="mb-0 small">
                                <li>Harton përgjigjen në Word</li>
                                <li>Printon dokumentin</li>
                                <li>Merr firmën dhe vulën nga menaxheri</li>
                                <li>Skanon në PDF</li>
                                <li>Ngarkon këtu dhe dërgon për aprovim</li>
                            </ol>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-send"></i> Ngarko dhe Dërgo për Aprovim
                            </button>
                            <a asp-controller="Task" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i> Anulo
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 12px;
        }
    </style>
}