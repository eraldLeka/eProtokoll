@using eProtokoll.Models
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-house-door me-2 text-info"></i>
                Mirë se vini, @User.Identity?.Name
            </h2>
            <p class="text-muted">Përmbledhja e aktivitetit - @DateTime.Now.ToString("dd MMMM yyyy")</p>
        </div>
    </div>

    <!-- Kartelat Statistikore -->
    <div class="row mb-4">
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-file-earmark-text text-secondary" style="font-size:2rem"></i>
                    <h3 class="mt-2 mb-0">@ViewBag.TotalDocuments</h3>
                    <small class="text-muted">Gjithsej Dokumentet</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-arrow-down-circle text-info" style="font-size:2rem"></i>
                    <h3 class="mt-2 mb-0">@ViewBag.TotalIncoming</h3>
                    <small class="text-muted">Dokumente Hyrëse</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-arrow-up-circle text-success" style="font-size:2rem"></i>
                    <h3 class="mt-2 mb-0">@ViewBag.TotalOutgoing</h3>
                    <small class="text-muted">Dokumente Dalëse</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3 mb-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-arrow-left-right text-warning" style="font-size:2rem"></i>
                    <h3 class="mt-2 mb-0">@ViewBag.TotalInternal</h3>
                    <small class="text-muted">Dokumente Brendshme</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Dokumentet e Fundit & Veprime të Shpejta -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2 text-info"></i>
                        Dokumentet e Fundit
                    </h5>
                    <a asp-area="Employee" asp-controller="ProtocolBook" asp-action="Index" class="btn btn-sm btn-outline-info">
                        Libër Protokolli <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.RecentDocuments != null && ((List<Document>)ViewBag.RecentDocuments).Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Protokolli</th>
                                        <th>Subjekti</th>
                                        <th>Lloji</th>
                                        <th>Data</th>
                                        <th class="text-end">Veprime</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in (List<Document>)ViewBag.RecentDocuments)
                                    {
                                        <tr>
                                            <td><strong>@doc.ProtocolNumber</strong></td>
                                            <td>
                                                <div class="text-truncate" style="max-width:350px" title="@doc.Subject">@doc.Subject</div>
                                            </td>
                                            <td>
                                                @switch (doc.DocumentType)
                                                {
                                                    case DocumentType.Incoming:
                                                        <span class="badge bg-info"><i class="bi bi-arrow-down-circle"></i> Hyrës</span>
                                                        break;
                                                    case DocumentType.Outgoing:
                                                        <span class="badge bg-success"><i class="bi bi-arrow-up-circle"></i> Dalës</span>
                                                        break;
                                                    case DocumentType.Internal:
                                                        <span class="badge bg-warning text-dark"><i class="bi bi-arrow-left-right"></i> Brendshëm</span>
                                                        break;
                                                }
                                            </td>
                                            <td><small>@doc.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                            <td class="text-end">
                                                <a asp-area="Employee" asp-controller="ProtocolBook" asp-action="Details"
                                                   asp-route-id="@doc.DocumentId" asp-route-type="@doc.DocumentType"
                                                   class="btn btn-sm btn-outline-info">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size:3rem"></i>
                            <p class="text-muted mt-3">Nuk ka dokumente</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Veprime të Shpejta -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header text-white" style="background-color:#0aa2c0">
                    <h5 class="mb-0"><i class="bi bi-lightning-charge me-2"></i>Veprime të Shpejta</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-area="Employee" asp-controller="IncomingDocument" asp-action="Create" class="btn btn-info">
                            <i class="bi bi-arrow-down-circle me-2"></i>Dokument Hyrës
                        </a>
                        <a asp-area="Employee" asp-controller="OutgoingDocument" asp-action="Create" class="btn btn-success">
                            <i class="bi bi-arrow-up-circle me-2"></i>Dokument Dalës
                        </a>
                        <a asp-area="Employee" asp-controller="InternalDocument" asp-action="Create" class="btn btn-warning">
                            <i class="bi bi-arrow-left-right me-2"></i>Dokument Brendshëm
                        </a>
                        <hr />
                        <a asp-area="Employee" asp-controller="ProtocolBook" asp-action="Index" class="btn btn-outline-info">
                            <i class="bi bi-book me-2"></i>Libër Protokolli
                        </a>
                        <a asp-area="Employee" asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-bar-chart me-2"></i>Raportet e Mia
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Aktiviteti i 7 Ditëve -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-bar-chart-line me-2 text-info"></i>
                        Aktiviteti i 7 Ditëve të Fundit
                    </h5>
                </div>
                <div class="card-body">
                    @{
                        var dailyStats = ViewBag.DailyStats as IEnumerable<dynamic>;
                        int maxVal = dailyStats != null && dailyStats.Any()
                        ? (int)dailyStats.Max(d => (int)d.Count)
                        : 1;
                        if (maxVal == 0) maxVal = 1;
                    }
                    @if (dailyStats != null)
                    {
                        <div class="d-flex align-items-end gap-3 w-100" style="height: 180px;">
                            @foreach (var day in dailyStats)
                            {
                                int heightPct = (int)day.Count * 100 / maxVal;
                                <div class="d-flex flex-column align-items-center flex-fill h-100 justify-content-end">
                                    <small class="text-muted mb-1" style="font-size:0.7rem;">@day.Count</small>
                                    <div class="rounded-top w-75"
                                         style="height: @(Math.Max(heightPct, 2))%; background-color:#0aa2c0;">
                                    </div>
                                    <small class="text-muted mt-2" style="font-size:0.65rem;">@day.Date</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-center text-muted">Nuk ka të dhëna.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
        }
    </style>
}
