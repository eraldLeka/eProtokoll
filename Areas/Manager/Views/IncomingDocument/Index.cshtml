@model IEnumerable<eProtokoll.Models.IncomingDocument>

@{
    ViewData["Title"] = "Dokumente Hyrëse";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Dokumente Hyrëse</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-arrow-down-circle-fill me-2 text-primary"></i>
                Dokumente Hyrëse
            </h2>
            <p class="text-muted mt-2">Menaxho dokumentet që vijnë nga institucione të jashtme</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Regjistro Dokument të Ri
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Total Dokumente</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalIncoming</h2>
                            <small class="text-muted">Të gjitha</small>
                        </div>
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-files"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Sot</h6>
                            <h2 class="mb-0 fw-bold text-success">@ViewBag.TodayIncoming</h2>
                            <small class="text-success">
                                <i class="bi bi-calendar-check"></i> Të regjistruara
                            </small>
                        </div>
                        <div class="stat-icon bg-success-subtle text-success">
                            <i class="bi bi-arrow-down-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Kërkon Përgjigje</h6>
                            <h2 class="mb-0 fw-bold text-warning">@ViewBag.NeedsResponse</h2>
                            <small class="text-warning">
                                <i class="bi bi-reply"></i> Në pritje
                            </small>
                        </div>
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-chat-left-text"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Të Vonuara</h6>
                            <h2 class="mb-0 fw-bold text-danger">@ViewBag.Overdue</h2>
                            <small class="text-danger">
                                <i class="bi bi-exclamation-triangle"></i> Kaloi afati
                            </small>
                        </div>
                        <div class="stat-icon bg-danger-subtle text-danger">
                            <i class="bi bi-alarm"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-funnel me-2"></i>
                Kërko dhe Filtro
            </h5>
        </div>
        <div class="card-body">
            <form method="get" id="filterForm" class="row g-3">
                <div class="col-md-6">
                    <label for="searchTerm" class="form-label">Kërko</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                               value="@ViewBag.SearchTerm" placeholder="Nr. protokolli, subjekt, dërgues...">
                    </div>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div>
                        <button type="submit" class="btn btn-primary me-2">
                            <i class="bi bi-search me-1"></i>
                            Kërko
                        </button>
                        <a href="@Url.Action("Index", "IncomingDocument", new { area = "Manager" })" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>
                            Pastro
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Documents Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Lista e Dokumenteve (@ViewBag.TotalItems)
                    </h5>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 14%;">Nr. Protokolli</th>
                                <th style="width: 26%;">Subjekti</th>
                                <th style="width: 16%;">Institucioni Dërgues</th>
                                <th style="width: 11%;">Data e Marrjes</th>
                                <th style="width: 11%;">Prioriteti</th>
                                <th style="width: 11%;">Statusi</th>
                                <th style="width: 11%;" class="text-end">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary">@doc.ProtocolNumber</strong>
                                        <br />
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> @doc.ProtocolDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 350px;" title="@doc.Subject">
                                            <strong>@doc.Subject</strong>
                                        </div>
                                        <small class="text-muted">
                                            <i class="bi bi-person"></i> @doc.SenderName
                                        </small>
                                    </td>
                                    <td>
                                        @if (doc.Institution != null)
                                        {
                                            <span class="badge bg-light text-dark border">
                                                <i class="bi bi-building"></i> @doc.Institution.Name
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            <i class="bi bi-calendar-event"></i> @doc.ReceivedDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        @switch (doc.Priority)
                                        {
                                            case Priority.Urgent:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-lightning-charge-fill"></i> Urgjent
                                                </span>
                                                break;
                                            case Priority.High:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-triangle"></i> I Lartë
                                                </span>
                                                break;
                                            case Priority.Normal:
                                                <span class="badge bg-info">
                                                    <i class="bi bi-info-circle"></i> Normal
                                                </span>
                                                break;
                                            case Priority.Low:
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-arrow-down"></i> I Ulët
                                                </span>
                                                break;
                                        }
                                    </td>
                                 <td>
                                     @switch (doc.Status)
                                     {
                                       case DocumentStatus.Registered:
                                         <span class="badge bg-primary">Protokolluar</span>
                                          break;
                                        case DocumentStatus.InProgress:
                                         <span class="badge bg-warning text-dark">Në Proces</span>
                                          break;
                                        case DocumentStatus.Completed:
                                        <span class="badge bg-success">Përfunduar</span>
                                        break;
                                        default:
                                          <span class="badge bg-secondary">@doc.Status</span>
                                          break;
                                            }
                                  </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Details" asp-route-id="@doc.DocumentId"
                                               class="btn btn-outline-info"
                                               title="Detajet">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-outline-danger delete-document"
                                                    data-id="@doc.DocumentId"
                                                    data-protocol="@doc.ProtocolNumber"
                                                    title="Fshij">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="card-footer bg-white">
                        <nav aria-label="Pagination">
                            <ul class="pagination pagination-sm mb-0 justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { 
                                        searchTerm = ViewBag.SearchTerm, 
                                        status = ViewBag.SelectedStatus, 
                                        priority = ViewBag.SelectedPriority,
                                        institution = ViewBag.SelectedInstitution,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage - 1 
                                    })">
                                        <i class="bi bi-chevron-left"></i> Mbrapa
                                    </a>
                                </li>

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { 
                                            searchTerm = ViewBag.SearchTerm, 
                                            status = ViewBag.SelectedStatus, 
                                            priority = ViewBag.SelectedPriority,
                                            institution = ViewBag.SelectedInstitution,
                                            dateFrom = ViewBag.DateFrom,
                                            dateTo = ViewBag.DateTo,
                                            page = i 
                                        })">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { 
                                        searchTerm = ViewBag.SearchTerm, 
                                        status = ViewBag.SelectedStatus, 
                                        priority = ViewBag.SelectedPriority,
                                        institution = ViewBag.SelectedInstitution,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage + 1 
                                    })">
                                        Përpara <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                        <div class="text-center mt-2">
                            <small class="text-muted">
                                Faqja @ViewBag.CurrentPage nga @ViewBag.TotalPages (@ViewBag.TotalItems dokumente gjithsej)
                            </small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka dokumente</h4>
                    <p class="text-muted">Kliko butonin "Regjistro Dokument të Ri" për të filluar</p>
                    <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Create" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle me-1"></i>
                        Regjistro Dokument të Ri
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Konfirmo Fshirjen
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A jeni të sigurt që dëshironi të fshini dokumentin:</p>
                <p class="fw-bold text-center text-primary fs-5" id="deleteDocumentProtocol"></p>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Kujdes:</strong> Kjo do të fshijë edhe të gjitha shtojcat e dokumentit!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <form method="post" asp-area="Manager" asp-controller="IncomingDocument" asp-action="Delete" id="deleteForm" class="d-inline">
                    <input type="hidden" name="id" id="deleteDocumentId">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill me-1"></i>
                        Fshij Dokumentin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Delete document
            $('.delete-document').on('click', function() {
                const id = $(this).data('id');
                const protocol = $(this).data('protocol');
                $('#deleteDocumentProtocol').text(protocol);
                $('#deleteDocumentId').val(id);
                $('#deleteModal').modal('show');
            });
        });
    </script>
}
@section Styles {
    <style>
        .stat-card {
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .bg-primary-subtle {
            background-color: rgba(13, 110, 253, 0.1) !important;
        }

        .bg-success-subtle {
            background-color: rgba(25, 135, 84, 0.1) !important;
        }

        .bg-warning-subtle {
            background-color: rgba(255, 193, 7, 0.1) !important;
        }

        .bg-danger-subtle {
            background-color: rgba(220, 53, 69, 0.1) !important;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }

        .card {
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
        }

        .pagination .page-link {
            border-radius: 6px;
            margin: 0 2px;
        }

        .pagination .page-item.active .page-link {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }
    </style>
}