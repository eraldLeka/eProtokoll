@model eProtokoll.Models.IncomingDocument

@{
    ViewData["Title"] = "Modifiko Dokument Hyrës";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Index">Dokumente Hyrëse</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Modifiko</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-pencil-square me-2 text-primary"></i>
                Modifiko Dokument Hyrës
            </h2>
            <p class="text-muted mt-2">Përditëso të dhënat e dokumentit: <strong class="text-primary">@Model.ProtocolNumber</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Details" asp-route-id="@Model.DocumentId" class="btn btn-outline-info">
                <i class="bi bi-eye me-1"></i>
                Shiko Detajet
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
                <input type="hidden" asp-for="DocumentId" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="CreatedBy" />
                <input type="hidden" asp-for="DocumentType" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Protocol Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-hash me-2"></i>
                            Informacioni i Protokollimit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProtocolNumber" class="form-label">
                                        <i class="bi bi-file-text text-primary"></i>
                                        Numri i Protokollit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProtocolNumber" class="form-control form-control-lg fw-bold text-primary" readonly />
                                    <span asp-validation-for="ProtocolNumber" class="text-danger"></span>
                                    <small class="text-muted">Nuk mund të ndryshohet</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProtocolDate" class="form-label">
                                        Data e Protokollimit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProtocolDate" class="form-control" type="date" />
                                    <span asp-validation-for="ProtocolDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProtocolTime" class="form-label">
                                        Ora e Protokollimit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProtocolTime" class="form-control" type="time" />
                                    <span asp-validation-for="ProtocolTime" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sender Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-building me-2"></i>
                            Informacioni i Dërguesit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="InstitutionId" class="form-label">
                                        <i class="bi bi-bank text-info"></i>
                                        Institucioni Dërgues <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="InstitutionId" class="form-select" asp-items="ViewBag.Institutions">
                                        <option value="">-- Zgjidh Institucionin --</option>
                                    </select>
                                    <span asp-validation-for="InstitutionId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SenderName" class="form-label">
                                        <i class="bi bi-person text-info"></i>
                                        Emri i Dërguesit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SenderName" class="form-control" placeholder="Emri i plotë i dërguesit" />
                                    <span asp-validation-for="SenderName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SenderPosition" class="form-label">
                                        <i class="bi bi-briefcase text-info"></i>
                                        Pozicioni
                                    </label>
                                    <input asp-for="SenderPosition" class="form-control" placeholder="p.sh. Drejtor, Sekretar..." />
                                    <span asp-validation-for="SenderPosition" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SenderEmail" class="form-label">
                                        <i class="bi bi-envelope text-info"></i>
                                        Email
                                    </label>
                                    <input asp-for="SenderEmail" class="form-control" type="email" placeholder="email@example.com" />
                                    <span asp-validation-for="SenderEmail" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SenderPhone" class="form-label">
                                        <i class="bi bi-telephone text-info"></i>
                                        Telefoni
                                    </label>
                                    <input asp-for="SenderPhone" class="form-control" type="tel" placeholder="+355 69 123 4567" />
                                    <span asp-validation-for="SenderPhone" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Document Content -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-text me-2"></i>
                            Përmbajtja e Dokumentit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">
                                <i class="bi bi-chat-left-text text-success"></i>
                                Subjekti <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Subject" class="form-control" placeholder="Subjekti/Titulli i dokumentit" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">
                                <i class="bi bi-text-paragraph text-success"></i>
                                Përmbajtja/Përshkrimi
                            </label>
                            <textarea asp-for="Content" class="form-control" rows="5" placeholder="Përshkrimi i shkurtër i përmbajtjes së dokumentit..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="OriginalDocumentNumber" class="form-label">
                                        <i class="bi bi-hash text-success"></i>
                                        Nr. Origjinal i Dokumentit
                                    </label>
                                    <input asp-for="OriginalDocumentNumber" class="form-control" placeholder="Nr. që ka dokumenti i institucionit dërgues" />
                                    <span asp-validation-for="OriginalDocumentNumber" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="OriginalDocumentDate" class="form-label">
                                        <i class="bi bi-calendar text-success"></i>
                                        Data Origjinale
                                    </label>
                                    <input asp-for="OriginalDocumentDate" class="form-control" type="date" />
                                    <span asp-validation-for="OriginalDocumentDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Classification & Details -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="bi bi-shield-lock me-2"></i>
                            Klasifikimi dhe Detajet
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ClassificationId" class="form-label">
                                        <i class="bi bi-lock text-warning"></i>
                                        Klasifikimi <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="ClassificationId" class="form-select" asp-items="ViewBag.Classifications">
                                        <option value="">-- Zgjidh Klasifikimin --</option>
                                    </select>
                                    <span asp-validation-for="ClassificationId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="Status" class="form-label">
                                        Statusi <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<DocumentStatus>()">
                                    </select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="Priority" class="form-label">
                                        Prioriteti <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<Priority>()">
                                    </select>
                                    <span asp-validation-for="Priority" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ReceivedDate" class="form-label">
                                        <i class="bi bi-calendar-event text-warning"></i>
                                        Data e Marrjes <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ReceivedDate" class="form-control" type="date" />
                                    <span asp-validation-for="ReceivedDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ReceivedTime" class="form-label">
                                        <i class="bi bi-clock text-warning"></i>
                                        Ora e Marrjes <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ReceivedTime" class="form-control" type="time" />
                                    <span asp-validation-for="ReceivedTime" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="DeliveryMethod" class="form-label">
                                        <i class="bi bi-truck text-warning"></i>
                                        Mënyra e Dërgesës <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="DeliveryMethod" class="form-select" asp-items="Html.GetEnumSelectList<DeliveryMethod>()">
                                    </select>
                                    <span asp-validation-for="DeliveryMethod" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Response & Deadline -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-reply me-2"></i>
                            Përgjigja dhe Afati
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="RequiresResponse" class="form-check-input" type="checkbox" id="requiresResponseSwitch" />
                                    <label asp-for="RequiresResponse" class="form-check-label" for="requiresResponseSwitch">
                                        <i class="bi bi-chat-dots text-secondary"></i>
                                        Kërkon Përgjigje
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6" id="responseDeadlineField">
                                <div class="mb-3">
                                    <label asp-for="ResponseDeadline" class="form-label">
                                        <i class="bi bi-calendar-x text-danger"></i>
                                        Data e Kthimit të Përgjigjes
                                    </label>
                                    <input asp-for="ResponseDeadline" class="form-control" type="date" />
                                    <span asp-validation-for="ResponseDeadline" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        @if (Model.IsResponded)
                        {
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <strong>Statusi:</strong> Është përgjigjur më @Model.ResponseDate?.ToString("dd/MM/yyyy")
                            </div>
                        }
                    </div>
                </div>

                <!-- Existing Attachments -->
                @if (Model.Attachments != null && Model.Attachments.Any())
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-paperclip me-2"></i>
                                Shtojcat Ekzistuese (@Model.Attachments.Count)
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="list-group">
                                @foreach (var attachment in Model.Attachments)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1">
                                                    <i class="bi bi-file-earmark-@(attachment.FileExtension == ".pdf" ? "pdf" : attachment.FileExtension == ".docx" || attachment.FileExtension == ".doc" ? "word" : "text") text-primary"></i>
                                                    @attachment.OriginalFileName
                                                </h6>
                                                <small class="text-muted">
                                                    <i class="bi bi-hdd"></i> @attachment.FileSizeMB MB
                                                    | <i class="bi bi-calendar"></i> @attachment.UploadedDate.ToString("dd/MM/yyyy HH:mm")
                                                    | <i class="bi bi-person"></i> @attachment.UploadedBy
                                                </small>
                                            </div>
                                            <div class="btn-group btn-group-sm">
                                                <a href="@attachment.FilePath" target="_blank" class="btn btn-outline-primary" title="Shiko">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="@attachment.FilePath" download class="btn btn-outline-success" title="Shkarko">
                                                    <i class="bi bi-download"></i>
                                                </a>
                                                <button type="button" class="btn btn-outline-danger delete-attachment"
                                                        data-id="@attachment.AttachmentId"
                                                        data-name="@attachment.OriginalFileName"
                                                        title="Fshij">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- New File Upload -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-plus-circle me-2"></i>
                            Shto Bashkëngjitje të Re
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="attachmentFile" class="form-label">
                                <i class="bi bi-file-earmark-arrow-up text-dark"></i>
                                Ngarko Skedarin e Ri
                            </label>
                            <input type="file" class="form-control" id="attachmentFile" name="attachmentFile" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" />
                            <small class="text-muted">Formatet e lejuara: PDF, Word, Imazhe (max 10MB)</small>
                        </div>
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Shënim:</strong> Shtojcat e reja do të shtohen bashkë me ato ekzistuese.
                        </div>
                    </div>
                </div>

                <!-- Physical Copy -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-box-seam me-2 text-muted"></i>
                            Kopja Fizike
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="HasPhysicalCopy" class="form-check-input" type="checkbox" />
                                    <label asp-for="HasPhysicalCopy" class="form-check-label">
                                        <i class="bi bi-archive text-muted"></i>
                                        Ka Kopje Fizike (në arkiv)
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="PhysicalLocation" class="form-label">
                                        <i class="bi bi-geo-alt text-muted"></i>
                                        Vendndodhja Fizike
                                    </label>
                                    <input asp-for="PhysicalLocation" class="form-control" placeholder="p.sh. Arkivi A, Rafte 5, Kutia 12" />
                                    <span asp-validation-for="PhysicalLocation" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-sticky me-2 text-muted"></i>
                            Shënime Shtesë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">
                                <i class="bi bi-pencil-square text-muted"></i>
                                Shënime/Komente
                            </label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Shënime ose komente shtesë për këtë dokument..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Metadata Info -->
                <div class="card shadow-sm mb-4 bg-light">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Metadata e Dokumentit
                        </h6>
                        <div class="row small">
                            <div class="col-md-6">
                                <p class="mb-2">
                                    <strong>Krijuar nga:</strong> @Model.Creator?.FullName (@Model.CreatedBy)
                                </p>
                                <p class="mb-2">
                                    <strong>Data e krijimit:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>
                            <div class="col-md-6">
                                @if (Model.ModifiedDate.HasValue)
                                {
                                    <p class="mb-2">
                                        <strong>Modifikuar nga:</strong> @Model.ModifiedBy
                                    </p>
                                    <p class="mb-2">
                                        <strong>Data e modifikimit:</strong> @Model.ModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                }
                                else
                                {
                                    <p class="text-muted mb-2">
                                        <em>Nuk është modifikuar ende</em>
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-1"></i>
                                    Kthehu në Listë
                                </a>
                                <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Details" asp-route-id="@Model.DocumentId" class="btn btn-outline-info">
                                    <i class="bi bi-eye me-1"></i>
                                    Shiko Detajet
                                </a>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-save me-1"></i>
                                Përditëso Dokumentin
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-warning sticky-top" style="top: 20px;">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Vërejtje
                    </h5>
                </div>
                <div class="card-body small">
                    <h6 class="text-warning">
                        <i class="bi bi-info-circle-fill"></i> Modifiko me Kujdes
                    </h6>
                    <p class="mb-3">
                        Duke modifikuar këtë dokument, ju do të ndryshoni informacionin zyrtar të protokolluar.
                    </p>
                    <hr />
                    <h6 class="text-warning">
                        <i class="bi bi-lock-fill"></i> Të Kyçura
                    </h6>
                    <ul class="ps-3 mb-3">
                        <li>Numri i Protokollit</li>
                        <li>Lloji i Dokumentit</li>
                    </ul>
                    <hr />
                    <h6 class="text-warning">
                        <i class="bi bi-trash-fill"></i> Fshirja e Shtojcave
                    </h6>
                    <p class="mb-3 text-danger small">
                        <strong>KUJDES:</strong> Shtojcat e fshira nuk mund të rikthehen!
                    </p>
                    <hr />
                    <div class="text-muted small">
                        <strong>Dokumenti ID:</strong> @Model.DocumentId
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Attachment Modal -->
<div class="modal fade" id="deleteAttachmentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Fshij Bashkëngjitjen
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A jeni të sigurt që dëshironi të fshini bashkëngjitjen:</p>
                <p class="fw-bold text-center text-primary" id="deleteAttachmentName"></p>
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>KUJDES:</strong> Kjo veprim nuk mund të zhbëhet!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteAttachment">
                    <i class="bi bi-trash-fill me-1"></i>
                    Fshij
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Show/hide response deadline field
            function toggleResponseDeadline() {
                if ($('#requiresResponseSwitch').is(':checked')) {
                    $('#responseDeadlineField').slideDown();
                } else {
                    $('#responseDeadlineField').slideUp();
                    $('#ResponseDeadline').val('');
                }
            }

            $('#requiresResponseSwitch').on('change', toggleResponseDeadline);
            toggleResponseDeadline(); // Initialize on load

            // File upload validation
            $('#attachmentFile').on('change', function() {
                const file = this.files[0];
                if (file) {
                    const fileSize = file.size / 1024 / 1024; // in MB
                    const allowedTypes = ['.pdf', '.doc', '.docx', '.jpg', '.jpeg', '.png'];
                    const fileExt = '.' + file.name.split('.').pop().toLowerCase();

                    if (fileSize > 10) {
                        alert('Skedari është shumë i madh! Madhësia maksimale është 10MB.');
                        $(this).val('');
                        return false;
                    }

                    if (!allowedTypes.includes(fileExt)) {
                        alert('Format i pasaktë! Formatet e lejuara janë: PDF, Word, Imazhe');
                        $(this).val('');
                        return false;
                    }
                }
            });

            // Delete attachment
            let attachmentIdToDelete = null;

            $('.delete-attachment').on('click', function() {
                attachmentIdToDelete = $(this).data('id');
                const attachmentName = $(this).data('name');
                $('#deleteAttachmentName').text(attachmentName);
                $('#deleteAttachmentModal').modal('show');
            });

            $('#confirmDeleteAttachment').on('click', function() {
                if (attachmentIdToDelete) {
                    $.ajax({
                        url: '@Url.Action("DeleteAttachment", "IncomingDocument", new { area = "Manager" })',
                        type: 'POST',
                        data: { id: attachmentIdToDelete },
                        success: function(response) {
                            if (response.success) {
                                $('#deleteAttachmentModal').modal('hide');
                                location.reload(); // Reload to show updated list
                            } else {
                                alert('Gabim: ' + response.message);
                            }
                        },
                        error: function() {
                            alert('Ka ndodhur një gabim gjatë fshirjes së shtojcës!');
                        }
                    });
                }
            });

            // Form validation
            $('#editForm').on('submit', function(e) {
                let isValid = true;
                let errorMessage = '';

                if (!$('#InstitutionId').val()) {
                    isValid = false;
                    errorMessage += '- Institucioni dërgues është i detyrueshëm\n';
                }

                if (!$('#SenderName').val()) {
                    isValid = false;
                    errorMessage += '- Emri i dërguesit është i detyrueshëm\n';
                }

                if (!$('#Subject').val()) {
                    isValid = false;
                    errorMessage += '- Subjekti është i detyrueshëm\n';
                }

                if (!$('#ClassificationId').val()) {
                    isValid = false;
                    errorMessage += '- Klasifikimi është i detyrueshëm\n';
                }

                if (!isValid) {
                    e.preventDefault();
                    alert('Ju lutem plotësoni fushat e detyrueshme:\n\n' + errorMessage);
                    return false;
                }
            });
        });
    </script>
}

