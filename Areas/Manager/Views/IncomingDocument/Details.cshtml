@model eProtokoll.Models.IncomingDocument

@{
    ViewData["Title"] = "Detajet e Dokumentit";
}

<div class="container-fluid">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Index">Dokumente Hyrëse</a>
            </li>
            <li class="breadcrumb-item active">@Model.ProtocolNumber</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-2">
                <i class="bi bi-file-earmark-text-fill me-2 text-info"></i>
                @Model.Subject
            </h2>
            <div class="d-flex gap-2 flex-wrap">
                <span class="badge bg-info fs-6">@Model.ProtocolNumber</span>

                @switch (Model.Status)
                {
                    case DocumentStatus.Registered:
                        <span class="badge bg-primary fs-6">Protokolluar</span>
                        ; break;
                    case DocumentStatus.InProgress:
                        <span class="badge bg-warning text-dark fs-6">Në Proces</span>
                        ; break;
                    case DocumentStatus.Completed:
                        <span class="badge bg-success fs-6">Përfunduar</span>
                        ; break;
                }

                @if (Model.Priority == Priority.Urgent)
                {
                    <span class="badge bg-danger fs-6">Urgjent</span>
                }
            </div>
        </div>

        <div class="col-md-4 text-end">
            <div class="btn-group">
                <button onclick="window.print()" class="btn btn-outline-secondary">
                    <i class="bi bi-printer"></i>
                </button>
                <button data-bs-toggle="modal" data-bs-target="#deleteModal" class="btn btn-danger">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <!-- PROTOKOLLI -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-hash"></i> Protokolli</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <small class="text-muted">Numri i Protokollit</small>
                            <h5 class="text-info">@Model.ProtocolNumber</h5>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Data e Protokollimit</small>
                            <h6><i class="bi bi-calendar"></i> @Model.ProtocolDate.ToString("dd/MM/yyyy")</h6>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Ora e Protokollimit</small>
                            <h6><i class="bi bi-clock"></i> @Model.ProtocolTime.ToString(@"hh\:mm")</h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- INFORMACIONI I DËRGUESIT -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-building me-2"></i>
                        Informacioni i Dërguesit
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Institucioni Dërgues</small>
                            <h6>
                                <i class="bi bi-bank text-primary"></i>
                                @(Model.Institution?.Name ?? "N/A")
                            </h6>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Emri i Dërguesit</small>
                            <h6>
                                <i class="bi bi-person text-primary"></i>
                                @Model.SenderName
                            </h6>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.OriginalDocumentNumber))
                    {
                        <hr />
                        <div class="row">
                            <div class="col-md-6">
                                <small class="text-muted">Nr. Origjinal i Dokumentit</small>
                                <h6>@Model.OriginalDocumentNumber</h6>
                            </div>
                            @if (Model.OriginalDocumentDate.HasValue)
                            {
                                <div class="col-md-6">
                                    <small class="text-muted">Data e Dokumentit Origjinal</small>
                                    <h6>@Model.OriginalDocumentDate.Value.ToString("dd/MM/yyyy")</h6>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- INFORMACION -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Informacion</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Klasifikimi</small>
                            <h6>
                                <i class="bi bi-shield-lock text-warning"></i>
                                @(Model.Classification?.Name ?? "N/A")
                            </h6>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Statusi</small>
                            <h6>
                                @switch (Model.Status)
                                {
                                    case DocumentStatus.Registered:
                                        <span class="badge bg-primary">Protokolluar</span>
                                        ; break;
                                    case DocumentStatus.InProgress:
                                        <span class="badge bg-warning text-dark">Në Proces</span>
                                        ; break;
                                    case DocumentStatus.Completed:
                                        <span class="badge bg-success">Përfunduar</span>
                                        ; break;
                                    default:
                                        <span class="badge bg-secondary">@Model.Status</span>
                                        ; break;
                                }
                            </h6>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Prioriteti</small>
                            <h6>
                                @switch (Model.Priority)
                                {
                                    case Priority.Urgent:
                                        <span class="badge bg-danger">Urgjent</span>
                                        ; break;
                                    case Priority.High:
                                        <span class="badge bg-warning text-dark">I Lartë</span>
                                        ; break;
                                    case Priority.Normal:
                                        <span class="badge bg-info">Normal</span>
                                        ; break;
                                    case Priority.Low:
                                        <span class="badge bg-secondary">I Ulët</span>
                                        ; break;
                                }
                            </h6>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Bashkëngjitje</small>
                            <h6>
                                @if (Model.HasAttachments && Model.Attachments != null && Model.Attachments.Any())
                                {
                                    <i class="bi bi-check-circle text-success"></i>
                                    <span>@Model.Attachments.Count file</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted"></i>
                                    <span>Asnjë</span>
                                }
                            </h6>
                        </div>
                    </div>
                </div>
            </div>
     
            <!-- BASHKËNGJITJET -->
            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-paperclip"></i>
                            Bashkëngjitjet (@Model.Attachments.Count)
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var att in Model.Attachments.OrderBy(a => a.DisplayOrder))
                            {
                                <div class="list-group-item d-flex align-items-center">
                                    <div class="me-3">
                                        @if (att.FileExtension == ".pdf")
                                        {
                                            <i class="bi bi-file-pdf-fill text-danger" style="font-size:2rem;"></i>
                                        }
                                        else if (att.FileExtension == ".docx" || att.FileExtension == ".doc")
                                        {
                                            <i class="bi bi-file-word-fill text-primary" style="font-size:2rem;"></i>
                                        }
                                        else if (att.FileExtension == ".xlsx" || att.FileExtension == ".xls")
                                        {
                                            <i class="bi bi-file-excel-fill text-success" style="font-size:2rem;"></i>
                                        }
                                        else if (att.FileExtension == ".jpg" || att.FileExtension == ".jpeg" || att.FileExtension == ".png")
                                        {
                                            <i class="bi bi-file-image-fill text-info" style="font-size:2rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-file-fill text-secondary" style="font-size:2rem;"></i>
                                        }
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1">
                                            @att.OriginalFileName
                                            @if (att.IsPrimaryDocument)
                                            {
                                                <span class="badge bg-primary ms-2">Kryesor</span>
                                            }
                                        </h6>
                                        <small class="text-muted">
                                            @att.FileSizeMB MB |
                                            Ngarkuar: @att.UploadedDate.ToString("dd/MM/yyyy HH:mm") |
                                            Nga: @(Model.Creator!.FullName)
                                        </small>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@att.FilePath" target="_blank" class="btn btn-outline-primary">
                                            <i class="bi bi-eye"></i> Shiko
                                        </a>
                                        <a href="@att.FilePath" download class="btn btn-outline-success">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            <!-- SHËNIME -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-sticky"></i> Shënime</h6>
                    </div>
                    <div class="card-body">
                        <p class="bg-light p-3 rounded border">@Model.Notes</p>
                    </div>
                </div>
            }

            <!-- METADATA -->
            <div class="card shadow-sm mb-4 bg-light">
                <div class="card-body small">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Krijuar nga:</strong> @(Model.Creator!.FullName)<br />
                            <strong>Data e Krijimit:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i>
                    Fshij Dokumentin
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Jeni të sigurt që dëshironi të fshini këtë dokument?</p>
                <div class="alert alert-info mb-2">
                    <strong>Protokoll:</strong> @Model.ProtocolNumber<br />
                    <strong>Subjekt:</strong> @Model.Subject
                </div>
                <div class="alert alert-danger mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Kjo veprim do të fshijë përgjithmonë dokumentin dhe të gjitha të dhënat e tij!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <form method="post" asp-action="Delete" class="d-inline">
                    <input type="hidden" name="id" value="@Model.DocumentId">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Fshij Dokumentin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            font-weight: 600;
        }

        @@media print {
            .btn, .breadcrumb, .modal, nav {
                display: none !important;
            }
        }
    </style>
}