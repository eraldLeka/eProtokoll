@model eProtokoll.Models.IncomingDocument

@{
    ViewData["Title"] = "Regjistro Dokument Hyrës";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Index">Dokumente Hyrëse</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Regjistro të Ri</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0">
                <i class="bi bi-file-earmark-plus me-2 text-info"></i>
                Regjistro Dokument Hyrës të Ri
            </h2>
            <p class="text-muted mt-2">Plotëso të dhënat e dokumentit që vjen nga institucioni i jashtëm</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">
            <form asp-area="Manager" asp-controller="IncomingDocument" asp-action="Create" method="post" enctype="multipart/form-data" id="createForm">
                @Html.AntiForgeryToken()
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                }
                <!-- Protocol Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-hash me-2"></i>
                            Informacioni i Protokollimit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ProtocolNumber" class="form-label">
                                        <i class="bi bi-file-text text-info"></i>
                                        Numri i Protokollit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProtocolNumber"
                                           class="form-control form-control-lg fw-bold text-info"
                                           readonly />
                                    <span asp-validation-for="ProtocolNumber" class="text-danger"></span>
                                    <small class="text-muted">Gjenerohet automatikisht</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sender Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-building me-2"></i>
                            Informacioni i Dërguesit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="InstitutionId" class="form-label">
                                        <i class="bi bi-bank text-primary"></i>
                                        Institucioni Dërgues <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="InstitutionId" class="form-select" asp-items="ViewBag.Institutions">
                                        <option value="">-- Zgjidh Institucionin --</option>
                                    </select>
                                    <span asp-validation-for="InstitutionId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SenderName" class="form-label">
                                        <i class="bi bi-person text-primary"></i>
                                        Emri i Dërguesit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SenderName" class="form-control" placeholder="Emri i plotë i dërguesit" />
                                    <span asp-validation-for="SenderName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Document Content -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-text me-2"></i>
                            Përmbajtja e Dokumentit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">
                                <i class="bi bi-chat-left-text text-success"></i>
                                Subjekti <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Subject" class="form-control" placeholder="Subjekti/Titulli i dokumentit" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">
                                <i class="bi bi-text-paragraph text-success"></i>
                                Përshkrimi
                            </label>
                            <textarea asp-for="Content" class="form-control" rows="5" placeholder="Përshkrimi i shkurtër i përmbajtjes së dokumentit..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="OriginalDocumentNumber" class="form-label">
                                        <i class="bi bi-hash text-success"></i>
                                        Nr. Origjinal i Dokumentit
                                    </label>
                                    <input asp-for="OriginalDocumentNumber" class="form-control" placeholder="Nr. që ka dokumenti i institucionit dërgues" />
                                    <span asp-validation-for="OriginalDocumentNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Classification & Details -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="bi bi-shield-lock me-2"></i>
                            Klasifikimi dhe Detajet
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ClassificationId" class="form-label">
                                        <i class="bi bi-lock text-warning"></i>
                                        Klasifikimi <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="ClassificationId" class="form-select" asp-items="ViewBag.Classifications">
                                        <option value="">-- Zgjidh Klasifikimin --</option>
                                    </select>
                                    <span asp-validation-for="ClassificationId" class="text-danger"></span>
                                </div>
                            </div
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ReceivedDate" class="form-label">
                                        <i class="bi bi-calendar-event text-warning"></i>
                                        Data e Marrjes <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ReceivedDate" class="form-control" type="date" />
                                    <span asp-validation-for="ReceivedDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- File Upload -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-paperclip me-2"></i>
                                Bashkëngjitja e Dokumentit
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                            <label for="attachmentFile" class="form-label">
                                <i class="bi bi-file-earmark-arrow-up text-dark"></i>
                                Ngarko Skedarin
                                <span class="text-danger">*</span>
                            </label>

                                <input type="file" class="form-control" id="attachmentFile" name="attachmentFile" accept=".pdf" required />
                            </div>
                            <div class="alert alert-info mb-0 d-none" id="attachmentInfoAlert">
                                <i class="bi bi-info-circle me-2"></i>
                            </div>
                        </div>
                    </div>

                <!-- Notes -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-sticky me-2 text-muted"></i>
                            Shënime Shtesë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">
                                <i class="bi bi-pencil-square text-muted"></i>
                                Shënime/Komente
                            </label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Shënime ose komente shtesë për këtë dokument..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>
                                Kthehu
                            </a>
                            <button type="submit" class="btn btn-info btn-lg px-5" id="submitBtn">
                                <i class="bi bi-save me-1"></i>
                                Ruaj Dokumentin
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div
                    <div class="alert alert-info mb-0 small">
                        <i class="bi bi-person-check me-1"></i>
                        <strong>Krijuar nga:</strong> @User.Identity?.Name
                    </div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

@section Styles {
    <style>
        .form-control:focus,
        .form-select:focus {
            border-color: #0dcaf0;
            box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.15);
        }

        .card {
            border: none;
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            font-weight: 600;
        }

        .breadcrumb-item a {
            text-decoration: none;
        }

        .sticky-top {
            position: sticky;
            z-index: 1020;
        }

        .form-label {
            font-weight: 500;
        }

        .form-check-label {
            font-weight: 500;
        }

        .btn-lg {
            padding: 0.75rem 2rem;
        }
    </style>
}