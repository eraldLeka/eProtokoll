@model eProtokoll.Models.OutgoingDocument

@{
    ViewData["Title"] = "Regjistro Dokument Dalës";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Index">Dokumente Dalëse</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Regjistro të Ri</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0">
                <i class="bi bi-file-earmark-arrow-up me-2 text-success"></i>
                Regjistro Dokument Dalës të Ri
            </h2>
            <p class="text-muted mt-2">Plotëso të dhënat e dokumentit që dërgohet tek institucioni i jashtëm</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">
            <form asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Create" method="post" enctype="multipart/form-data" id="createForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Protocol Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-hash me-2"></i>
                            Informacioni i Protokollimit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProtocolNumber" class="form-label">
                                        <i class="bi bi-file-text text-info"></i>
                                        Numri i Protokollit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProtocolNumber" class="form-control form-control-lg fw-bold text-info" readonly />
                                    <input type="hidden" asp-for="ProtocolNumber" />
                                    <small class="text-muted">Gjenerohet automatikisht</small>
                                </div>
                            </div>


                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProtocolDate" class="form-label">
                                        Data e Protokollimit 
                                    </label>
                                    <input asp-for="ProtocolDate" class="form-control" type="date" readonly />
                                    <span asp-validation-for="ProtocolDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProtocolTime" class="form-label">
                                        Ora e Protokollimit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="ProtocolTime" class="form-control" type="time"  readonly />
                                    <span asp-validation-for="ProtocolTime" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recipient Information -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-building me-2"></i>
                            Informacioni i Marrësit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="InstitutionId" class="form-label">
                                        <i class="bi bi-bank text-info"></i>
                                        Institucioni Marrës <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="InstitutionId" class="form-select" asp-items="ViewBag.Institutions">
                                        <option value="">-- Zgjidh Institucionin --</option>
                                    </select>
                                    <span asp-validation-for="InstitutionId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="RecipientName" class="form-label">
                                        <i class="bi bi-person text-info"></i>
                                        Emri i Marrësit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RecipientName" class="form-control" placeholder="Emri i plotë i marrësit" />
                                    <span asp-validation-for="RecipientName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div> 
                <!-- Document Content -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-text me-2"></i>
                            Përmbajtja e Dokumentit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">
                                <i class="bi bi-chat-left-text text-primary"></i>
                                Subjekti <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Subject" class="form-control" placeholder="Subjekti/Titulli i dokumentit" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">
                                <i class="bi bi-text-paragraph text-primary"></i>
                                Përmbajtja/Përshkrimi
                            </label>
                            <textarea asp-for="Content" class="form-control" rows="5" placeholder="Përshkrimi i shkurtër i përmbajtjes së dokumentit..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Response to Incoming Document -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-reply me-2"></i>
                            Lidhja me Dokumentin Hyrës
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="IsResponse" class="form-check-input" type="checkbox" id="isResponseSwitch" />
                                    <label asp-for="IsResponse" class="form-check-label" for="isResponseSwitch">
                                        <i class="bi bi-arrow-return-left text-secondary"></i>
                                        Është Përgjigje për Dokument Hyrës
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6" id="originalDocumentField" style="display: none;">
                                <div class="mb-3">
                                    <label asp-for="OriginalIncomingDocumentId" class="form-label">
                                        <i class="bi bi-file-earmark-arrow-down text-secondary"></i>
                                        Dokumenti Hyrës Origjinal
                                    </label>
                                    <select asp-for="OriginalIncomingDocumentId" class="form-select" asp-items="ViewBag.IncomingDocuments">
                                        <option value="">-- Zgjidh Dokumentin --</option>
                                    </select>
                                    <span asp-validation-for="OriginalIncomingDocumentId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Classification & Details -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="bi bi-shield-lock me-2"></i>
                            Klasifikimi dhe Detajet
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ClassificationId" class="form-label">
                                        <i class="bi bi-lock text-warning"></i>
                                        Klasifikimi <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="ClassificationId" class="form-select" asp-items="ViewBag.Classifications">
                                        <option value="">-- Zgjidh Klasifikimin --</option>
                                    </select>
                                    <span asp-validation-for="ClassificationId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- File Upload -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-paperclip me-2"></i>
                            Bashkëngjitja e Dokumentit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="attachmentFile" class="form-label">
                                <i class="bi bi-file-earmark-arrow-up text-dark"></i>
                                Ngarko Skedarin
                            </label>
                            <input type="file" class="form-control" id="attachmentFile" name="attachmentFile" accept=".pdf" />
                        </div>
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                        </div>
                    </div>
                </div>

                <!-- Archive Copy -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-archive me-2 text-muted"></i>
                            Kopja për Arkiv
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ArchiveLocation" class="form-label">
                                        <i class="bi bi-geo-alt text-muted"></i>
                                        Vendndodhja në Arkiv
                                    </label>
                                    <input asp-for="ArchiveLocation" class="form-control" placeholder="p.sh. Arkivi B, Rafte 3, Kutia 8" />
                                    <span asp-validation-for="ArchiveLocation" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Notes -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="bi bi-sticky me-2 text-muted"></i>
                            Shënime Shtesë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">
                                <i class="bi bi-pencil-square text-muted"></i>
                                Shënime/Komente
                            </label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Shënime ose komente shtesë për këtë dokument..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>
                                Kthehu
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5" id="submitBtn">
                                <i class="bi bi-save me-1"></i>
                                Ruaj Dokumentin
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
                      $(document).ready(function () {
                    console.log("Page loaded - form ready");

                    function toggleOriginalDocument() {
                        if ($('#isResponseSwitch').is(':checked')) {
                            $('#originalDocumentField').slideDown();
                        } else {
                            $('#originalDocumentField').slideUp();
                            $('#OriginalIncomingDocumentId').val('');
                        }
                    }

                    $('#isResponseSwitch').on('change', toggleOriginalDocument);
                    toggleOriginalDocument(); 
                });

    </script>
}

@section Styles {
    <style>
        .form-control:focus,
        .form-select:focus {
            border-color: #198754;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15);
        }

        .card {
            border: none;
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            font-weight: 600;
        }

        .breadcrumb-item a {
            text-decoration: none;
        }

        .sticky-top {
            position: sticky;
            z-index: 1020;
        }

        .form-label {
            font-weight: 500;
        }

        .form-check-label {
            font-weight: 500;
        }

        .btn-lg {
            padding: 0.75rem 2rem;
        }
    </style>
}