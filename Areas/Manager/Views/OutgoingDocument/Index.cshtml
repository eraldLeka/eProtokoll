@model IEnumerable<eProtokoll.Models.OutgoingDocument>

@{
    ViewData["Title"] = "Dokumente Dalëse";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Dokumente Dalëse</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-arrow-up-circle-fill me-2 text-success"></i>
                Dokumente Dalëse
            </h2>
            <p class="text-muted mt-2">Menaxho dokumentet që dërgohen tek institucione të jashtme</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle me-1"></i>
                Regjistro Dokument të Ri
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Total Dokumente</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalOutgoing</h2>
                            <small class="text-muted">Të gjitha</small>
                        </div>
                        <div class="stat-icon bg-success-subtle text-success">
                            <i class="bi bi-files"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Sot</h6>
                            <h2 class="mb-0 fw-bold text-success">@ViewBag.TodayOutgoing</h2>
                            <small class="text-success">
                                <i class="bi bi-calendar-check"></i> Të regjistruara
                            </small>
                        </div>
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-arrow-up-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Në Pritje</h6>
                            <h2 class="mb-0 fw-bold text-warning">@ViewBag.PendingSend</h2>
                            <small class="text-warning">
                                <i class="bi bi-hourglass-split"></i> Për dërgim
                            </small>
                        </div>
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-clock-history"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Të Dërguara</h6>
                            <h2 class="mb-0 fw-bold text-info">@ViewBag.Sent</h2>
                            <small class="text-info">
                                <i class="bi bi-check-circle"></i> Dorëzuar
                            </small>
                        </div>
                        <div class="stat-icon bg-info-subtle text-info">
                            <i class="bi bi-send-check"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-funnel me-2"></i>
                Kërko dhe Filtro
            </h5>
        </div>
        <div class="card-body">
            <form method="get" id="filterForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="searchTerm" class="form-label">Kërko</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                                   value="@ViewBag.SearchTerm" placeholder="Nr. protokolli, subjekt, marrës...">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label for="status" class="form-label">Statusi</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">Të gjithë</option>
                            <option value="Draft" selected="@(ViewBag.SelectedStatus == "Draft")">Draft</option>
                            <option value="Registered" selected="@(ViewBag.SelectedStatus == "Registered")">Protokolluar</option>
                            <option value="InProgress" selected="@(ViewBag.SelectedStatus == "InProgress")">Në Proces</option>
                            <option value="Pending" selected="@(ViewBag.SelectedStatus == "Pending")">Në Pritje</option>
                            <option value="Completed" selected="@(ViewBag.SelectedStatus == "Completed")">Përfunduar</option>
                            <option value="Cancelled" selected="@(ViewBag.SelectedStatus == "Cancelled")">Anulluar</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="priority" class="form-label">Prioriteti</label>
                        <select class="form-select" id="priority" name="priority">
                            <option value="">Të gjithë</option>
                            <option value="Low" selected="@(ViewBag.SelectedPriority == "Low")">I Ulët</option>
                            <option value="Normal" selected="@(ViewBag.SelectedPriority == "Normal")">Normal</option>
                            <option value="High" selected="@(ViewBag.SelectedPriority == "High")">I Lartë</option>
                            <option value="Urgent" selected="@(ViewBag.SelectedPriority == "Urgent")">Urgjent</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="institution" class="form-label">Institucioni</label>
                        <select class="form-select" id="institution" name="institution">
                            <option value="">Të gjithë</option>
                            @if (ViewBag.Institutions != null)
                            {
                                @foreach (var inst in (IEnumerable<SelectListItem>)ViewBag.Institutions)
                                {
                                    <option value="@inst.Value" selected="@(ViewBag.SelectedInstitution == inst.Value)">@inst.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Periudha</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="dateFrom" name="dateFrom" value="@ViewBag.DateFrom">
                            <span class="input-group-text">deri</span>
                            <input type="date" class="form-control" id="dateTo" name="dateTo" value="@ViewBag.DateTo">
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-funnel me-1"></i>
                            Apliko Filtrat
                        </button>
                        <a href="@Url.Action("Index", "OutgoingDocument", new { area = "Manager" })" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>
                            Pastro
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Documents Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Lista e Dokumenteve (@ViewBag.TotalItems)
                    </h5>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-sm btn-outline-success" id="exportExcelBtn">
                        <i class="bi bi-file-earmark-excel me-1"></i>
                        Excel
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger" id="exportPdfBtn">
                        <i class="bi bi-file-earmark-pdf me-1"></i>
                        PDF
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">Nr. Protokolli</th>
                                <th style="width: 25%;">Subjekti</th>
                                <th style="width: 15%;">Institucioni Marrës</th>
                                <th style="width: 10%;">Data e Dërgimit</th>
                                <th style="width: 10%;">Prioriteti</th>
                                <th style="width: 10%;">Statusi Dërgese</th>
                                <th style="width: 8%;">Shtojca</th>
                                <th style="width: 10%;" class="text-end">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-success">@doc.ProtocolNumber</strong>
                                        <br />
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> @doc.ProtocolDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 350px;" title="@doc.Subject">
                                            <strong>@doc.Subject</strong>
                                        </div>
                                        <small class="text-muted">
                                            <i class="bi bi-person"></i> @doc.RecipientName
                                        </small>
                                    </td>
                                    <td>
                                        @if (doc.Institution != null)
                                        {
                                            <span class="badge bg-light text-dark border">
                                                <i class="bi bi-building"></i> @doc.Institution.Name
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (doc.SentDate.HasValue)
                                        {
                                            <small>
                                                <i class="bi bi-calendar-event"></i> @doc.SentDate.Value.ToString("dd/MM/yyyy")
                                                @if (doc.SentTime.HasValue)
                                                {
                                                    <br />
                                                    <i class="bi bi-clock"></i> @doc.SentTime.Value.ToString(@"hh\:mm")
                                                }
                                            </small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td>
                                        @switch (doc.Priority)
                                        {
                                            case Priority.Urgent:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-lightning-charge-fill"></i> Urgjent
                                                </span>
                                                break;
                                            case Priority.High:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-triangle"></i> I Lartë
                                                </span>
                                                break;
                                            case Priority.Normal:
                                                <span class="badge bg-info">
                                                    <i class="bi bi-info-circle"></i> Normal
                                                </span>
                                                break;
                                            case Priority.Low:
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-arrow-down"></i> I Ulët
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (doc.ShipmentStatus)
                                        {
                                            case ShipmentStatus.Prepared:
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-box"></i> Në Përgatitje
                                                </span>
                                                break;
                                            case ShipmentStatus.ReadyToSend:
                                                <span class="badge bg-primary">
                                                    <i class="bi bi-check-circle"></i> Gati
                                                </span>
                                                break;
                                            case ShipmentStatus.InTransit:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-truck"></i> Në Dërgim
                                                </span>
                                                break;
                                            case ShipmentStatus.Delivered:
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-all"></i> Dorëzuar
                                                </span>
                                                break;
                                            case ShipmentStatus.Failed:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle"></i> Dështoi
                                                </span>
                                                break;
                                            case ShipmentStatus.Returned:
                                                <span class="badge bg-dark">
                                                    <i class="bi bi-arrow-return-left"></i> Kthyer
                                                </span>
                                                break;
                                            default:
                                                <span class="badge bg-light text-dark">@doc.ShipmentStatus</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (doc.HasAttachments)
                                        {
                                            <i class="bi bi-paperclip text-success fs-5" title="Ka shtojca"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-dash text-muted"></i>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Details" asp-route-id="@doc.DocumentId"
                                               class="btn btn-outline-info"
                                               title="Detajet">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>
                                            <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Edit" asp-route-id="@doc.DocumentId"
                                               class="btn btn-outline-primary"
                                               title="Modifiko">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            @if (doc.ShipmentStatus != ShipmentStatus.Delivered)
                                            {
                                                <button type="button"
                                                        class="btn btn-outline-success mark-as-sent"
                                                        data-id="@doc.DocumentId"
                                                        data-protocol="@doc.ProtocolNumber"
                                                        title="Shëno si të dërguar">
                                                    <i class="bi bi-send-check"></i>
                                                </button>
                                            }
                                            <button type="button"
                                                    class="btn btn-outline-danger delete-document"
                                                    data-id="@doc.DocumentId"
                                                    data-protocol="@doc.ProtocolNumber"
                                                    title="Fshij">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="card-footer bg-white">
                        <nav aria-label="Pagination">
                            <ul class="pagination pagination-sm mb-0 justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { 
                                        searchTerm = ViewBag.SearchTerm, 
                                        status = ViewBag.SelectedStatus, 
                                        priority = ViewBag.SelectedPriority,
                                        institution = ViewBag.SelectedInstitution,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage - 1 
                                    })">
                                        <i class="bi bi-chevron-left"></i> Mbrapa
                                    </a>
                                </li>

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { 
                                            searchTerm = ViewBag.SearchTerm, 
                                            status = ViewBag.SelectedStatus, 
                                            priority = ViewBag.SelectedPriority,
                                            institution = ViewBag.SelectedInstitution,
                                            dateFrom = ViewBag.DateFrom,
                                            dateTo = ViewBag.DateTo,
                                            page = i 
                                        })">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { 
                                        searchTerm = ViewBag.SearchTerm, 
                                        status = ViewBag.SelectedStatus, 
                                        priority = ViewBag.SelectedPriority,
                                        institution = ViewBag.SelectedInstitution,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage + 1 
                                    })">
                                        Përpara <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                        <div class="text-center mt-2">
                            <small class="text-muted">
                                Faqja @ViewBag.CurrentPage nga @ViewBag.TotalPages (@ViewBag.TotalItems dokumente gjithsej)
                            </small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka dokumente</h4>
                    <p class="text-muted">Kliko butonin "Regjistro Dokument të Ri" për të filluar</p>
                    <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Create" class="btn btn-success mt-3">
                        <i class="bi bi-plus-circle me-1"></i>
                        Regjistro Dokument të Ri
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Mark as Sent Modal -->
<div class="modal fade" id="markAsSentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-send-check me-2"></i>
                    Konfirmo Dërgimin
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A jeni të sigurt që dëshironi të shënoni dokumentin si të dërguar:</p>
                <p class="fw-bold text-center text-success fs-5" id="sentDocumentProtocol"></p>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Kjo do të ndryshojë statusin e dokumentit në "Dorëzuar" dhe do të regjistrojë datën e dërgimit.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <button type="button" class="btn btn-success" id="confirmMarkAsSent">
                    <i class="bi bi-send-check me-1"></i>
                    Konfirmo Dërgimin
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Konfirmo Fshirjen
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A jeni të sigurt që dëshironi të fshini dokumentin:</p>
                <p class="fw-bold text-center text-danger fs-5" id="deleteDocumentProtocol"></p>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Kujdes:</strong> Kjo do të fshijë edhe të gjitha shtojcat e dokumentit!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <form method="post" asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Delete" id="deleteForm" class="d-inline">
                    <input type="hidden" name="id" id="deleteDocumentId">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill me-1"></i>
                        Fshij Dokumentin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let documentIdToMark = null;

            // Mark as sent
            $('.mark-as-sent').on('click', function() {
                documentIdToMark = $(this).data('id');
                const protocol = $(this).data('protocol');
                $('#sentDocumentProtocol').text(protocol);
                $('#markAsSentModal').modal('show');
            });

            $('#confirmMarkAsSent').on('click', function() {
                if (documentIdToMark) {
                    $.ajax({
                        url: '@Url.Action("MarkAsSent", "OutgoingDocument", new { area = "Manager" })',
                        type: 'POST',
                        data: { id: documentIdToMark },
                        success: function(response) {
                            if (response.success) {
                                $('#markAsSentModal').modal('hide');
                                location.reload();
                            } else {
                                alert('Gabim: ' + response.message);
                            }
                        },
                        error: function() {
                            alert('Ka ndodhur një gabim gjatë shënimit të dokumentit!');
                        }
                    });
                }
            });

            // Delete document
            $('.delete-document').on('click', function() {
                const id = $(this).data('id');
                const protocol = $(this).data('protocol');
                $('#deleteDocumentProtocol').text(protocol);
                $('#deleteDocumentId').val(id);
                $('#deleteModal').modal('show');
            });

            // Export to Excel (placeholder)
            $('#exportExcelBtn').on('click', function() {
                alert('Eksportimi në Excel do të implementohet së shpejti!');
            });

            // Export to PDF (placeholder)
            $('#exportPdfBtn').on('click', function() {
                alert('Eksportimi në PDF do të implementohet së shpejti!');
            });
        });
    </script>
}

@section Styles {
    <style>
        .stat-card {
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .bg-success-subtle {
            background-color: rgba(25, 135, 84, 0.1) !important;
        }

        .bg-primary-subtle {
            background-color: rgba(13, 110, 253, 0.1) !important;
        }

        .bg-warning-subtle {
            background-color: rgba(255, 193, 7, 0.1) !important;
        }

        .bg-info-subtle {
            background-color: rgba(13, 202, 240, 0.1) !important;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(25, 135, 84, 0.05);
        }

        .card {
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
        }

        .pagination .page-link {
            border-radius: 6px;
            margin: 0 2px;
        }

        .pagination .page-item.active .page-link {
            background-color: #198754;
            border-color: #198754;
        }
    </style>
}