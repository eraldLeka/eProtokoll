@model eProtokoll.Models.InternalDocument

@{
    ViewData["Title"] = "Detajet e Dokumentit";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="Manager" asp-controller="InternalDocument" asp-action="Index">Dokumente Brendshme</a></li>
            <li class="breadcrumb-item active">@Model.ProtocolNumber</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-2"><i class="bi bi-arrow-left-right me-2 text-warning"></i> @Model.Subject</h2>
            <div class="d-flex gap-2">
                <span class="badge bg-warning text-dark fs-6">@Model.ProtocolNumber</span>
                @switch (Model.Status)
                {
                    case DocumentStatus.Registered: <span class="badge bg-info fs-6">Protokolluar</span>; break;
                    case DocumentStatus.InProgress: <span class="badge bg-primary fs-6">Në Proces</span>; break;
                    case DocumentStatus.Completed: <span class="badge bg-success fs-6">Përfunduar</span>; break;
                }
                @if (Model.Priority == Priority.Urgent) { <span class="badge bg-danger fs-6">Urgjent</span>; }
                @if (Model.IsApproved) { <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Miratuar</span>; }
            </div>
        </div>
        <div class="col-md-4 text-end">
            <div class="btn-group">
                <button onclick="window.print()" class="btn btn-outline-secondary"><i class="bi bi-printer"></i></button>
                <a asp-action="Edit" asp-route-id="@Model.DocumentId" class="btn btn-primary"><i class="bi bi-pencil"></i> Modifiko</a>
                <button data-bs-toggle="modal" data-bs-target="#deleteModal" class="btn btn-danger"><i class="bi bi-trash"></i></button>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Protocol Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-hash"></i> Protokolli</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <small class="text-muted">Numri i Protokollit</small>
                            <h5 class="text-warning">@Model.ProtocolNumber</h5>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Data e Protokollimit</small>
                            <h6><i class="bi bi-calendar"></i> @Model.ProtocolDate.ToString("dd/MM/yyyy")</h6>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Lloji</small>
                            <h6><i class="bi bi-folder"></i> @Model.InternalType</h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Circulation Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> Qarkullimi</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Departamenti Dërgues</small>
                            <h6><i class="bi bi-box-arrow-right text-danger"></i> @Model.FromDepartment</h6>
                            @if (Model.FromUser != null)
                            {
                                <small class="text-muted">Nga: @Model.FromUser.FullName</small>
                            }
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Departamenti Marrës</small>
                            <h6><i class="bi bi-box-arrow-in-left text-success"></i> @Model.ToDepartment</h6>
                            @if (Model.ToUser != null)
                            {
                                <small class="text-muted">Për: @Model.ToUser.FullName</small>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Document Content -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-file-text"></i> Përmbajtja</h5></div>
                <div class="card-body">
                    <small class="text-muted">Subjekti</small>
                    <h5>@Model.Subject</h5>
                    @if (!string.IsNullOrEmpty(Model.Content))
                    {
                        <hr/>
                        <p class="bg-light p-3 rounded">@Model.Content</p>
                    }
                </div>
            </div>

            <!-- Response & Approval -->
            @if (Model.RequiresResponse || Model.RequiresApproval)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white"><h5 class="mb-0"><i class="bi bi-check-circle"></i> Përgjigja & Miratimi</h5></div>
                    <div class="card-body">
                        @if (Model.RequiresResponse)
                        {
                            <div class="mb-3">
                                <h6><i class="bi bi-chat-dots"></i> Kërkon Përgjigje</h6>
                                @if (Model.ResponseDeadline.HasValue)
                                {
                                    <small class="text-muted">Afati: @Model.ResponseDeadline.Value.ToString("dd/MM/yyyy")</small>
                                }
                                @if (Model.IsResponded)
                                {
                                    <br/>
                                    <span class="badge bg-success mt-2">Përgjigjur më @Model.ResponseDate?.ToString("dd/MM/yyyy")</span>
                                }
                            </div>
                        }
                        @if (Model.RequiresApproval)
                        {
                            <div>
                                <h6><i class="bi bi-shield-check"></i> Kërkon Miratim</h6>
                                @if (Model.IsApproved)
                                {
                                    <div class="alert alert-success mt-2">
                                        <i class="bi bi-check-circle-fill"></i> <strong>Miratuar</strong> më @Model.ApprovedDate?.ToString("dd/MM/yyyy")
                                        <br/>
                                        <small>Nga: @Model.Approver?.FullName</small>
                                        @if (!string.IsNullOrEmpty(Model.ApprovalComment))
                                        {
                                            <br/>
                                            <small>Koment: @Model.ApprovalComment</small>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark mt-2">Në pritje për miratim</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Attachments -->
            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white"><h5 class="mb-0"><i class="bi bi-paperclip"></i> Bashkëngjitjet (@Model.Attachments.Count)</h5></div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var att in Model.Attachments.OrderBy(a => a.DisplayOrder))
                            {
                                <div class="list-group-item d-flex align-items-center">
                                    <div class="me-3">
                                        @if (att.FileExtension == ".pdf") { <i class="bi bi-file-pdf-fill text-danger" style="font-size:2rem;"></i> }
                                        else if (att.FileExtension == ".docx" || att.FileExtension == ".doc") { <i class="bi bi-file-word-fill text-primary" style="font-size:2rem;"></i> }
                                        else { <i class="bi bi-file-fill text-secondary" style="font-size:2rem;"></i> }
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6>@att.OriginalFileName @if(att.IsPrimaryDocument){<span class="badge bg-warning text-dark ms-2">Kryesor</span>}</h6>
                                        <small class="text-muted">@att.FileSizeMB MB | @att.UploadedDate.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@att.FilePath" target="_blank" class="btn btn-outline-primary"><i class="bi bi-eye"></i> Shiko</a>
                                        <a href="@att.FilePath" download class="btn btn-outline-success"><i class="bi bi-download"></i></a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Tracking History -->
            @if (Model.Trackings != null && Model.Trackings.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white"><h5 class="mb-0"><i class="bi bi-geo-alt"></i> Gjurmimi (@Model.Trackings.Count)</h5></div>
                    <div class="card-body">
                        @foreach (var t in Model.Trackings.OrderByDescending(x => x.AssignedDate))
                        {
                            <div class="card border-secondary mb-2">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h6><i class="bi bi-person"></i> @t.AssignedToUser?.FullName</h6>
                                            <small class="text-muted">Nga: @t.AssignedByUser?.FullName</small>
                                        </div>
                                        @switch (t.Status)
                                        {
                                            case TrackingStatus.Completed: <span class="badge bg-success">Përfunduar</span>; break;
                                            case TrackingStatus.InProgress: <span class="badge bg-primary">Në Proces</span>; break;
                                            default: <span class="badge bg-secondary">@t.Status</span>; break;
                                        }
                                    </div>
                                    <p class="mb-1 mt-2"><strong>Udhëzimet:</strong> @t.Instructions</p>
                                    <small class="text-muted"><i class="bi bi-calendar"></i> @t.AssignedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Notes -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light"><h6 class="mb-0"><i class="bi bi-sticky"></i> Shënime</h6></div>
                    <div class="card-body"><p class="bg-light p-3 rounded border">@Model.Notes</p></div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top:20px;">
                <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="bi bi-info-circle"></i> Info</h6></div>
                <div class="card-body">
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Klasifikimi</small>
                        <h6><i class="bi bi-shield-lock text-secondary"></i> @Model.Classification?.Name</h6>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Statusi</small>
                        <h6>
                            @switch (Model.Status)
                            {
                                case DocumentStatus.Registered: <span class="badge bg-info">Protokolluar</span>; break;
                                case DocumentStatus.InProgress: <span class="badge bg-primary">Në Proces</span>; break;
                                case DocumentStatus.Completed: <span class="badge bg-success">Përfunduar</span>; break;
                                default: <span class="badge bg-secondary">@Model.Status</span>; break;
                            }
                        </h6>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Prioriteti</small>
                        <h6>
                            @switch (Model.Priority)
                            {
                                case Priority.Urgent: <span class="badge bg-danger">Urgjent</span>; break;
                                case Priority.High: <span class="badge bg-warning text-dark">I Lartë</span>; break;
                                case Priority.Normal: <span class="badge bg-info">Normal</span>; break;
                                default: <span class="badge bg-secondary">@Model.Priority</span>; break;
                            }
                        </h6>
                    </div>
                    @if (Model.IsConfidential)
                    {
                        <div class="mb-3 pb-3 border-bottom">
                            <span class="badge bg-danger"><i class="bi bi-shield-lock"></i> Konfidencial</span>
                        </div>
                    }
                    @if (Model.RequiresAttention)
                    {
                        <div class="mb-3 pb-3 border-bottom">
                            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Kërkon Vëmendje</span>
                        </div>
                    }
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Kopje Fizike</small>
                        <h6>
                            @if (Model.HasPhysicalCopy)
                            {
                                <i class="bi bi-check-circle text-success"></i> <span>Po</span>
                                @if (!string.IsNullOrEmpty(Model.PhysicalLocation))
                                {
                                    <br/><small class="text-muted">@Model.PhysicalLocation</small>
                                }
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-muted"></i> <span>Jo</span>
                            }
                        </h6>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted">Shtojca</small>
                        <h6>@(Model.HasAttachments ? $"{Model.Attachments?.Count} file" : "Jo")</h6>
                    </div>
                </div>
            </div>

            <!-- Metadata -->
            <div class="card shadow-sm mt-3 bg-light">
                <div class="card-body small">
                    <div><strong>ID:</strong> @Model.DocumentId</div>
                    <div><strong>Krijuar nga:</strong> @Model.Creator?.FullName</div>
                    <div><strong>Data:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                    @if (Model.ModifiedDate.HasValue)
                    {
                        <hr/>
                        <div><strong>Modifikuar:</strong> @Model.ModifiedDate.Value.ToString("dd/MM/yyyy")</div>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card shadow-sm mt-3">
                <div class="card-body p-2">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.DocumentId" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i> Modifiko</a>
                        @if (Model.RequiresApproval && !Model.IsApproved)
                        {
                            <button class="btn btn-sm btn-success" onclick="approveDocument(@Model.DocumentId, '@Model.ProtocolNumber')">
                                <i class="bi bi-check-circle"></i> Mirato
                            </button>
                        }
                        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i> Printo</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Fshij Dokumentin</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Fshij dokumentin: <strong class="text-warning">@Model.ProtocolNumber</strong>?</p>
                <div class="alert alert-danger">Kjo do të fshijë të gjitha të dhënat e dokumentit!</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <form method="post" asp-action="Delete" class="d-inline">
                    <input type="hidden" name="id" value="@Model.DocumentId">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Fshij</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-check-circle"></i> Mirato Dokumentin</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Mirato dokumentin: <strong id="approveProtocol"></strong>?</p>
                <div class="mb-3">
                    <label for="approvalComment" class="form-label">Koment (opsional):</label>
                    <textarea class="form-control" id="approvalComment" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <button type="button" class="btn btn-success" id="confirmApprove">
                    <i class="bi bi-check-circle"></i> Mirato
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let documentIdToApprove = null;

        function approveDocument(id, protocol) {
            documentIdToApprove = id;
            $('#approveProtocol').text(protocol);
            $('#approveModal').modal('show');
        }

        $(document).ready(function() {
            $('#confirmApprove').on('click', function() {
                if (documentIdToApprove) {
                    const comment = $('#approvalComment').val();
                    $.ajax({
                        url: '@Url.Action("Approve", "InternalDocument", new { area = "Manager" })',
                        type: 'POST',
                        data: { 
                            id: documentIdToApprove,
                            comment: comment
                        },
                        success: function(response) {
                            if (response.success) {
                                $('#approveModal').modal('hide');
                                location.reload();
                            } else {
                                alert('Gabim: ' + response.message);
                            }
                        },
                        error: function() {
                            alert('Ka ndodhur një gabim!');
                        }
                    });
                }
            });
        });
    </script>
}

@section Styles {
<style>
    .card { border:none; border-radius:12px; }
    .card-header { border-radius:12px 12px 0 0!important; font-weight:600; }
    .sticky-top { position:sticky; z-index:1020; }
    @@media print { .btn, .breadcrumb { display:none!important; } }
</style>
}