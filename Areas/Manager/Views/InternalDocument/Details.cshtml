@model eProtokoll.Models.InternalDocument

@{
    ViewData["Title"] = "Detajet e Dokumentit";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="Manager" asp-controller="InternalDocument" asp-action="Index">Dokumente Brendshme</a></li>
            <li class="breadcrumb-item active">@Model.ProtocolNumber</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-2"><i class="bi bi-arrow-left-right me-2 text-warning"></i> @Model.Subject</h2>
            <div class="d-flex gap-2">
                <span class="badge bg-warning text-dark fs-6">@Model.ProtocolNumber</span>
                @switch (Model.Status)
                {
                    case DocumentStatus.Registered:
                        <span class="badge bg-info fs-6">I Protokolluar</span>
                        break;
                    case DocumentStatus.InProgress:
                        <span class="badge bg-primary fs-6">Në Proces</span>
                        break;
                    case DocumentStatus.Completed:
                        <span class="badge bg-success fs-6">I Përfunduar</span>
                        break;
                }
                @switch (Model.Priority)
                {
                    case Priority.Urgent:
                        <span class="badge bg-danger fs-6">Urgjent</span>
                        break;
                    case Priority.High:
                        <span class="badge bg-warning text-dark fs-6">I Lartë</span>
                        break;
                    case Priority.Normal:
                        <span class="badge bg-info fs-6">Normal</span>
                        break;
                    case Priority.Low:
                        <span class="badge bg-secondary fs-6">I Ulët</span>
                        break;
                }
                @if (Model.IsArchived)
                {
                    <span class="badge bg-dark fs-6"><i class="bi bi-archive"></i> Arkivuar</span>
                }
            </div>
        </div>
        <div class="col-md-4 text-end">
            <div class="btn-group">
                <button onclick="window.print()" class="btn btn-outline-secondary"><i class="bi bi-printer"></i></button>
                <a asp-action="Edit" asp-route-id="@Model.DocumentId" class="btn btn-primary"><i class="bi bi-pencil"></i> Modifiko</a>
                <button data-bs-toggle="modal" data-bs-target="#deleteModal" class="btn btn-danger"><i class="bi bi-trash"></i></button>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Protocol Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-hash"></i> Protokolli</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <small class="text-muted">Numri i Protokollit</small>
                            <h5 class="text-warning">@Model.ProtocolNumber</h5>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Data e Protokollimit</small>
                            <h6><i class="bi bi-calendar"></i> @Model.ProtocolDate.ToString("dd/MM/yyyy")</h6>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Ora e Protokollimit</small>
                            <h6><i class="bi bi-clock"></i> @Model.ProtocolTime.ToString(@"hh\:mm")</h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Circulation Information -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> Qarkullimi</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Departamenti Dërgues</small>
                            @if (!string.IsNullOrEmpty(Model.FromDepartment))
                            {
                                <h6><i class="bi bi-box-arrow-right text-danger"></i> @Model.FromDepartment</h6>
                            }
                            else
                            {
                                <h6><i class="bi bi-box-arrow-right text-danger"></i> <span class="text-muted">Nuk është specifikuar</span></h6>
                            }
                            @if (Model.FromUser != null)
                            {
                                <small class="text-muted">Nga: @Model.FromUser.FullName</small>
                            }
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Departamenti Marrës</small>
                            @if (!string.IsNullOrEmpty(Model.ToDepartment))
                            {
                                <h6><i class="bi bi-box-arrow-in-left text-success"></i> @Model.ToDepartment</h6>
                            }
                            else
                            {
                                <h6><i class="bi bi-box-arrow-in-left text-success"></i> <span class="text-muted">Nuk është specifikuar</span></h6>
                            }
                            @if (Model.ToUser != null)
                            {
                                <small class="text-muted">Për: @Model.ToUser.FullName</small>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Document Content -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-file-text"></i> Përmbajtja</h5></div>
                <div class="card-body">
                    <small class="text-muted">Subjekti</small>
                    <h5>@Model.Subject</h5>

                    @if (!string.IsNullOrEmpty(Model.Content))
                    {
                        <hr />
                        <small class="text-muted">Përmbajtja</small>
                        <p class="bg-light p-3 rounded mt-2">@Model.Content</p>
                    }
                </div>
            </div>

            <!-- Classification & Details -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-secondary text-white"><h5 class="mb-0"><i class="bi bi-shield-lock"></i> Klasifikimi dhe Detaje</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Klasifikimi</small>
                            <h6><i class="bi bi-tag"></i> @Model.Classification?.Name</h6>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Prioriteti</small>
                            <h6>
                                @switch (Model.Priority)
                                {
                                    case Priority.Urgent:
                                        <span class="badge bg-danger">Urgjent</span>
                                        break;
                                    case Priority.High:
                                        <span class="badge bg-warning text-dark">I Lartë</span>
                                        break;
                                    case Priority.Normal:
                                        <span class="badge bg-info">Normal</span>
                                        break;
                                    case Priority.Low:
                                        <span class="badge bg-secondary">I Ulët</span>
                                        break;
                                }
                            </h6>
                        </div>
                    </div>
                    @if (Model.HasDeadline && Model.DeadlineDate.HasValue)
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <small class="text-muted">Afati</small>
                                <h6><i class="bi bi-calendar-check text-danger"></i> @Model.DeadlineDate.Value.ToString("dd/MM/yyyy")</h6>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Response Settings -->
            @if (Model.RequiresResponse)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white"><h5 class="mb-0"><i class="bi bi-chat-dots"></i> Përgjigja</h5></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <h6><i class="bi bi-chat-dots"></i> Kërkon Përgjigje</h6>
                            @if (Model.ResponseDeadline.HasValue)
                            {
                                <small class="text-muted">Afati: @Model.ResponseDeadline.Value.ToString("dd/MM/yyyy")</small>
                            }
                            @if (Model.IsResponded && Model.ResponseDate.HasValue)
                            {
                                <br />
                                <span class="badge bg-success mt-2">Përgjigjur më @Model.ResponseDate.Value.ToString("dd/MM/yyyy")</span>
                                @if (Model.ResponseDocument != null)
                                {
                                    <br />
                                    <small class="text-muted">Dokumenti i përgjigjes: @Model.ResponseDocument.ProtocolNumber</small>
                                }
                            }
                            else if (Model.ResponseDeadline.HasValue && Model.ResponseDeadline.Value < DateTime.Now)
                            {
                                <br />
                                <span class="badge bg-danger mt-2">Afati ka skaduar</span>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Archival Status -->
            @if (Model.IsArchived)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white"><h5 class="mb-0"><i class="bi bi-archive"></i> Statusi i Arkivimit</h5></div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <small class="text-muted">Data e Arkivimit</small>
                                <h6><i class="bi bi-calendar"></i> @Model.ArchivedDate?.ToString("dd/MM/yyyy")</h6>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">Arkivuar nga</small>
                                <h6><i class="bi bi-person"></i> @Model.ArchivedBy</h6>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Attachments -->
            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white"><h5 class="mb-0"><i class="bi bi-paperclip"></i> Bashkëngjitjet (@Model.Attachments.Count)</h5></div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var att in Model.Attachments.OrderBy(a => a.DisplayOrder))
                            {
                                <div class="list-group-item d-flex align-items-center">
                                    <div class="me-3">
                                        @if (att.FileExtension == ".pdf")
                                        {
                                            <i class="bi bi-file-pdf-fill text-danger" style="font-size:2rem;"></i>
                                        }
                                        else if (att.FileExtension == ".docx" || att.FileExtension == ".doc")
                                        {
                                            <i class="bi bi-file-word-fill text-primary" style="font-size:2rem;"></i>
                                        }
                                        else if (att.FileExtension == ".jpg" || att.FileExtension == ".jpeg" || att.FileExtension == ".png")
                                        {
                                            <i class="bi bi-file-image-fill text-success" style="font-size:2rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-file-fill text-secondary" style="font-size:2rem;"></i>
                                        }
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6>@att.OriginalFileName</h6>
                                        <small class="text-muted">
                                            @att.FileSizeMB MB | @att.UploadedDate.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@att.FilePath" target="_blank" class="btn btn-outline-primary"><i class="bi bi-eye"></i> Shiko</a>
                                        <a href="@att.FilePath" download class="btn btn-outline-success"><i class="bi bi-download"></i></a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Tracking History -->
            @if (Model.Trackings != null && Model.Trackings.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white"><h5 class="mb-0"><i class="bi bi-geo-alt"></i> Gjurmimi (@Model.Trackings.Count)</h5></div>
                    <div class="card-body">
                        @foreach (var t in Model.Trackings.OrderByDescending(x => x.AssignedDate))
                        {
                            <div class="card border-secondary mb-2">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6><i class="bi bi-person"></i> @t.AssignedToUser?.FullName</h6>
                                            <small class="text-muted">Nga: @t.AssignedByUser?.FullName</small>
                                            <br />
                                            <small class="text-muted"><i class="bi bi-calendar"></i> @t.AssignedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>
                                        <div class="text-end">
                                            @switch (t.Priority)
                                            {
                                                case Priority.Urgent:
                                                    <span class="badge bg-danger">Urgjent</span>
                                                    break;
                                                case Priority.High:
                                                    <span class="badge bg-warning text-dark">I Lartë</span>
                                                    break;
                                                case Priority.Normal:
                                                    <span class="badge bg-info">Normal</span>
                                                    break;
                                                case Priority.Low:
                                                    <span class="badge bg-secondary">I Ulët</span>
                                                    break;
                                            }
                                            @if (t.IsActive)
                                            {
                                                <br />
                                                <span class="badge bg-primary mt-1">Aktiv</span>
                                            }
                                            else
                                            {
                                                <br />
                                                <span class="badge bg-secondary mt-1">Jo Aktiv</span>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(t.Notes))
                                    {
                                        <p class="mb-1 mt-2"><strong>Shënime:</strong> @t.Notes</p>
                                    }
                                    @if (t.DueDate.HasValue)
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-calendar-check"></i> Afati: @t.DueDate.Value.ToString("dd/MM/yyyy")
                                        </small>
                                    }
                                    @if (t.CompletedDate.HasValue)
                                    {
                                        <br />
                                        <small class="text-success">
                                            <i class="bi bi-check-circle"></i> Përfunduar: @t.CompletedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Deadlines -->
            @if (Model.Deadlines != null && Model.Deadlines.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-danger text-white"><h5 class="mb-0"><i class="bi bi-calendar-check"></i> Afatet (@Model.Deadlines.Count)</h5></div>
                    <div class="card-body">
                        @foreach (var deadline in Model.Deadlines.OrderBy(d => d.DueDate))
                        {
                            <div class="card border-danger mb-2">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h6><i class="bi bi-calendar-x"></i> @deadline.Title</h6>
                                            <p class="mb-1">@deadline.Description</p>
                                            <small class="text-muted">Përgjegjës: @deadline.ResponsibleUser?.FullName</small>
                                        </div>
                                        <div>
                                            @if (deadline.IsCompleted)
                                            {
                                                <span class="badge bg-success">Përfunduar</span>
                                            }
                                            else if (deadline.DueDate < DateTime.Now)
                                            {
                                                <span class="badge bg-danger">I Vonuar</span>
                                            }
                                            else if ((deadline.DueDate - DateTime.Now).TotalDays <= 3)
                                            {
                                                <span class="badge bg-warning text-dark">Afati afër</span>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar"></i> Afati: @deadline.DueDate.ToString("dd/MM/yyyy")
                                        @if (deadline.CompletedDate.HasValue)
                                        {
                                        <br />
                                        <i class="bi bi-check-circle"></i>
                                        Përfunduar: @deadline.CompletedDate.Value.ToString("dd/MM/yyyy");
                                          }
                                    </small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Notes -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light"><h6 class="mb-0"><i class="bi bi-sticky"></i> Shënime</h6></div>
                    <div class="card-body"><p class="bg-light p-3 rounded border">@Model.Notes</p></div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top:20px;">
                <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="bi bi-info-circle"></i> Info</h6></div>
                <div class="card-body">
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Klasifikimi</small>
                        <h6><i class="bi bi-tag text-secondary"></i> @Model.Classification?.Name</h6>
                        @if (!string.IsNullOrEmpty(Model.Classification?.ColorCode))
                        {
                            <div style="width:20px; height:20px; background-color:@Model.Classification.ColorCode; border-radius:3px;"></div>
                        }
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Statusi</small>
                        <h6>
                            @switch (Model.Status)
                            {
                                case DocumentStatus.Registered:
                                    <span class="badge bg-info">I Protokolluar</span>
                                    break;
                                case DocumentStatus.InProgress:
                                    <span class="badge bg-primary">Në Proces</span>
                                    break;
                                case DocumentStatus.Completed:
                                    <span class="badge bg-success">I Përfunduar</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@Model.Status</span>
                                    break;
                            }
                        </h6>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Prioriteti</small>
                        <h6>
                            @switch (Model.Priority)
                            {
                                case Priority.Urgent:
                                    <span class="badge bg-danger">Urgjent</span>
                                    break;
                                case Priority.High:
                                    <span class="badge bg-warning text-dark">I Lartë</span>
                                    break;
                                case Priority.Normal:
                                    <span class="badge bg-info">Normal</span>
                                    break;
                                case Priority.Low:
                                    <span class="badge bg-secondary">I Ulët</span>
                                    break;
                            }
                        </h6>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Kërkon Përgjigje</small>
                        <h6>
                            @if (Model.RequiresResponse)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Po</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Jo</span>
                            }
                        </h6>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Ka Afat</small>
                        <h6>
                            @if (Model.HasDeadline)
                            {
                                <span class="badge bg-danger"><i class="bi bi-calendar-check"></i> Po</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-calendar"></i> Jo</span>
                            }
                        </h6>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Shtojca</small>
                        <h6>
                            @if (Model.HasAttachments)
                            {
                                <span class="badge bg-primary"><i class="bi bi-paperclip"></i> @(Model.Attachments?.Count ?? 0) file</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-paperclip"></i> Jo</span>
                            }
                        </h6>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted">Arkivuar</small>
                        <h6>
                            @if (Model.IsArchived)
                            {
                                <span class="badge bg-dark"><i class="bi bi-archive"></i> Po</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-archive"></i> Jo</span>
                            }
                        </h6>
                    </div>
                </div>
            </div>

            <!-- Metadata -->
            <div class="card shadow-sm mt-3 bg-light">
                <div class="card-body small">
                    <div><strong>ID:</strong> @Model.DocumentId</div>
                    <div><strong>Krijuar nga:</strong> @Model.Creator?.FullName</div>
                    <div><strong>Data e krijimit:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                    @if (Model.ModifiedDate.HasValue)
                    {
                        <hr />
                        <div><strong>Modifikuar:</strong> @Model.ModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</div>
                        <div><strong>Modifikuar nga:</strong> @Model.ModifiedBy</div>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card shadow-sm mt-3">
                <div class="card-body p-2">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.DocumentId" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i> Modifiko</a>
                        <a asp-action="Details" asp-route-id="@Model.DocumentId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i> Shiko</a>
                        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i> Printo</button>
                        @if (!Model.IsArchived)
                        {
                            <button class="btn btn-sm btn-outline-dark" onclick="archiveDocument(@Model.DocumentId)">
                                <i class="bi bi-archive"></i> Arkivo
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Fshij Dokumentin</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Fshij dokumentin: <strong class="text-warning">@Model.ProtocolNumber</strong>?</p>
                <div class="alert alert-danger">Kjo do të fshijë të gjitha të dhënat e dokumentit!</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <form method="post" asp-action="Delete" class="d-inline">
                    <input type="hidden" name="id" value="@Model.DocumentId">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Fshij</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Archive Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="bi bi-archive"></i> Arkivo Dokumentin</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Arkivo dokumentin: <strong id="archiveProtocol"></strong>?</p>
                <div class="mb-3">
                    <label for="archiveLocation" class="form-label">Vendndodhja e Arkivimit:</label>
                    <input type="text" class="form-control" id="archiveLocation" placeholder="p.sh. Arkivi A, Rafte 2">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <button type="button" class="btn btn-dark" id="confirmArchive">
                    <i class="bi bi-archive"></i> Arkivo
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let documentIdToArchive = null;

        function archiveDocument(id) {
            documentIdToArchive = id;
            $('#archiveProtocol').text('@Model.ProtocolNumber');
            $('#archiveModal').modal('show');
        }

        $(document).ready(function() {
            $('#confirmArchive').on('click', function() {
                if (documentIdToArchive) {
                    const location = $('#archiveLocation').val();
                    $.ajax({
                        url: '@Url.Action("Archive", "InternalDocument", new { area = "Manager" })',
                        type: 'POST',
                        data: {
                            id: documentIdToArchive,
                            location: location
                        },
                        success: function(response) {
                            if (response.success) {
                                $('#archiveModal').modal('hide');
                                location.reload();
                            } else {
                                alert('Gabim: ' + response.message);
                            }
                        },
                        error: function() {
                            alert('Ka ndodhur një gabim!');
                        }
                    });
                }
            });
        });
    </script>
}

