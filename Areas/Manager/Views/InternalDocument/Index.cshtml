@model IEnumerable<eProtokoll.Models.InternalDocument>

@{
    ViewData["Title"] = "Dokumente Brendshme";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Dokumente Brendshme</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-arrow-left-right me-2 text-warning"></i>
                Dokumente Brendshme
            </h2>
            <p class="text-muted mt-2">Menaxho dokumentet që qarkullojnë brenda institucionit</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Create" class="btn btn-warning">
                <i class="bi bi-plus-circle me-1"></i>
                Regjistro Dokument të Ri
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Total Dokumente</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalInternal</h2>
                            <small class="text-muted">Të gjitha brendshme</small>
                        </div>
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-files"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Sot</h6>
                            <h2 class="mb-0 fw-bold text-warning">@ViewBag.TodayInternal</h2>
                            <small class="text-warning">
                                <i class="bi bi-calendar-check"></i> Të regjistruara sot
                            </small>
                        </div>
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-arrow-left-right"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-search me-2"></i>
                Kërko
            </h5>
        </div>
        <div class="card-body">
            <form method="get" id="filterForm" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label for="searchTerm" class="form-label">Kërko</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                               value="@ViewBag.SearchTerm" placeholder="Nr. protokolli, subjekt...">
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <button type="submit" class="btn btn-warning me-2">
                        <i class="bi bi-search me-1"></i>
                        Kërko
                    </button>
                    <a href="@Url.Action("Index", "InternalDocument", new { area = "Manager" })" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>
                        Pastro
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Documents Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Lista e Dokumenteve (@ViewBag.TotalItems)
                    </h5>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">Nr. Protokolli</th>
                                <th style="width: 30%;">Subjekti</th>
                                <th style="width: 18%;">Nga → Për</th>
                                <th style="width: 10%;">Data</th>
                                <th style="width: 12%;">Prioriteti</th>
                                <th style="width: 10%;">Statusi</th>
                                <th style="width: 8%;" class="text-end">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-warning">@doc.ProtocolNumber</strong>
                                        <br />
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> @doc.ProtocolDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 350px;" title="@doc.Subject">
                                            <strong>@doc.Subject</strong>
                                        </div>
                                        @if (!string.IsNullOrEmpty(doc.Content))
                                        {
                                            <small class="text-muted d-block text-truncate" style="max-width: 350px;">
                                                @doc.Content
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            @if (!string.IsNullOrEmpty(doc.FromDepartment))
                                            {
                                                <div class="mb-1">
                                                    <i class="bi bi-box-arrow-right text-danger"></i> @doc.FromDepartment
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(doc.ToDepartment))
                                            {
                                                <div>
                                                    <i class="bi bi-box-arrow-in-left text-success"></i> @doc.ToDepartment
                                                </div>
                                            }
                                            @if (string.IsNullOrEmpty(doc.FromDepartment) && string.IsNullOrEmpty(doc.ToDepartment))
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        <small>
                                            <i class="bi bi-calendar-event"></i> @doc.CreatedDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        @switch (doc.Priority)
                                        {
                                            case Priority.Urgent:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-lightning-charge-fill"></i> Urgjent
                                                </span>
                                                break;
                                            case Priority.High:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-triangle"></i> I Lartë
                                                </span>
                                                break;
                                            case Priority.Normal:
                                                <span class="badge bg-info">
                                                    <i class="bi bi-info-circle"></i> Normal
                                                </span>
                                                break;
                                            case Priority.Low:
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-arrow-down"></i> I Ulët
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (doc.Status)
                                        {
                                            case DocumentStatus.Registered:
                                                <span class="badge bg-primary">Protokolluar</span>
                                                break;
                                            case DocumentStatus.InProgress:
                                                <span class="badge bg-warning text-dark">Në Proces</span>
                                                break;
                                            case DocumentStatus.Completed:
                                                <span class="badge bg-success">Përfunduar</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@doc.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Details" asp-route-id="@doc.DocumentId"
                                               class="btn btn-outline-info"
                                               title="Detajet">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-outline-danger delete-document"
                                                    data-id="@doc.DocumentId"
                                                    data-protocol="@doc.ProtocolNumber"
                                                    title="Fshij">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="card-footer bg-white">
                        <nav aria-label="Pagination">
                            <ul class="pagination pagination-sm mb-0 justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new {
                                        searchTerm = ViewBag.SearchTerm,
                                        status = ViewBag.SelectedStatus,
                                        priority = ViewBag.SelectedPriority,
                                        department = ViewBag.SelectedDepartment,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage - 1
                                    })">
                                        <i class="bi bi-chevron-left"></i> Mbrapa
                                    </a>
                                </li>

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new {
                                            searchTerm = ViewBag.SearchTerm,
                                            status = ViewBag.SelectedStatus,
                                            priority = ViewBag.SelectedPriority,
                                            department = ViewBag.SelectedDepartment,
                                            dateFrom = ViewBag.DateFrom,
                                            dateTo = ViewBag.DateTo,
                                            page = i
                                        })">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new {
                                        searchTerm = ViewBag.SearchTerm,
                                        status = ViewBag.SelectedStatus,
                                        priority = ViewBag.SelectedPriority,
                                        department = ViewBag.SelectedDepartment,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage + 1
                                    })">
                                        Përpara <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                        <div class="text-center mt-2">
                            <small class="text-muted">
                                Faqja @ViewBag.CurrentPage nga @ViewBag.TotalPages (@ViewBag.TotalItems dokumente gjithsej)
                            </small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka dokumente</h4>
                    <p class="text-muted">Kliko butonin "Regjistro Dokument të Ri" për të filluar</p>
                    <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Create" class="btn btn-warning mt-3">
                        <i class="bi bi-plus-circle me-1"></i>
                        Regjistro Dokument të Ri
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Konfirmo Fshirjen
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Jeni të sigurt që dëshironi të fshini këtë dokument?</p>
                <p class="fw-bold text-center text-warning fs-5" id="deleteDocumentProtocol"></p>
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>KUJDES:</strong> Kjo do të fshijë edhe të gjitha bashkëngjitjet e dokumentit!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <form method="post" asp-area="Manager" asp-controller="InternalDocument" asp-action="Delete" id="deleteForm" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteDocumentId">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill me-1"></i>
                        Fshij Dokumentin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let documentIdToDelete = null;

            // Delete document
            $('.delete-document').on('click', function () {
                documentIdToDelete = $(this).data('id');
                const protocol = $(this).data('protocol');
                $('#deleteDocumentProtocol').text(protocol);
                $('#deleteDocumentId').val(documentIdToDelete);
                $('#deleteModal').modal('show');
            });
        });
    </script>
}

@section Styles {
    <style>
        .stat-card {
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
            }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .bg-warning-subtle {
            background-color: rgba(255, 193, 7, 0.1) !important;
        }

        .bg-primary-subtle {
            background-color: rgba(13, 110, 253, 0.1) !important;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(255, 193, 7, 0.05);
        }

        .card {
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
        }

        .pagination .page-link {
            border-radius: 6px;
            margin: 0 2px;
        }

        .pagination .page-item.active .page-link {
            background-color: #ffc107;
            border-color: #ffc107;
            color: #000;
        }

        .btn-outline-warning:hover {
            background-color: #ffc107;
            border-color: #ffc107;
            color: #000;
        }
    </style>
}