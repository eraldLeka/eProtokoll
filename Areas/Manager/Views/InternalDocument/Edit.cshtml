@model eProtokoll.Models.InternalDocument

@{
    ViewData["Title"] = "Modifiko Dokument Brendshëm";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Index">Dokumente Brendshme</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Modifiko</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-pencil-square me-2 text-warning"></i>
                Modifiko Dokument Brendshëm
            </h2>
            <p class="text-muted mt-2">Përditëso të dhënat e dokumentit: <strong class="text-warning">@Model.ProtocolNumber</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Details" asp-route-id="@Model.DocumentId" class="btn btn-outline-warning">
                <i class="bi bi-eye me-1"></i>
                Shiko Detajet
            </a>
        </div>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="DocumentId" />
        <input type="hidden" asp-for="CreatedDate" />
        <input type="hidden" asp-for="CreatedBy" />
        <input type="hidden" asp-for="DocumentType" />
        <input type="hidden" asp-for="IsResponded" />
        <input type="hidden" asp-for="ResponseDate" />
        <input type="hidden" asp-for="ResponseDocumentId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <!-- Protocol Information -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="bi bi-hash me-2"></i>
                    Informacioni i Protokollimit
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label asp-for="ProtocolNumber" class="form-label">
                                <i class="bi bi-file-text text-warning"></i>
                                Numri i Protokollit <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ProtocolNumber" class="form-control form-control-lg fw-bold text-warning" readonly />
                            <span asp-validation-for="ProtocolNumber" class="text-danger"></span>
                            <small class="text-muted">Nuk mund të ndryshohet</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label asp-for="ProtocolDate" class="form-label">
                                Data e Protokollimit <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ProtocolDate" class="form-control" type="date" />
                            <span asp-validation-for="ProtocolDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label asp-for="ProtocolTime" class="form-label">
                                Ora e Protokollimit <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ProtocolTime" class="form-control" type="time" />
                            <span asp-validation-for="ProtocolTime" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Department & User Information -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="bi bi-building me-2"></i>
                    Informacioni i Qarkullimit të Brendshëm
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="FromDepartment" class="form-label">
                                <i class="bi bi-box-arrow-right text-danger"></i>
                                Departamenti Dërgues
                            </label>
                            <input asp-for="FromDepartment" class="form-control" placeholder="p.sh. Departamenti i IT" />
                            <span asp-validation-for="FromDepartment" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ToDepartment" class="form-label">
                                <i class="bi bi-box-arrow-in-left text-success"></i>
                                Departamenti Marrës
                            </label>
                            <input asp-for="ToDepartment" class="form-control" placeholder="p.sh. Departamenti i Financës" />
                            <span asp-validation-for="ToDepartment" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="FromUserId" class="form-label">
                                <i class="bi bi-person text-info"></i>
                                Nga (Përdoruesi)
                            </label>
                            <select asp-for="FromUserId" class="form-select" asp-items="ViewBag.FromUsers">
                                <option value="">-- Zgjidh Përdoruesin --</option>
                            </select>
                            <span asp-validation-for="FromUserId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ToUserId" class="form-label">
                                <i class="bi bi-person text-info"></i>
                                Për (Përdoruesi)
                            </label>
                            <select asp-for="ToUserId" class="form-select" asp-items="ViewBag.ToUsers">
                                <option value="">-- Zgjidh Përdoruesin --</option>
                            </select>
                            <span asp-validation-for="ToUserId" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Document Content -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-file-earmark-text me-2"></i>
                    Përmbajtja e Dokumentit
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Subject" class="form-label">
                        <i class="bi bi-chat-left-text text-primary"></i>
                        Subjekti <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Subject" class="form-control" placeholder="Subjekti/Titulli i dokumentit" />
                    <span asp-validation-for="Subject" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Content" class="form-label">
                        <i class="bi bi-text-paragraph text-primary"></i>
                        Përmbajtja/Përshkrimi
                    </label>
                    <textarea asp-for="Content" class="form-control" rows="5" placeholder="Përshkrimi i shkurtër i përmbajtjes së dokumentit..."></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Classification & Details -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Klasifikimi dhe Detajet
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ClassificationId" class="form-label">
                                <i class="bi bi-lock text-secondary"></i>
                                Klasifikimi <span class="text-danger">*</span>
                            </label>
                            <select asp-for="ClassificationId" class="form-select" asp-items="ViewBag.Classifications">
                                <option value="">-- Zgjidh Klasifikimin --</option>
                            </select>
                            <span asp-validation-for="ClassificationId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">
                                Statusi <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<DocumentStatus>()">
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label asp-for="Priority" class="form-label">
                                Prioriteti <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<Priority>()">
                            </select>
                            <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Response Settings -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="bi bi-reply me-2"></i>
                    Përgjigja dhe Afati
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-check form-switch mb-3">
                            <input asp-for="RequiresResponse" class="form-check-input" type="checkbox" id="requiresResponseSwitch" />
                            <label asp-for="RequiresResponse" class="form-check-label" for="requiresResponseSwitch">
                                <i class="bi bi-chat-dots text-success"></i>
                                Kërkon Përgjigje
                            </label>
                        </div>
                    </div>
                    <div class="col-md-6" id="responseDeadlineField">
                        <div class="mb-3">
                            <label asp-for="ResponseDeadline" class="form-label">
                                <i class="bi bi-calendar-x text-danger"></i>
                                Data e Kthimit të Përgjigjes
                            </label>
                            <input asp-for="ResponseDeadline" class="form-control" type="date" />
                            <span asp-validation-for="ResponseDeadline" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                @if (Model.IsResponded)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <strong>Statusi:</strong> Është përgjigjur më @Model.ResponseDate?.ToString("dd/MM/yyyy")
                        @if (Model.ResponseDocumentId.HasValue)
                        {
                            <br />
                            <small class="text-muted">Dokument Përgjigje ID: @Model.ResponseDocumentId</small>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Current Attachment -->
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-paperclip me-2"></i>
                        Bashkëngjitja Aktuale
                    </h5>
                </div>
                <div class="card-body">
                    @foreach (var attachment in Model.Attachments.OrderBy(a => a.DisplayOrder))
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">
                                    @if (attachment.FileExtension == ".pdf")
                                    {
                                        <i class="bi bi-file-earmark-pdf text-danger"></i>
                                    }
                                    else if (attachment.FileExtension == ".docx" || attachment.FileExtension == ".doc")
                                    {
                                        <i class="bi bi-file-earmark-word text-primary"></i>
                                    }
                                    else if (attachment.FileExtension == ".xlsx" || attachment.FileExtension == ".xls")
                                    {
                                        <i class="bi bi-file-earmark-excel text-success"></i>
                                    }
                                    else if (attachment.FileExtension == ".jpg" || attachment.FileExtension == ".jpeg" || attachment.FileExtension == ".png")
                                    {
                                        <i class="bi bi-file-earmark-image text-info"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-file-earmark text-secondary"></i>
                                    }
                                    @attachment.OriginalFileName
                                    @if (attachment.IsPrimaryDocument)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Kryesor</span>
                                    }
                                </h6>
                                <small class="text-muted">
                                    <i class="bi bi-hdd"></i> @attachment.FileSizeMB MB
                                    | <i class="bi bi-calendar"></i> @attachment.UploadedDate.ToString("dd/MM/yyyy HH:mm")
                                    @if (!string.IsNullOrEmpty(attachment.UploadedBy))
                                    {
                                        <span>| <i class="bi bi-person"></i> @attachment.UploadedBy</span>
                                    }
                                </small>
                            </div>
                            <div class="btn-group btn-group-sm">
                                <a href="@attachment.FilePath" target="_blank" class="btn btn-outline-primary" title="Shiko">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="@attachment.FilePath" download class="btn btn-outline-success" title="Shkarko">
                                    <i class="bi bi-download"></i>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Replace File Upload -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    @if (Model.Attachments != null && Model.Attachments.Any())
                    {
                        <text>Zëvendëso Bashkëngjitjen</text>
                    }
                    else
                    {
                        <text>Shto Bashkëngjitje</text>
                    }
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="attachmentFile" class="form-label">
                        <i class="bi bi-file-earmark-arrow-up text-warning"></i>
                        Ngarko Skedarin
                    </label>
                    <input type="file" class="form-control" id="attachmentFile" name="attachmentFile" accept=".pdf,.doc,.docx,.xlsx,.xls,.jpg,.jpeg,.png" />
                    <small class="text-muted">Formatet e lejuara: PDF, Word, Excel, Imazhe (max 10MB)</small>
                </div>
                @if (Model.Attachments != null && Model.Attachments.Any())
                {
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>KUJDES:</strong> Bashkëngjitja e re do të zëvendësojë atë ekzistuesen. Bashkëngjitja e vjetër do të fshihet përfundimisht.
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Shënim:</strong> Ky dokument nuk ka bashkëngjitje. Ngarko një skedar.
                    </div>
                }
            </div>
        </div>

        <!-- Notes -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">
                    <i class="bi bi-sticky me-2 text-muted"></i>
                    Shënime Shtesë
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">
                        <i class="bi bi-pencil-square text-muted"></i>
                        Shënime/Komente
                    </label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Shënime ose komente shtesë për këtë dokument..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Submit Buttons -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>
                            Kthehu në Listë
                        </a>
                        <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Details" asp-route-id="@Model.DocumentId" class="btn btn-outline-warning">
                            <i class="bi bi-eye me-1"></i>
                            Shiko Detajet
                        </a>
                    </div>
                    <button type="submit" class="btn btn-warning btn-lg px-5">
                        <i class="bi bi-save me-1"></i>
                        Përditëso Dokumentin
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // Show/hide response deadline field
            function toggleResponseDeadline() {
                if ($('#requiresResponseSwitch').is(':checked')) {
                    $('#responseDeadlineField').slideDown();
                } else {
                    $('#responseDeadlineField').slideUp();
                    $('#ResponseDeadline').val('');
                }
            }

            $('#requiresResponseSwitch').on('change', toggleResponseDeadline);
            toggleResponseDeadline(); // Initialize on load

            // File upload validation
            $('#attachmentFile').on('change', function () {
                const file = this.files[0];
                if (file) {
                    const fileSize = file.size / 1024 / 1024; // in MB
                    const allowedTypes = ['.pdf', '.doc', '.docx', '.xlsx', '.xls', '.jpg', '.jpeg', '.png'];
                    const fileExt = '.' + file.name.split('.').pop().toLowerCase();

                    if (fileSize > 10) {
                        alert('Skedari është shumë i madh! Madhësia maksimale është 10MB.');
                        $(this).val('');
                        return false;
                    }

                    if (!allowedTypes.includes(fileExt)) {
                        alert('Format i pasaktë! Formatet e lejuara janë: PDF, Word, Excel, Imazhe');
                        $(this).val('');
                        return false;
                    }
                }
            });

            // Form validation before submit
            $('#editForm').on('submit', function (e) {
                let isValid = true;
                let errorMessage = '';

                // Required field validation
                if (!$('#Subject').val().trim()) {
                    isValid = false;
                    errorMessage += '- Subjekti është i detyrueshëm\n';
                }

                if (!$('#ClassificationId').val()) {
                    isValid = false;
                    errorMessage += '- Klasifikimi është i detyrueshëm\n';
                }

                if (!$('#ProtocolDate').val()) {
                    isValid = false;
                    errorMessage += '- Data e protokollimit është e detyrueshme\n';
                }

                if (!isValid) {
                    e.preventDefault();
                    alert('Ju lutem plotësoni fushat e detyrueshme:\n\n' + errorMessage);
                    return false;
                }

                // Show loading state
                const submitBtn = $(this).find('button[type="submit"]');
                submitBtn.prop('disabled', true);
                submitBtn.html('<i class="bi bi-hourglass-split me-1"></i> Duke përditësuar...');
            });
        });
    </script>
}

@section Styles {
    <style>
        .form-control:focus,
        .form-select:focus {
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.15);
        }

        .card {
            border: none;
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            font-weight: 600;
        }

        .breadcrumb-item a {
            text-decoration: none;
        }

        .form-label {
            font-weight: 500;
        }

        .form-check-label {
            font-weight: 500;
        }

        .btn-lg {
            padding: 0.75rem 2rem;
        }

        .btn-outline-warning {
            color: #ffc107;
            border-color: #ffc107;
        }

            .btn-outline-warning:hover {
                background-color: #ffc107;
                border-color: #ffc107;
                color: #212529;
            }
    </style>
}