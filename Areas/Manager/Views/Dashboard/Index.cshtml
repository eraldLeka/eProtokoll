@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-house-door me-2 text-primary"></i>
                Mirë se vini, @User.Identity?.Name
            </h2>
            <p class="text-muted">Përmbledhja e aktivitetit - @DateTime.Now.ToString("dd MMMM yyyy")</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Total</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalDocuments</h2>
                            <small class="text-success"><i class="bi bi-arrow-up"></i> @ViewBag.MonthDocuments total</small>
                        </div>
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-files"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Sot</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TodayDocuments</h2>
                            <small class="text-muted"><i class="bi bi-calendar-check"></i> Protokolluar</small>
                        </div>
                        <div class="stat-icon bg-success-subtle text-success">
                            <i class="bi bi-file-earmark-plus"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Urgjente</h6>
                            <h2 class="mb-0 fw-bold text-danger">@ViewBag.UrgentDocuments</h2>
                            <small class="text-danger"><i class="bi bi-exclamation-triangle"></i> Aktive</small>
                        </div>
                        <div class="stat-icon bg-danger-subtle text-danger">
                            <i class="bi bi-lightning-charge"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Në Proces</h6>
                            <h2 class="mb-0 fw-bold text-primary">@ViewBag.InProgressDocuments</h2>
                            <small class="text-primary"><i class="bi bi-arrow-repeat"></i> Aktive</small>
                        </div>
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-arrow-repeat"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <!-- Daily Activity Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-bar-chart-line me-2 text-primary"></i>
                        Aktiviteti i 7 Ditëve të Fundit
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="dailyActivityChart" height="80"></canvas>
                </div>
            </div>
        </div>

        <!-- Document Types Chart -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart me-2 text-primary"></i>
                        Llojet e Dokumenteve
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="documentTypesChart"></canvas>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="bi bi-circle-fill text-info"></i> Hyrëse</span>
                            <strong>@ViewBag.TotalIncoming</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="bi bi-circle-fill text-success"></i> Dalëse</span>
                            <strong>@ViewBag.TotalOutgoing</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span><i class="bi bi-circle-fill text-warning"></i> Brendshme</span>
                            <strong>@ViewBag.TotalInternal</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Documents & Quick Actions -->
    <div class="row mb-4">
        <!-- Recent Documents -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2 text-primary"></i>
                        Dokumentet e Fundit
                    </h5>
                    <a asp-area="Manager" asp-controller="ProtocolBook" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        Libër Protokolli <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.RecentDocuments != null && ((IEnumerable<Document>)ViewBag.RecentDocuments).Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Protokolli</th>
                                        <th>Subjekti</th>
                                        <th>Lloji</th>
                                        <th>Statusi</th>
                                        <th>Data</th>
                                        <th class="text-end">Veprime</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in (IEnumerable<Document>)ViewBag.RecentDocuments)
                                    {
                                        <tr>
                                            <td><strong>@doc.ProtocolNumber</strong></td>
                                            <td>
                                                <div class="text-truncate" style="max-width:350px" title="@doc.Subject">@doc.Subject</div>
                                            </td>
                                            <td>
                                                @switch (doc.DocumentType)
                                                {
                                                    case DocumentType.Incoming:
                                                        <span class="badge bg-info"><i class="bi bi-arrow-down-circle"></i> Hyrës</span>
                                                        ; break;
                                                    case DocumentType.Outgoing:
                                                        <span class="badge bg-success"><i class="bi bi-arrow-up-circle"></i> Dalës</span>
                                                        ; break;
                                                    case DocumentType.Internal:
                                                        <span class="badge bg-warning text-dark"><i class="bi bi-arrow-left-right"></i> Brendshëm</span>
                                                        ; break;
                                                }
                                            </td>
                                            <td>
                                                @switch (doc.Status)
                                                {
                                                    case DocumentStatus.Registered:
                                                        <span class="badge bg-info">I Protokolluar</span>
                                                        ; break;
                                                    case DocumentStatus.InProgress:
                                                        <span class="badge bg-primary">Në Proces</span>
                                                        ; break;
                                                    case DocumentStatus.Completed:
                                                        <span class="badge bg-success">I Përfunduar</span>
                                                        ; break;
                                                }
                                            </td>
                                            <td><small>@doc.ProtocolDate.ToString("dd/MM/yyyy")</small></td>
                                            <td class="text-end">
                                                <a asp-area="Manager" asp-controller="ProtocolBook" asp-action="Details" asp-route-id="@doc.DocumentId" asp-route-type="@doc.DocumentType" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size:3rem"></i>
                            <p class="text-muted mt-3">Nuk ka dokumente</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-lightning-charge me-2"></i>Veprime të Shpejta</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-area="Manager" asp-controller="IncomingDocument" asp-action="Create" class="btn btn-info">
                            <i class="bi bi-arrow-down-circle me-2"></i>Dokument Hyrës
                        </a>
                        <a asp-area="Manager" asp-controller="OutgoingDocument" asp-action="Create" class="btn btn-success">
                            <i class="bi bi-arrow-up-circle me-2"></i>Dokument Dalës
                        </a>
                        <a asp-area="Manager" asp-controller="InternalDocument" asp-action="Create" class="btn btn-warning">
                            <i class="bi bi-arrow-left-right me-2"></i>Dokument Brendshëm
                        </a>
                        <hr />
                        <a asp-area="Manager" asp-controller="Tracking" asp-action="Create" class="btn btn-outline-purple">
                            <i class="bi bi-geo-alt me-2"></i>Cakto Dokument
                        </a>
                        <a asp-area="Manager" asp-controller="ProtocolBook" asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-book me-2"></i>Libër Protokolli
                        </a>
                    </div>
                </div>
            </div>

            <!-- Month Summary -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-calendar-month me-2"></i>Përmbledhje Mujore</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span><i class="bi bi-arrow-down-circle text-info"></i> Hyrëse</span>
                        <strong class="text-info">@ViewBag.MonthlyIncoming</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span><i class="bi bi-arrow-up-circle text-success"></i> Dalëse</span>
                        <strong class="text-success">@ViewBag.MonthlyOutgoing</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span><i class="bi bi-arrow-left-right text-warning"></i> Brendshme</span>
                        <strong class="text-warning">@ViewBag.MonthlyInternal</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        console.log('Chart.js loaded:', typeof Chart !== 'undefined');

        // Daily activity chart
        const dailyData = @Html.Raw(Json.Serialize(ViewBag.DailyStats ?? new object[0]));
        console.log('Daily data:', dailyData);

        const dailyEl = document.getElementById('dailyActivityChart');
        if (dailyEl && dailyData && dailyData.length > 0) {
            const labels = dailyData.map(d => d.Date || d.date);
            const data = dailyData.map(d => d.Count || d.count || 0);

            new Chart(dailyEl, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Dokumentet',
                        data: data,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13,110,253,0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });
        }

        // Document types pie
        const pieEl = document.getElementById('documentTypesChart');
        if (pieEl) {
            const incoming = Number(@(ViewBag.TotalIncoming ?? 0));
            const outgoing = Number(@(ViewBag.TotalOutgoing ?? 0));
            const internalCount = Number(@(ViewBag.TotalInternal ?? 0));

            new Chart(pieEl, {
                type: 'doughnut',
                data: {
                    labels: ['Hyrëse', 'Dalëse', 'Brendshme'],
                    datasets: [{
                        data: [incoming, outgoing, internalCount],
                        backgroundColor: ['#0dcaf0', '#198754', '#ffc107'],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { display: false } }
                }
            });
        }
    </script>
}

@section Styles {
    <style>
        .stat-card {
            transition: transform .2s
        }

            .stat-card:hover {
                transform: translateY(-5px)
            }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem
        }

        .card {
            border-radius: 12px
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important
        }

        .bg-primary-subtle {
            background-color: rgba(13,110,253,.1) !important
        }

        .bg-success-subtle {
            background-color: rgba(25,135,84,.1) !important
        }

        .bg-danger-subtle {
            background-color: rgba(220,53,69,.1) !important
        }

        .bg-warning-subtle {
            background-color: rgba(255,193,7,.1) !important
        }

        .text-purple {
            color: #6f42c1 !important
        }

        .btn-outline-purple {
            border-color: #6f42c1;
            color: #6f42c1
        }

            .btn-outline-purple:hover {
                background-color: #6f42c1;
                color: #fff
            }
    </style>
}