@{
    ViewData["Title"] = "Raporte Statistikore";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active">Raporte Statistikore</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="bi bi-bar-chart text-primary"></i> Raporte Statistikore</h2>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">TOTAL DOKUMENTET</h6>
                    <h2 class="fw-bold text-primary">@ViewBag.TotalDocuments</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">SOT</h6>
                    <h2 class="fw-bold text-success">@ViewBag.TodayCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">MUAJI</h6>
                    <h2 class="fw-bold text-info">@ViewBag.MonthCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">VITI</h6>
                    <h2 class="fw-bold text-warning">@ViewBag.YearCount</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Document Types -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-files"></i> Llojet e Dokumenteve</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <h3 class="text-info">@ViewBag.TotalIncoming</h3>
                            <small>Hyrëse</small>
                        </div>
                        <div class="col-4">
                            <h3 class="text-success">@ViewBag.TotalOutgoing</h3>
                            <small>Dalëse</small>
                        </div>
                        <div class="col-4">
                            <h3 class="text-warning">@ViewBag.TotalInternal</h3>
                            <small>Brendshme</small>
                        </div>
                    </div>
                    <canvas id="docTypesChart" class="mt-3" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Status & Priority -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Statuset</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Draft</span>
                        <strong>@ViewBag.Draft</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Në Proces</span>
                        <strong>@ViewBag.InProgress</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Përfunduar</span>
                        <strong>@ViewBag.Completed</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Arkivuar</span>
                        <strong>@ViewBag.Archived</strong>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Prioritetet</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-circle-fill text-danger"></i> Urgjent</span>
                        <strong>@ViewBag.Urgent</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-circle-fill text-warning"></i> I Lartë</span>
                        <strong>@ViewBag.High</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-circle-fill text-info"></i> Normal</span>
                        <strong>@ViewBag.Normal</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span><i class="bi bi-circle-fill text-secondary"></i> I Ulët</span>
                        <strong>@ViewBag.Low</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Monthly Trend -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-graph-up"></i> Trendi Mujor (12 muajt e fundit)</h5>
                </div>
                <div class="card-body">
                    <canvas id="monthlyChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Lists -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-building"></i> Top 10 Institucione</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopInstitutions != null && ((IEnumerable<dynamic>)ViewBag.TopInstitutions).Any())
                    {
                        <table class="table table-sm">
                            <tbody>
                                @{
                                    int rank = 1;
                                }
                                @foreach (var inst in (IEnumerable<dynamic>)ViewBag.TopInstitutions)
                                {
                                    <tr>
                                        <td width="30"><strong>@rank.</strong></td>
                                        <td>@inst.Name</td>
                                        <td width="60" class="text-end"><span class="badge bg-primary">@inst.Count</span></td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">Nuk ka të dhëna</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Top 10 Përdorues</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopUsers != null && ((IEnumerable<dynamic>)ViewBag.TopUsers).Any())
                    {
                        <table class="table table-sm">
                            <tbody>
                                @{
                                    int rank = 1;
                                }
                                @foreach (var user in (IEnumerable<dynamic>)ViewBag.TopUsers)
                                {
                                    <tr>
                                        <td width="30"><strong>@rank.</strong></td>
                                        <td>@user.Name</td>
                                        <td width="60" class="text-end"><span class="badge bg-success">@user.Count</span></td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">Nuk ka të dhëna</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Document Types Chart
        new Chart(document.getElementById('docTypesChart'), {
            type: 'doughnut',
            data: {
                labels: ['Hyrëse', 'Dalëse', 'Brendshme'],
                datasets: [{
                    data: [@ViewBag.TotalIncoming, @ViewBag.TotalOutgoing, @ViewBag.TotalInternal],
                    backgroundColor: ['#0dcaf0', '#198754', '#ffc107']
                }]
            }
        });

        // Monthly Trend Chart
        const monthlyData = @Html.Raw(Json.Serialize(ViewBag.MonthlyData));
        new Chart(document.getElementById('monthlyChart'), {
            type: 'line',
            data: {
                labels: monthlyData.map(d => d.month),
                datasets: [{
                    label: 'Dokumentet',
                    data: monthlyData.map(d => d.count),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13,110,253,0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true
            }
        });
    </script>
}