@using eProtokoll.Repositories
@{
    ViewData["Title"] = "Raporte Statistikore";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active">Raporte Statistikore</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="bi bi-bar-chart text-primary"></i> Raporte Statistikore</h2>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">TOTAL DOKUMENTET</h6>
                    <h2 class="fw-bold text-primary">@ViewBag.TotalDocuments</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">SOT</h6>
                    <h2 class="fw-bold text-success">@ViewBag.TodayCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">MUAJI</h6>
                    <h2 class="fw-bold text-info">@ViewBag.MonthCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted small">JAVA</h6>
                    <h2 class="fw-bold text-warning">@ViewBag.WeekCount</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Llojet e Dokumenteve + Prioritetet -->
    <div class="row mb-4">

        <!-- Llojet -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-files"></i> Llojet e Dokumenteve</h5>
                </div>
                <div class="card-body">
                    @{
                        var totalDocs = (int)(ViewBag.TotalDocuments ?? 1);
                        if (totalDocs == 0) totalDocs = 1;
                        int incomingPct = (int)(ViewBag.TotalIncoming ?? 0) * 100 / totalDocs;
                        int outgoingPct = (int)(ViewBag.TotalOutgoing ?? 0) * 100 / totalDocs;
                        int internalPct = (int)(ViewBag.TotalInternal ?? 0) * 100 / totalDocs;
                    }
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-info me-1"></i> Hyrëse</span>
                            <strong>@ViewBag.TotalIncoming (@incomingPct%)</strong>
                        </div>
                        <div class="progress" style="height:10px;">
                            <div class="progress-bar bg-info" style="width:@incomingPct%;"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-success me-1"></i> Dalëse</span>
                            <strong>@ViewBag.TotalOutgoing (@outgoingPct%)</strong>
                        </div>
                        <div class="progress" style="height:10px;">
                            <div class="progress-bar bg-success" style="width:@outgoingPct%;"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-warning me-1"></i> Brendshme</span>
                            <strong>@ViewBag.TotalInternal (@internalPct%)</strong>
                        </div>
                        <div class="progress" style="height:10px;">
                            <div class="progress-bar bg-warning" style="width:@internalPct%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Prioritetet -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Prioritetet</h5>
                </div>
                <div class="card-body">
                    @{
                        int totalPri = (int)(ViewBag.High ?? 0) + (int)(ViewBag.Normal ?? 0) + (int)(ViewBag.Low ?? 0);
                        if (totalPri == 0) totalPri = 1;
                        int highPct = (int)(ViewBag.High ?? 0) * 100 / totalPri;
                        int normalPct = (int)(ViewBag.Normal ?? 0) * 100 / totalPri;
                        int lowPct = (int)(ViewBag.Low ?? 0) * 100 / totalPri;
                    }
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-danger me-1"></i> I Lartë</span>
                            <strong>@ViewBag.High (@highPct%)</strong>
                        </div>
                        <div class="progress" style="height:10px;">
                            <div class="progress-bar bg-danger" style="width:@highPct%;"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-info me-1"></i> Normal</span>
                            <strong>@ViewBag.Normal (@normalPct%)</strong>
                        </div>
                        <div class="progress" style="height:10px;">
                            <div class="progress-bar bg-info" style="width:@normalPct%;"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-secondary me-1"></i> I Ulët</span>
                            <strong>@ViewBag.Low (@lowPct%)</strong>
                        </div>
                        <div class="progress" style="height:10px;">
                            <div class="progress-bar bg-secondary" style="width:@lowPct%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Trendi Mujor -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-graph-up"></i> Trendi Mujor (12 muajt e fundit)</h5>
                </div>
                <div class="card-body">
                    @{
                        var monthlyData = ViewBag.MonthlyData as List<MonthlyDocumentCount>;
                        int maxMonthVal = monthlyData != null && monthlyData.Any()
                            ? monthlyData.Max(m => m.Count) : 1;
                        if (maxMonthVal == 0) maxMonthVal = 1;
                    }
                    @if (monthlyData != null && monthlyData.Any())
                    {
                        <div class="d-flex align-items-end gap-2 w-100" style="height:180px;">
                            @foreach (var m in monthlyData)
                            {
                                int hPct = m.Count * 100 / maxMonthVal;
                                <div class="d-flex flex-column align-items-center flex-fill h-100 justify-content-end">
                                    <small class="text-muted mb-1" style="font-size:0.65rem;">@m.Count</small>
                                    <div class="bg-primary rounded-top w-75" style="height:@(Math.Max(hPct, 2))%;"></div>
                                    <small class="text-muted mt-1" style="font-size:0.6rem;">@m.MonthName</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-center text-muted">Nuk ka të dhëna.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top Institucione + Top Përdorues -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-building"></i> Top 5 Institucione</h5>
                </div>
                <div class="card-body">
                    @{
                        var topInstitutions = ViewBag.TopInstitutions as IEnumerable<eProtokoll.Repositories.TopInstitution>;
                    }
                    @if (topInstitutions != null && topInstitutions.Any())
                    {
                        <table class="table table-sm">
                            <tbody>
                                @{
                                    int rank = 1;
                                }
                                @foreach (var inst in topInstitutions)
                                {
                                    <tr>
                                        <td width="30"><strong>@rank.</strong></td>
                                        <td>@inst.Name</td>
                                        <td width="60" class="text-end">
                                            <span class="badge bg-primary">@inst.TotalDocuments</span>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">Nuk ka të dhëna</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Top 5 Përdorues</h5>
                </div>
                <div class="card-body">
                    @{
                        var topUsers = ViewBag.TopUsers as IEnumerable<eProtokoll.Repositories.TopUser>;
                    }
                    @if (topUsers != null && topUsers.Any())
                    {
                        <table class="table table-sm">
                            <tbody>
                                @{
                                    int rankU = 1;
                                }
                                @foreach (var user in topUsers)
                                {
                                    <tr>
                                        <td width="30"><strong>@rankU.</strong></td>
                                        <td>@user.FullName</td>
                                        <td width="60" class="text-end">
                                            <span class="badge bg-success">@user.TotalDocuments</span>
                                        </td>
                                    </tr>
                                    rankU++;
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">Nuk ka të dhëna</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>