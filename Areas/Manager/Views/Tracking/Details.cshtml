@model eProtokoll.Models.DocumentTracking

@{
    ViewData["Title"] = "Detajet e Gjurmimit";
    string GetFullName(ApplicationUser? u) => u == null ? "N/A" : ((u.FirstName ?? "") + " " + (u.LastName ?? "")).Trim().Length > 0 ? ((u.FirstName ?? "") + " " + (u.LastName ?? "")).Trim() : (u.UserName ?? "N/A");
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Gjurmimi</a></li>
            <li class="breadcrumb-item active">Detajet</li>
        </ol>
    </nav>

    <div class="row mb-3">
        <div class="col-md-8">
            <h2><i class="bi bi-geo-alt-fill text-purple"></i> Gjurmimi #@Model.TrackingId</h2>
            <div class="d-flex gap-2 mt-2">
                @if (Model.CompletedDate.HasValue)
                {
                    <span class="badge bg-success fs-6">Përfunduar</span>
                }
                else
                {
                    <span class="badge bg-secondary fs-6">Aktiv</span>
                }

                @if (Model.Priority == Priority.Urgent)
                {
                    <span class="badge bg-danger fs-6">Urgjent</span>
                }
            </div>
        </div>

        <div class="col-md-4 text-end">
            <div class="btn-group">
                <button onclick="window.print()" class="btn btn-outline-secondary"><i class="bi bi-printer"></i></button>
                <a asp-action="Delegate" asp-route-id="@Model.TrackingId" class="btn btn-purple"><i class="bi bi-arrow-right-circle"></i> Delego</a>
                <button data-bs-toggle="modal" data-bs-target="#deleteModal" class="btn btn-danger"><i class="bi bi-trash"></i></button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            @if (Model.Document != null)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-purple text-white"><h5 class="mb-0"><i class="bi bi-file-text"></i> Dokumenti</h5></div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <small class="text-muted">Protokolli</small>
                                <h5 class="text-purple">@Model.Document.ProtocolNumber</h5>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">Data</small>
                                <h6>@Model.Document.ProtocolDate.ToString("dd/MM/yyyy")</h6>
                            </div>
                        </div>
                        <hr />
                        <h6>@Model.Document.Subject</h6>
                        @if (!string.IsNullOrEmpty(Model.Document.Content))
                        {
                            <p class="text-muted small">@Model.Document.Content</p>
                        }
                    </div>
                </div>
            }

            <div class="card shadow-sm mb-3">
                <div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-info-circle"></i> Informacioni</h5></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <small class="text-muted">Caktuar Për</small>
                            <h6><i class="bi bi-person-fill text-purple"></i> @GetFullName(Model.AssignedToUser)</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                            <small class="text-muted">Caktuar Nga</small>
                            <h6><i class="bi bi-person"></i> @GetFullName(Model.AssignedByUser)</h6>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Data e Caktimit</small>
                            <h6><i class="bi bi-calendar"></i> @Model.AssignedDate.ToString("dd/MM/yyyy HH:mm")</h6>
                        </div>
                        <div class="col-md-6">
                            @if (Model.DueDate.HasValue)
                            {
                                <small class="text-muted">Afati</small>
                                <h6><i class="bi bi-alarm"></i> @Model.DueDate.Value.ToString("dd/MM/yyyy")</h6>
                            }
                        </div>
                    </div>

                    <hr />
                    <div class="mb-2">
                        <strong>Udhëzimet / Shënime:</strong>
                        <p class="bg-light p-3 rounded mt-2">@(!string.IsNullOrEmpty(Model.Notes) ? Model.Notes : "<i class='text-muted'>(Nuk ka udhëzime)</i>")</p>
                    </div>

                    @if (Model.CompletedDate.HasValue)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-all"></i> <strong>Përfunduar:</strong> @Model.CompletedDate?.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-activity"></i> Progresi</h5></div>
                <div class="card-body">
                    @{
                        var percent = Model.CompletedDate.HasValue ? 100 : 0;
                    }
                    <div class="progress mb-3" style="height:30px">
                        <div class="progress-bar bg-purple" style="width:@percent%">@percent%</div>
                    </div>
                    <p class="small text-muted mb-0">Status bazuar në fushën <strong>CompletedDate</strong>.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light"><h6 class="mb-0"><i class="bi bi-info-circle"></i> Detaje</h6></div>
                <div class="card-body">
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Prioriteti</small>
                        <h6>
                            @switch (Model.Priority)
                            {
                                case Priority.Urgent:
                                    <span class="badge bg-danger">Urgjent</span>
                                    ;
                                    break;
                                case Priority.High:
                                    <span class="badge bg-warning text-dark">I Lartë</span>
                                    ;
                                    break;
                                case Priority.Normal:
                                    <span class="badge bg-info">Normal</span>
                                    ;
                                    break;
                                default:
                                    <span class="badge bg-secondary">@Model.Priority</span>
                                    ;
                                    break;
                            }
                        </h6>
                    </div>

                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Gjendja</small>
                        <h6>
                            @if (Model.CompletedDate.HasValue)
                            {
                                <span class="badge bg-success">Përfunduar</span>
                            }
                            else if (!Model.IsActive)
                            {
                                <span class="badge bg-secondary">I Paaktiv</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Aktiv</span>
                            }
                        </h6>
                    </div>

                    <div class="mb-3">
                        <small class="text-muted">Krijuar</small>
                        <h6>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</h6>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm bg-light">
                <div class="card-body small">
                    <div><strong>ID:</strong> @Model.TrackingId</div>
                </div>
            </div>

            @if (!Model.CompletedDate.HasValue)
            {
                <div class="card shadow-sm mt-3">
                    <div class="card-body p-2">
                        <div class="d-grid gap-2">
                            <button class="btn btn-sm btn-success" onclick="acceptTracking(@Model.TrackingId)">
                                <i class="bi bi-check-circle"></i> Prano
                            </button>
                            <button class="btn btn-sm btn-primary" onclick="startTracking(@Model.TrackingId)">
                                <i class="bi bi-play-circle"></i> Fillo
                            </button>
                            <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#completeModal">
                                <i class="bi bi-check-all"></i> Përfundo
                            </button>
                            <a asp-action="Delegate" asp-route-id="@Model.TrackingId" class="btn btn-sm btn-purple">
                                <i class="bi bi-arrow-right-circle"></i> Delego
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Complete Modal -->
<div class="modal fade" id="completeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-check-circle"></i> Përfundo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Koment:</label>
                    <textarea class="form-control" id="completeComment" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Përqindja:</label>
                    <input type="range" class="form-range" id="completePercentage" min="0" max="100" value="100">
                    <div class="text-center"><span class="badge bg-success fs-5" id="percentDisplay">100%</span></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <button type="button" class="btn btn-success" onclick="confirmComplete()">Përfundo</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-trash"></i> Fshij</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Fshij këtë gjurmim?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulo</button>
                <form method="post" asp-action="Delete" class="d-inline">
                    <input type="hidden" name="id" value="@Model.TrackingId">
                    <button type="submit" class="btn btn-danger">Fshij</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function acceptTracking(id){
            $.post('@Url.Action("Accept")',{id:id},()=>location.reload());
        }
        function startTracking(id){
            $.post('@Url.Action("Start")',{id:id},()=>location.reload());
        }
        function confirmComplete(){
            const comment=$('#completeComment').val();
            const percentage=$('#completePercentage').val();
            $.post('@Url.Action("Complete")',{id:@Model.TrackingId,comment:comment,percentage:percentage},()=>location.reload());
        }
        $('#completePercentage').on('input',function(){
            $('#percentDisplay').text($(this).val()+'%');
        });
    </script>
}

@section Styles {
    <style>
        .text-purple {
            color: #6f42c1 !important;
        }

        .btn-purple {
            background-color: #6f42c1;
            border-color: #6f42c1;
            color: #fff;
        }

            .btn-purple:hover {
                background-color: #5a32a3;
                border-color: #5a32a3;
                color: #fff;
            }

        .bg-purple {
            background-color: #6f42c1 !important;
        }

        .badge.bg-purple {
            background-color: #6f42c1 !important;
        }

        .progress-bar.bg-purple {
            background-color: #6f42c1 !important;
        }
    </style>
}