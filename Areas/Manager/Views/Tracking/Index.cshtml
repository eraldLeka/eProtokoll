@model List<eProtokoll.Models.DocumentTracking>
@{
    ViewData["Title"] = "Gjurmimi i Dokumenteve";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalItems = (int)(ViewBag.TotalItems ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted">
        Gjithsej: <strong>@totalItems</strong> gjurmime
    </span>
    <a asp-area="Manager" asp-controller="Tracking" asp-action="Assign"
       class="btn btn-sm" style="background-color:#6f42c1; color:white;">
        <i class="bi bi-plus-circle me-1"></i> Cakto Dokument
    </a>
</div>


<!-- Tabela -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nr. Protokollit</th>
                    <th>Subjekti</th>
                    <th>Tipi</th>
                    <th>Caktuar Për</th>
                    <th>Caktuar Nga</th>
                    <th>Data Caktimit</th>
                    <th>Afati</th>
                    <th>Prioriteti</th>
                    <th>Statusi</th>
                    <th>Veprime</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            Nuk ka gjurmime. Kliko "Cakto Dokument" për të filluar.
                        </td>
                    </tr>
                }
                @foreach (var tracking in Model)
                {
                    var isCompleted = tracking.CompletedDate.HasValue;
                    var isOverdue = tracking.DueDate.HasValue
                    && tracking.DueDate.Value.Date < DateTime.Now.Date
                    && !isCompleted;

                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td>
                            <code>@tracking.DocumentProtocolNumber</code>
                        </td>
                        <td>
                            <span title="@tracking.DocumentSubject">
                                @(tracking.DocumentSubject?.Length > 50
                                                            ? tracking.DocumentSubject.Substring(0, 50) + "..."
                                                            : tracking.DocumentSubject ?? "—")
                            </span>
                        </td>
                        <td>
                            @{
                                var tipiBadge = tracking.DocumentDiscriminator switch
                                {
                                                "IncomingDocument" => ("bg-info", "Hyrës"),
                                                "OutgoingDocument" => ("bg-success", "Dalës"),
                                                "InternalDocument" => ("bg-warning text-dark", "Brendshëm"),
                                    _ => ("bg-secondary", "—")
                                };
                            }
                            <span class="badge @tipiBadge.Item1">@tipiBadge.Item2</span>
                        </td>
                        <td>
                            <i class="bi bi-person-fill text-purple"></i>
                            @(tracking.AssignedToUser?.FullName ?? "—")
                        </td>
                        <td>
                            <i class="bi bi-person text-muted"></i>
                            @(tracking.AssignedByUser?.FullName ?? "—")
                        </td>
                        <td>@tracking.AssignedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (tracking.DueDate.HasValue)
                            {
                                <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                    @tracking.DueDate.Value.ToString("dd/MM/yyyy")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @switch (tracking.Priority)
                            {
                                case eProtokoll.Models.Priority.High:
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-exclamation-triangle"></i> I Lartë
                                    </span>
                                    break;
                                case eProtokoll.Models.Priority.Normal:
                                    <span class="badge bg-info text-dark">Normal</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">I Ulët</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (isCompleted)
                            {
                                <span class="badge bg-success">Përfunduar</span>
                            }
                            else if (!tracking.IsActive)
                            {
                                <span class="badge bg-secondary">Anuluar</span>
                            }
                            else if (isOverdue)
                            {
                                <span class="badge bg-danger">Vonuar</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Aktiv</span>
                            }
                        </td>
                        <td>
                            @if (!isCompleted && tracking.IsActive)
                            {
                                <form method="post"
                                      asp-area="Manager"
                                      asp-controller="Tracking"
                                      asp-action="Complete"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@tracking.TrackingId" />
                                </form>

                                <form method="post"
                                      asp-area="Manager"
                                      asp-controller="Tracking"
                                      asp-action="Cancel"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@tracking.TrackingId" />
                                    <input type="hidden" name="reason" value="Anuluar nga menaxheri" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            title="Anulo"
                                            onclick="return confirm('E anulon këtë caktim?')">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-area="Manager" asp-controller="Tracking"
                   asp-action="Index"
                   asp-route-searchTerm="@ViewBag.SearchTerm"
                   asp-route-page="@(currentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-area="Manager" asp-controller="Tracking"
                       asp-action="Index"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-area="Manager" asp-controller="Tracking"
                   asp-action="Index"
                   asp-route-searchTerm="@ViewBag.SearchTerm"
                   asp-route-page="@(currentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
        <p class="text-center text-muted small">
            Faqja @currentPage nga @totalPages (@totalItems gjurmime gjithsej)
        </p>
    </nav>
}

@section Styles {
    <style>
        .text-purple {
            color: #6f42c1 !important;
        }

        .pagination .page-item.active .page-link {
            background-color: #6f42c1;
            border-color: #6f42c1;
        }
    </style>
}
