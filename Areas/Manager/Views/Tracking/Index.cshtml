@model IEnumerable<eProtokoll.Models.DocumentTracking>

@{
    ViewData["Title"] = "Gjurmimi i Dokumenteve";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Manager" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Gjurmimi i Dokumenteve</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-geo-alt-fill me-2 text-purple"></i>
                Gjurmimi i Dokumenteve
            </h2>
            <p class="text-muted mt-2">Gjurmo dhe menaxho delegimin e dokumenteve tek punonjësit</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Manager" asp-controller="Tracking" asp-action="Create" class="btn btn-purple">
                <i class="bi bi-plus-circle me-1"></i>
                Cakto Dokument
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Total</h6>
                            <h2 class="mb-0 fw-bold">@ViewBag.TotalTrackings</h2>
                            <small class="text-muted">Gjurmime</small>
                        </div>
                        <div class="stat-icon bg-purple-subtle text-purple">
                            <i class="bi bi-files"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Sot</h6>
                            <h2 class="mb-0 fw-bold text-purple">@ViewBag.TodayAssigned</h2>
                            <small class="text-purple">
                                <i class="bi bi-calendar-check"></i> Caktuar
                            </small>
                        </div>
                        <div class="stat-icon bg-info-subtle text-info">
                            <i class="bi bi-calendar-day"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Në Pritje</h6>
                            <h2 class="mb-0 fw-bold text-warning">@ViewBag.Pending</h2>
                            <small class="text-warning">
                                <i class="bi bi-hourglass-split"></i> Pending
                            </small>
                        </div>
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-clock-history"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Në Proces</h6>
                            <h2 class="mb-0 fw-bold text-primary">@ViewBag.InProgress</h2>
                            <small class="text-primary">
                                <i class="bi bi-play-circle"></i> Active
                            </small>
                        </div>
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-arrow-repeat"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Përfunduar</h6>
                            <h2 class="mb-0 fw-bold text-success">@ViewBag.Completed</h2>
                            <small class="text-success">
                                <i class="bi bi-check-circle"></i> Done
                            </small>
                        </div>
                        <div class="stat-icon bg-success-subtle text-success">
                            <i class="bi bi-check-all"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1 text-uppercase small">Vonuar</h6>
                            <h2 class="mb-0 fw-bold text-danger">@ViewBag.Overdue</h2>
                            <small class="text-danger">
                                <i class="bi bi-exclamation-triangle"></i> Overdue
                            </small>
                        </div>
                        <div class="stat-icon bg-danger-subtle text-danger">
                            <i class="bi bi-alarm"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-funnel me-2"></i>
                Kërko dhe Filtro
            </h5>
        </div>
        <div class="card-body">
            <form method="get" id="filterForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="searchTerm" class="form-label">Kërko</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                                   value="@ViewBag.SearchTerm" placeholder="Protokoll, subjekt, udhëzime...">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label for="status" class="form-label">Statusi</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">Të gjithë</option>
                            <option value="Assigned" selected="@(ViewBag.SelectedStatus == "Assigned")">I Caktuar</option>
                            <option value="Accepted" selected="@(ViewBag.SelectedStatus == "Accepted")">Pranuar</option>
                            <option value="InProgress" selected="@(ViewBag.SelectedStatus == "InProgress")">Në Proces</option>
                            <option value="Pending" selected="@(ViewBag.SelectedStatus == "Pending")">Në Pritje</option>
                            <option value="Completed" selected="@(ViewBag.SelectedStatus == "Completed")">Përfunduar</option>
                            <option value="Delegated" selected="@(ViewBag.SelectedStatus == "Delegated")">Deleguar</option>
                            <option value="Cancelled" selected="@(ViewBag.SelectedStatus == "Cancelled")">Anulluar</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="priority" class="form-label">Prioriteti</label>
                        <select class="form-select" id="priority" name="priority">
                            <option value="">Të gjithë</option>
                            <option value="Low" selected="@(ViewBag.SelectedPriority == "Low")">I Ulët</option>
                            <option value="Normal" selected="@(ViewBag.SelectedPriority == "Normal")">Normal</option>
                            <option value="High" selected="@(ViewBag.SelectedPriority == "High")">I Lartë</option>
                            <option value="Urgent" selected="@(ViewBag.SelectedPriority == "Urgent")">Urgjent</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="assignedTo" class="form-label">Caktuar Për</label>
                        <select class="form-select" id="assignedTo" name="assignedTo" asp-items="ViewBag.Users">
                            <option value="">Të gjithë</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Periudha</label>
                        <div class="input-group">
                            <input type="date" class="form-control" id="dateFrom" name="dateFrom" value="@ViewBag.DateFrom">
                            <span class="input-group-text">deri</span>
                            <input type="date" class="form-control" id="dateTo" name="dateTo" value="@ViewBag.DateTo">
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <button type="submit" class="btn btn-purple">
                            <i class="bi bi-funnel me-1"></i>
                            Apliko Filtrat
                        </button>
                        <a href="@Url.Action("Index", "Tracking", new { area = "Manager" })" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>
                            Pastro
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Trackings Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Lista e Gjurmimeve (@ViewBag.TotalItems)
                    </h5>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-sm btn-outline-purple" id="exportExcelBtn">
                        <i class="bi bi-file-earmark-excel me-1"></i>
                        Excel
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">Dokumenti</th>
                                <th style="width: 18%;">Subjekti</th>
                                <th style="width: 12%;">Caktuar Për</th>
                                <th style="width: 12%;">Caktuar Nga</th>
                                <th style="width: 10%;">Data</th>
                                <th style="width: 8%;">Prioriteti</th>
                                <th style="width: 10%;">Statusi</th>
                                <th style="width: 8%;">Progresi</th>
                                <th style="width: 10%;" class="text-end">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tracking in Model)
                            {
                                <tr class="@(tracking.IsOverdue && !tracking.IsCompleted ? "table-danger" : "")">
                                    <td>
                                        @if (tracking.Document != null)
                                        {
                                            <strong class="text-purple">@tracking.Document.ProtocolNumber</strong>
                                            <br />
                                            <small class="text-muted">
                                                <i class="bi bi-calendar"></i> @tracking.Document.ProtocolDate.ToString("dd/MM/yyyy")
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (tracking.Document != null)
                                        {
                                            <div class="text-truncate" style="max-width: 250px;" title="@tracking.Document.Subject">
                                                @tracking.Document.Subject
                                            </div>
                                        }
                                        <small class="badge bg-light text-dark border">
                                            @tracking.ActionType
                                        </small>
                                    </td>
                                    <td>
                                        <small>
                                            <i class="bi bi-person-fill text-purple"></i>
                                            @(tracking.AssignedToUser?.FullName ?? "-")
                                        </small>
                                    </td>
                                    <td>
                                        <small>
                                            <i class="bi bi-person text-muted"></i>
                                            @(tracking.AssignedByUser?.FullName ?? "-")
                                        </small>
                                    </td>
                                    <td>
                                        <small>
                                            <i class="bi bi-calendar-event"></i> @tracking.AssignedDate.ToString("dd/MM/yyyy")
                                            @if (tracking.DueDate.HasValue)
                                            {
                                                <br />
                                                <i class="bi bi-alarm text-danger"></i>
                                                <span class="text-danger">@tracking.DueDate.Value.ToString("dd/MM/yyyy")</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        @switch (tracking.Priority)
                                        {
                                            case Priority.Urgent:
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-lightning-charge-fill"></i> Urgjent
                                                </span>
                                                break;
                                            case Priority.High:
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-triangle"></i> I Lartë
                                                </span>
                                                break;
                                            case Priority.Normal:
                                                <span class="badge bg-info">Normal</span>
                                                break;
                                            case Priority.Low:
                                                <span class="badge bg-secondary">I Ulët</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (tracking.Status)
                                        {
                                            case TrackingStatus.Assigned:
                                                <span class="badge bg-secondary">I Caktuar</span>
                                                break;
                                            case TrackingStatus.Accepted:
                                                <span class="badge bg-info">Pranuar</span>
                                                break;
                                            case TrackingStatus.InProgress:
                                                <span class="badge bg-primary">Në Proces</span>
                                                break;
                                            case TrackingStatus.Pending:
                                                <span class="badge bg-warning text-dark">Në Pritje</span>
                                                break;
                                            case TrackingStatus.Completed:
                                                <span class="badge bg-success">Përfunduar</span>
                                                break;
                                            case TrackingStatus.Delegated:
                                                <span class="badge bg-purple">Deleguar</span>
                                                break;
                                            case TrackingStatus.Cancelled:
                                                <span class="badge bg-danger">Anulluar</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar @(tracking.CompletionPercentage == 100 ? "bg-success" : "bg-purple")"
                                                 role="progressbar"
                                                 style="width: @tracking.CompletionPercentage%"
                                                 aria-valuenow="@tracking.CompletionPercentage"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100">
                                                @tracking.CompletionPercentage%
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-area="Manager" asp-controller="Tracking" asp-action="Details" asp-route-id="@tracking.TrackingId"
                                               class="btn btn-outline-info"
                                               title="Detajet">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>
                                            @if (tracking.Status == TrackingStatus.Assigned)
                                            {
                                                <button type="button"
                                                        class="btn btn-outline-success accept-tracking"
                                                        data-id="@tracking.TrackingId"
                                                        title="Prano">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                            @if (tracking.Status == TrackingStatus.Accepted || tracking.Status == TrackingStatus.Assigned)
                                            {
                                                <button type="button"
                                                        class="btn btn-outline-primary start-tracking"
                                                        data-id="@tracking.TrackingId"
                                                        title="Fillo">
                                                    <i class="bi bi-play-circle"></i>
                                                </button>
                                            }
                                            @if (tracking.Status == TrackingStatus.InProgress && !tracking.IsCompleted)
                                            {
                                                <button type="button"
                                                        class="btn btn-outline-success complete-tracking"
                                                        data-id="@tracking.TrackingId"
                                                        title="Përfundo">
                                                    <i class="bi bi-check-all"></i>
                                                </button>
                                            }
                                            @if (!tracking.IsCompleted && tracking.Status != TrackingStatus.Cancelled)
                                            {
                                                <a asp-area="Manager" asp-controller="Tracking" asp-action="Delegate" asp-route-id="@tracking.TrackingId"
                                                   class="btn btn-outline-purple"
                                                   title="Delego">
                                                    <i class="bi bi-arrow-right-circle"></i>
                                                </a>
                                            }
                                            <button type="button"
                                                    class="btn btn-outline-danger delete-tracking"
                                                    data-id="@tracking.TrackingId"
                                                    title="Fshij">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="card-footer bg-white">
                        <nav aria-label="Pagination">
                            <ul class="pagination pagination-sm mb-0 justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { 
                                        searchTerm = ViewBag.SearchTerm, 
                                        status = ViewBag.SelectedStatus, 
                                        priority = ViewBag.SelectedPriority,
                                        assignedTo = ViewBag.SelectedAssignedTo,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage - 1 
                                    })">
                                        <i class="bi bi-chevron-left"></i> Mbrapa
                                    </a>
                                </li>

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { 
                                            searchTerm = ViewBag.SearchTerm, 
                                            status = ViewBag.SelectedStatus, 
                                            priority = ViewBag.SelectedPriority,
                                            assignedTo = ViewBag.SelectedAssignedTo,
                                            dateFrom = ViewBag.DateFrom,
                                            dateTo = ViewBag.DateTo,
                                            page = i 
                                        })">
                                            @i
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { 
                                        searchTerm = ViewBag.SearchTerm, 
                                        status = ViewBag.SelectedStatus, 
                                        priority = ViewBag.SelectedPriority,
                                        assignedTo = ViewBag.SelectedAssignedTo,
                                        dateFrom = ViewBag.DateFrom,
                                        dateTo = ViewBag.DateTo,
                                        page = ViewBag.CurrentPage + 1 
                                    })">
                                        Përpara <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                        <div class="text-center mt-2">
                            <small class="text-muted">
                                Faqja @ViewBag.CurrentPage nga @ViewBag.TotalPages (@ViewBag.TotalItems gjurmime gjithsej)
                            </small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka gjurmime</h4>
                    <p class="text-muted">Kliko butonin "Cakto Dokument" për të filluar</p>
                    <a asp-area="Manager" asp-controller="Tracking" asp-action="Create" class="btn btn-purple mt-3">
                        <i class="bi bi-plus-circle me-1"></i>
                        Cakto Dokument
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Complete Modal -->
<div class="modal fade" id="completeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-check-circle me-2"></i>
                    Përfundo Gjurmimin
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="completionComment" class="form-label">Koment:</label>
                    <textarea class="form-control" id="completionComment" rows="3" placeholder="Shkruani një koment për përfundimin..."></textarea>
                </div>
                <div class="mb-3">
                    <label for="completionPercentage" class="form-label">Përqindja e Përfundimit:</label>
                    <input type="range" class="form-range" id="completionPercentage" min="0" max="100" value="100">
                    <div class="text-center">
                        <span class="badge bg-success fs-5" id="percentageDisplay">100%</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <button type="button" class="btn btn-success" id="confirmComplete">
                    <i class="bi bi-check-circle me-1"></i>
                    Përfundo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Konfirmo Fshirjen
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A jeni të sigurt që dëshironi të fshini këtë gjurmim?</p>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Kujdes:</strong> Kjo veprim nuk mund të zhbëhet!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Anulo
                </button>
                <form method="post" asp-area="Manager" asp-controller="Tracking" asp-action="Delete" id="deleteForm" class="d-inline">
                    <input type="hidden" name="id" id="deleteTrackingId">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill me-1"></i>
                        Fshij
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let trackingIdToComplete = null;
            let trackingIdToDelete = null;

            // Accept tracking
            $('.accept-tracking').on('click', function() {
                const id = $(this).data('id');
                $.ajax({
                    url: '@Url.Action("Accept", "Tracking", new { area = "Manager" })',
                    type: 'POST',
                    data: { id: id },
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Gabim: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('Ka ndodhur një gabim!');
                    }
                });
            });

            // Start tracking
            $('.start-tracking').on('click', function() {
                const id = $(this).data('id');
                $.ajax({
                    url: '@Url.Action("Start", "Tracking", new { area = "Manager" })',
                    type: 'POST',
                    data: { id: id },
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Gabim: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('Ka ndodhur një gabim!');
                    }
                });
            });

            // Complete tracking
            $('.complete-tracking').on('click', function() {
                trackingIdToComplete = $(this).data('id');
                $('#completeModal').modal('show');
            });

            $('#completionPercentage').on('input', function() {
                $('#percentageDisplay').text($(this).val() + '%');
            });

            $('#confirmComplete').on('click', function() {
                if (trackingIdToComplete) {
                    const comment = $('#completionComment').val();
                    const percentage = $('#completionPercentage').val();
                    $.ajax({
                        url: '@Url.Action("Complete", "Tracking", new { area = "Manager" })',
                        type: 'POST',
                        data: { 
                            id: trackingIdToComplete,
                            comment: comment,
                            percentage: percentage
                        },
                        success: function(response) {
                            if (response.success) {
                                $('#completeModal').modal('hide');
                                location.reload();
                            } else {
                                alert('Gabim: ' + response.message);
                            }
                        },
                        error: function() {
                            alert('Ka ndodhur një gabim!');
                        }
                    });
                }
            });

            // Delete tracking
            $('.delete-tracking').on('click', function() {
                trackingIdToDelete = $(this).data('id');
                $('#deleteTrackingId').val(trackingIdToDelete);
                $('#deleteModal').modal('show');
            });

            // Export button
            $('#exportExcelBtn').on('click', function() {
                alert('Eksportimi në Excel do të implementohet së shpejti!');
            });
        });
    </script>
}

