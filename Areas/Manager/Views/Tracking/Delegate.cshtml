@model eProtokoll.Models.DocumentTracking

@{
    ViewData["Title"] = "Delego Dokumentin";
    var parentTracking = ViewBag.ParentTracking as DocumentTracking;
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Gjurmimi</a></li>
            <li class="breadcrumb-item active">Delego</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="bi bi-arrow-right-circle text-purple"></i> Delego Dokumentin</h2>

    @if (parentTracking != null)
    {
        <div class="alert alert-info mb-4">
            <h5><i class="bi bi-info-circle"></i> Gjurmimi Aktual</h5>
            <div class="row">
                <div class="col-md-6">
                    <strong>Dokumenti:</strong> @parentTracking.Document?.ProtocolNumber - @parentTracking.Document?.Subject
                </div>
                <div class="col-md-6">
                    <strong>Caktuar për:</strong> @parentTracking.AssignedToUser?.FullName
                </div>
            </div>
        </div>
    }

    <form asp-action="Delegate" method="post">
        <input type="hidden" asp-for="DocumentId" />
        <input type="hidden" asp-for="ParentTrackingId" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="card shadow-sm mb-3">
            <div class="card-header bg-purple text-white"><h5 class="mb-0">Informacioni i Delegimit</h5></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="AssignedToUserId" class="form-label">Delego Për <span class="text-danger">*</span></label>
                        <select asp-for="AssignedToUserId" class="form-select" asp-items="ViewBag.Users" required>
                            <option value="">-- Zgjidh Përdoruesin --</option>
                        </select>
                        <span asp-validation-for="AssignedToUserId" class="text-danger"></span>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="AssignedDate" class="form-label">Data <span class="text-danger">*</span></label>
                        <input asp-for="AssignedDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="DueDate" class="form-label">Afati</label>
                        <input asp-for="DueDate" class="form-control" type="date" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Priority" class="form-label">Prioriteti</label>
                        <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<Priority>()"></select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="ActionType" class="form-label">Lloji i Veprimit</label>
                        <select asp-for="ActionType" class="form-select" asp-items="Html.GetEnumSelectList<ActionType>()"></select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Status" class="form-label">Statusi</label>
                        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TrackingStatus>()"></select>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Instructions" class="form-label">Udhëzimet për Delegimin <span class="text-danger">*</span></label>
                    <textarea asp-for="Instructions" class="form-control" rows="3" placeholder="Udhëzimet për punonjësin e ri..." required></textarea>
                    <span asp-validation-for="Instructions" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Shënime</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Shënime shtesë..."></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="RequiresResponse" class="form-check-input" type="checkbox" />
                            <label asp-for="RequiresResponse" class="form-check-label">Kërkon Përgjigje</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">Aktiv</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> <strong>Vërejtje:</strong> Gjurmimi origjinal do të shënohet si "Deleguar" dhe do të krijohet një gjurmim i ri.
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Details" asp-route-id="@Model.ParentTrackingId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Kthehu
            </a>
            <button type="submit" class="btn btn-purple px-5">
                <i class="bi bi-arrow-right-circle"></i> Delego Dokumentin
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .text-purple {
            color: #6f42c1 !important
        }

        .btn-purple {
            background-color: #6f42c1;
            border-color: #6f42c1;
            color: #fff
        }

            .btn-purple:hover {
                background-color: #5a32a3;
                border-color: #5a32a3;
                color: #fff
            }

        .bg-purple {
            background-color: #6f42c1 !important
        }
    </style>
}