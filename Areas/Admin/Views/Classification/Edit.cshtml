@model eProtokoll.Models.Classification

@{
    ViewData["Title"] = "Modifiko Klasifikimin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Classification" asp-action="Index">Klasifikimet</a></li>
            <li class="breadcrumb-item active" aria-current="page">Modifiko</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0">
                <i class="bi bi-pencil-square me-2 text-primary"></i>
                Modifiko Klasifikimin: <span class="text-muted">@Model.Name</span>
            </h2>
            <p class="text-muted mt-2">Përditësoni parametrat e klasifikimit të sigurisë</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="ClassificationId" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="CreatedBy" />

                <!-- Info Alert -->
                @if (Model.Documents != null && Model.Documents.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Kujdes:</strong> Ky klasifikim përdoret nga <strong>@Model.Documents.Count dokumente</strong>.
                        Ndryshimet do të ndikojnë në të gjitha dokumentet që e përdorin.
                    </div>
                }

                <!-- Informacioni Bazë -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Informacioni Bazë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">
                                        <i class="bi bi-tag-fill text-primary"></i>
                                        Emri i Klasifikimit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Name" class="form-control" placeholder="p.sh. Konfidencial - Vetëm Stafi" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="SortOrder" class="form-label">
                                        <i class="bi bi-sort-numeric-down text-primary"></i>
                                        Renditja
                                    </label>
                                    <input asp-for="SortOrder" class="form-control" type="number" />
                                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">
                                <i class="bi bi-text-paragraph text-primary"></i>
                                Përshkrimi
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Përshkrim i detajuar i klasifikimit..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Niveli i Sigurisë -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="bi bi-shield-lock me-2"></i>
                            Niveli i Sigurisë dhe Aksesit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Level" class="form-label">
                                        <i class="bi bi-shield-fill text-warning"></i>
                                        Niveli i Aksesit <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Level" class="form-select" asp-items="Html.GetEnumSelectList<eProtokoll.Models.AccessLevel>()">
                                        <option value="">-- Zgjidh Nivelin --</option>
                                    </select>
                                    <span asp-validation-for="Level" class="text-danger"></span>
                                    <small class="text-muted d-block mt-1" id="levelDescription">Përcakton kush ka akses në dokumentet me këtë klasifikim</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="RetentionYears" class="form-label">
                                        <i class="bi bi-calendar-check text-warning"></i>
                                        Koha e Ruajtjes (vjet) <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RetentionYears" class="form-control" type="number" min="1" max="99" />
                                    <span asp-validation-for="RetentionYears" class="text-danger"></span>
                                    <small class="text-muted">Sa vite duhet të ruhen dokumentet</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cilësime Shtesë -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-sliders me-2"></i>
                            Cilësime Shtesë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ColorCode" class="form-label">
                                        <i class="bi bi-palette text-secondary"></i>
                                        Ngjyra e Etiketës
                                    </label>
                                    <input asp-for="ColorCode" class="form-control" type="color" />
                                    <span asp-validation-for="ColorCode" class="text-danger"></span>
                                    <small class="text-muted">Zgjidhni një ngjyrë për identifikim vizual</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="bi bi-toggle-on text-secondary"></i>
                                        Statuset
                                    </label>
                                    <div class="form-check form-switch">
                                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                        <label asp-for="IsActive" class="form-check-label">
                                            Aktiv (mund të përdoret)
                                        </label>
                                    </div>
                                    <div class="form-check form-switch mt-2">
                                        <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                                        <label asp-for="IsDefault" class="form-check-label">
                                            Parazgjedhje (zgjidhet automatikisht)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>
                                Anulo
                            </a>
                            <div>
                                <a asp-action="Details" asp-route-id="@Model.ClassificationId" class="btn btn-outline-info me-2">
                                    <i class="bi bi-eye me-1"></i>
                                    Detajet
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle me-1"></i>
                                    Ruaj Ndryshimet
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Sidebar me informacion -->
        <div class="col-lg-4">
            <!-- Metadata Card -->
            <div class="card shadow-sm mb-4 border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-info-square me-2"></i>
                        Metadata
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <th width="40%">ID:</th>
                            <td>@Model.ClassificationId</td>
                        </tr>
                        <tr>
                            <th>Krijuar më:</th>
                            <td>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <th>Krijuar nga:</th>
                            <td>@(Model.CreatedBy ?? "System")</td>
                        </tr>
                        @if (Model.ModifiedDate.HasValue)
                        {
                            <tr>
                                <th>Modifikuar më:</th>
                                <td>@Model.ModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <th>Modifikuar nga:</th>
                                <td>@(Model.ModifiedBy ?? "System")</td>
                            </tr>
                        }
                        <tr>
                            <th>Dokumente:</th>
                            <td>
                                <span class="badge bg-primary">
                                    @(Model.Documents?.Count ?? 0) dokumente
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Help Card -->
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-question-circle me-2"></i>
                        Ndihmë
                    </h5>
                </div>
                <div class="card-body">
                    <h6 class="text-primary">
                        <i class="bi bi-lightbulb-fill"></i> Nivelet e Klasifikimit
                    </h6>
                    <ul class="small">
                        <li class="mb-2">
                            <strong class="text-success">Publik:</strong> Të gjithë punonjësit mund ta shohin
                        </li>
                        <li class="mb-2">
                            <strong class="text-warning">I Kufizuar:</strong> Vetëm punonjësit e përzgjedhur
                        </li>
                        <li class="mb-2">
                            <strong class="text-danger">Sekret:</strong> Vetëm menaxherët dhe administratorët
                        </li>
                    </ul>

                    <hr />

                    <h6 class="text-primary">
                        <i class="bi bi-exclamation-triangle"></i> Kujdes
                    </h6>
                    <ul class="small">
                        <li class="mb-2">Ndryshimet do të ndikojnë në të gjitha dokumentet që përdorin këtë klasifikim</li>
                        <li class="mb-2">Çaktivizimi e bën të papërdorshëm për dokumente të reja</li>
                        <li class="mb-2">Niveli i sigurisë ndikon menjëherë në aksesin e dokumenteve</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Preview color
            $('#ColorCode').on('change', function() {
                const color = $(this).val();
                $(this).css('border-color', color);
            });

            // Level description
            $('#Level').on('change', function() {
                const level = $(this).val();
                let description = '';

                switch(level) {
                    case '0':
                        description = '✅ <strong>Publik:</strong> Të gjithë punonjësit mund ta shohin';
                        break;
                    case '1':
                        description = '⚠️ <strong>I Kufizuar:</strong> Vetëm punonjësit e përzgjedhur';
                        break;
                    case '2':
                        description = '🔒 <strong>Sekret:</strong> Vetëm menaxherët dhe administratorët';
                        break;
                }

                if (description) {
                    $('#levelDescription').html(description);
                }
            });

            // Confirm before making default
            $('#IsDefault').on('change', function() {
                if ($(this).is(':checked')) {
                    if (!confirm('A jeni të sigurt që dëshironi ta bëni këtë klasifikim si parazgjedhje? Kjo do të heqë parazgjedhjen nga klasifikimet e tjerë.')) {
                        $(this).prop('checked', false);
                    }
                }
            });

            // Warn if deactivating with documents
            $('#IsActive').on('change', function() {
                const documentsCount = @(Model.Documents?.Count ?? 0);
                if (!$(this).is(':checked') && documentsCount > 0) {
                    if (!confirm(`Ky klasifikim përdoret nga ${documentsCount} dokumente. A jeni të sigurt që dëshironi ta çaktivizoni?`)) {
                        $(this).prop('checked', true);
                    }
                }
            });

            // Highlight changes
            $('input, select, textarea').on('change', function() {
                $(this).addClass('border-warning');
            });
        });
    </script>
}

@section Styles {
    <style>
        .form-check-input:checked {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        .card-header {
            font-weight: 600;
        }

        .form-label {
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        input[type="color"] {
            height: 45px;
            cursor: pointer;
        }

        .alert {
            border-left: 4px solid;
        }

        .border-warning {
            transition: border-color 0.3s;
        }

        .table th {
            font-weight: 600;
            color: #6c757d;
        }

        #levelDescription {
            min-height: 24px;
            font-weight: 500;
        }
    </style>
}