@model eProtokoll.Models.Classification

@{
    ViewData["Title"] = "Shto Klasifikim të Ri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Classification" asp-action="Index">Klasifikimet</a></li>
            <li class="breadcrumb-item active" aria-current="page">Shto të Ri</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0">
                <i class="bi bi-plus-circle-fill me-2 text-primary"></i>
                Shto Klasifikim të Ri
            </h2>
            <p class="text-muted mt-2">Krijoni një klasifikim të ri për dokumentet me parametrat e sigurisë</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Informacioni Bazë -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Informacioni Bazë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">
                                        <i class="bi bi-tag-fill text-primary"></i>
                                        Emri i Klasifikimit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Name" class="form-control" placeholder="p.sh. Konfidencial - Vetëm Stafi" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="SortOrder" class="form-label">
                                        <i class="bi bi-sort-numeric-down text-primary"></i>
                                        Renditja
                                    </label>
                                    <input asp-for="SortOrder" class="form-control" type="number" />
                                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">
                                <i class="bi bi-text-paragraph text-primary"></i>
                                Përshkrimi
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Përshkrim i detajuar i klasifikimit..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Niveli i Sigurisë -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="bi bi-shield-lock me-2"></i>
                            Niveli i Sigurisë dhe Aksesit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Level" class="form-label">
                                        <i class="bi bi-shield-fill text-warning"></i>
                                        Niveli i Aksesit <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Level" class="form-select" asp-items="Html.GetEnumSelectList<eProtokoll.Models.AccessLevel>()">
                                        <option value="">-- Zgjidh Nivelin --</option>
                                    </select>
                                    <span asp-validation-for="Level" class="text-danger"></span>
                                    <small class="text-muted">Përcakton kush ka akses në dokumentet me këtë klasifikim</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="RetentionYears" class="form-label">
                                        <i class="bi bi-calendar-check text-warning"></i>
                                        Koha e Ruajtjes (vjet) <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RetentionYears" class="form-control" type="number" min="1" max="99" />
                                    <span asp-validation-for="RetentionYears" class="text-danger"></span>
                                    <small class="text-muted">Sa vite duhet të ruhen dokumentet</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MinimumRoleRequired" class="form-label">
                                <i class="bi bi-person-badge text-warning"></i>
                                Roli Minimal për Qasje
                            </label>
                            <select asp-for="MinimumRoleRequired" class="form-select">
                                <option value="">-- Nuk Kërkohet Rol Specifik --</option>
                                <option value="Administrator">Administrator</option>
                                <option value="Manager">Menaxher</option>
                                <option value="Employee">Punonjës</option>
                            </select>
                            <span asp-validation-for="MinimumRoleRequired" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="RequiresApproval" class="form-check-input" type="checkbox" />
                                    <label asp-for="RequiresApproval" class="form-check-label">
                                        <i class="bi bi-check-circle text-warning"></i>
                                        Kërkon Miratim për Qasje
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="EnableAuditLog" class="form-check-input" type="checkbox" checked />
                                    <label asp-for="EnableAuditLog" class="form-check-label">
                                        <i class="bi bi-journal-text text-warning"></i>
                                        Aktivizo Audit Log
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Lejet e Veprimit -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-gear me-2"></i>
                            Lejet e Veprimit
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">Përcaktoni çfarë veprimesh janë të lejuara për dokumentet me këtë klasifikim</p>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="AllowPrint" class="form-check-input" type="checkbox" checked />
                                    <label asp-for="AllowPrint" class="form-check-label">
                                        <i class="bi bi-printer-fill text-info"></i>
                                        Lejo Printimin
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="AllowDownload" class="form-check-input" type="checkbox" checked />
                                    <label asp-for="AllowDownload" class="form-check-label">
                                        <i class="bi bi-download text-info"></i>
                                        Lejo Shkarkimin
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="AllowCopy" class="form-check-input" type="checkbox" checked />
                                    <label asp-for="AllowCopy" class="form-check-label">
                                        <i class="bi bi-files text-info"></i>
                                        Lejo Kopjimin
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cilësime Shtesë -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-sliders me-2"></i>
                            Cilësime Shtesë
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ColorCode" class="form-label">
                                        <i class="bi bi-palette text-secondary"></i>
                                        Ngjyra e Etiketës
                                    </label>
                                    <input asp-for="ColorCode" class="form-control" type="color" />
                                    <span asp-validation-for="ColorCode" class="text-danger"></span>
                                    <small class="text-muted">Zgjidhni një ngjyrë për identifikim vizual</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="bi bi-toggle-on text-secondary"></i>
                                        Statuset
                                    </label>
                                    <div class="form-check form-switch">
                                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                        <label asp-for="IsActive" class="form-check-label">
                                            Aktiv (mund të përdoret)
                                        </label>
                                    </div>
                                    <div class="form-check form-switch mt-2">
                                        <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                                        <label asp-for="IsDefault" class="form-check-label">
                                            Parazgjedhje (zgjidhet automatikisht)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>
                                Anulo
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>
                                Ruaj Klasifikimin
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Sidebar me informacion -->
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Udhëzime
                    </h5>
                </div>
                <div class="card-body">
                    <h6 class="text-primary">
                        <i class="bi bi-lightbulb-fill"></i> Këshilla për Klasifikimet
                    </h6>
                    <ul class="small">
                        <li class="mb-2"><strong>Publik:</strong> Për dokumenta që janë të aksesueshëm për të gjithë</li>
                        <li class="mb-2"><strong>I Brendshëm:</strong> Vetëm për stafin e autorizuar</li>
                        <li class="mb-2"><strong>Konfidencial:</strong> Për disa punonjës të caktuar</li>
                        <li class="mb-2"><strong>Sekret:</strong> Vetëm menaxherët dhe administratorët</li>
                        <li class="mb-2"><strong>Tepër Sekret:</strong> Vetëm administratorët</li>
                    </ul>

                    <hr />

                    <h6 class="text-primary">
                        <i class="bi bi-shield-check"></i> Siguria
                    </h6>
                    <p class="small text-muted">
                        Aktivizoni <strong>Audit Log</strong> për të gjurmuar të gjitha veprimet e kryera në dokumentet me këtë klasifikim.
                    </p>

                    <hr />

                    <h6 class="text-primary">
                        <i class="bi bi-calendar-range"></i> Ruajtja
                    </h6>
                    <p class="small text-muted">
                        Koha e ruajtjes përcakton sa vite duhet të mbahen dokumentet para se të arkivohen ose fshihen.
                    </p>
                </div>
            </div>

            <div class="alert alert-info">
                <i class="bi bi-star-fill text-warning"></i>
                <strong>Parazgjedhje:</strong> Nëse vendosni këtë klasifikim si parazgjedhje, ai do të zgjidhet automatikisht kur krijohen dokumente të reja.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Preview color
            $('#ColorCode').on('change', function() {
                const color = $(this).val();
                $(this).css('border-color', color);
            });

            // Level description
            $('#Level').on('change', function() {
                const level = $(this).val();
                let description = '';

                switch(level) {
                    case '1': description = 'Publik - Të gjithë mund ta shohin'; break;
                    case '2': description = 'I Brendshëm - Vetëm punonjësit e autorizuar'; break;
                    case '3': description = 'Konfidencial - Vetëm disa punonjës të caktuar'; break;
                    case '4': description = 'Sekret - Vetëm menaxherët dhe administratorët'; break;
                    case '5': description = 'Tepër Sekret - Vetëm administratorët'; break;
                }

                if (description) {
                    $('#Level').next('.text-danger').after(`<small class="text-info d-block mt-1">${description}</small>`);
                }
            });

            // Confirm before making default
            $('#IsDefault').on('change', function() {
                if ($(this).is(':checked')) {
                    if (!confirm('A jeni të sigurt që dëshironi ta bëni këtë klasifikim si parazgjedhje? Kjo do të heqë parazgjedhjen nga klasifikimet e tjerë.')) {
                        $(this).prop('checked', false);
                    }
                }
            });
        });
    </script>
}

@section Styles {
    <style>
        .form-check-input:checked {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        .card-header {
            font-weight: 600;
        }

        .form-label {
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        input[type="color"] {
            height: 45px;
            cursor: pointer;
        }

        .alert {
            border-left: 4px solid;
        }
    </style>
}
