@using eProtokoll.Models
@{
    ViewData["Title"] = "Dashboard Administratori";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Përdoruesit</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalUsers</div>
                        <small class="text-muted">
                            <i class="bi bi-arrow-up text-success"></i> +@ViewBag.UsersThisMonth këtë muaj
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-people-fill text-primary" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Dokumentet</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalDocuments</div>
                        <small class="text-muted">
                            <i class="bi bi-arrow-up text-success"></i> +@ViewBag.DocumentsToday sot
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-file-earmark-text-fill text-success" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Institucionet</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalInstitutions</div>
                        <small class="text-muted">
                            <i class="bi bi-arrow-up text-success"></i> +@ViewBag.InstitutionsThisMonth këtë muaj
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-building text-warning" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Afatet Aktive</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.ActiveDeadlines</div>
                        <small class="text-muted">
                            <i class="bi bi-exclamation-circle text-danger"></i> Në pritje
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-alarm-fill text-danger" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Aktiviteti i Fundit - i plotë në gjerësi -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-activity"></i> Aktiviteti i Fundit
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Koha</th>
                                <th>Përdoruesi</th>
                                <th>Lloji</th>
                                <th>Protokolli</th>
                                <th>Subjekti</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentActivity != null)
                            {
                                @foreach (var activity in ViewBag.RecentActivity)
                                {
                                    <tr>
                                        <td class="ps-3"><small class="text-muted">@activity.Time</small></td>
                                        <td>
                                            <i class="bi bi-person-circle text-primary"></i> @activity.UserName
                                        </td>
                                        <td>
                                            @switch ((DocumentType)activity.DocumentType)
                                            {
                                                case DocumentType.Incoming:
                                                    <span class="badge bg-primary">Hyrës</span>
                                                    break;
                                                case DocumentType.Outgoing:
                                                    <span class="badge bg-success">Dalës</span>
                                                    break;
                                                case DocumentType.Internal:
                                                    <span class="badge bg-warning text-dark">I Brendshëm</span>
                                                    break;
                                            }
                                        </td>
                                        <td><strong>@activity.ProtocolNumber</strong></td>
                                        <td class="text-muted">@activity.Subject</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox"></i> Nuk ka aktivitet të fundit
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Grafiku Mujor + Shpërndarja - lartësi e njëjtë -->
<div class="row mb-4">

    <!-- Vlerësim Mujor -->
    <div class="col-xl-8 col-lg-7 d-flex">
        <div class="card shadow w-100">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-graph-up"></i> Dokumentet - Vlerësim Mujor
                </h6>
            </div>
            <div class="card-body d-flex align-items-end">
                @if (ViewBag.MonthlyCounts != null)
                {
                    var months = (List<string>)ViewBag.MonthNames;
                    var counts = (List<int>)ViewBag.MonthlyCounts;
                    int maxCount = counts.Count > 0 ? counts.Max() : 1;
                    if (maxCount == 0) maxCount = 1;

                    <div class="d-flex align-items-end gap-3 w-100" style="height: 180px;">
                        @for (int i = 0; i < months.Count; i++)
                        {
                            int heightPct = counts[i] * 100 / maxCount;
                            <div class="d-flex flex-column align-items-center flex-fill h-100 justify-content-end">
                                <small class="text-muted mb-1" style="font-size:0.7rem;">@counts[i]</small>
                                <div class="bg-primary rounded-top w-75"
                                     style="height: @(Math.Max(heightPct, 2))%;">
                                </div>
                                <small class="text-muted mt-2" style="font-size:0.65rem;">@months[i]</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-muted w-100">Nuk ka të dhëna.</p>
                }
            </div>
        </div>
    </div>

    <!-- Shpërndarja e Dokumenteve -->
    <div class="col-xl-4 col-lg-5 d-flex">
        <div class="card shadow w-100">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-pie-chart"></i> Shpërndarja e Dokumenteve
                </h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                @if (ViewBag.Total == null || ViewBag.Total == 0)
                {
                    <p class="text-center text-muted">Nuk ka dokumente të regjistruara.</p>
                }
                else
                {
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-primary me-1"></i> Hyrëse</span>
                            <strong>@ViewBag.Incoming (@ViewBag.IncomingPct%)</strong>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-primary" style="width: @(ViewBag.IncomingPct)%;"></div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-success me-1"></i> Dalëse</span>
                            <strong>@ViewBag.Outgoing (@ViewBag.OutgoingPct%)</strong>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-success" style="width: @(ViewBag.OutgoingPct)%;"></div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <span><i class="bi bi-circle-fill text-info me-1"></i> Të Brendshme</span>
                            <strong>@ViewBag.Internal (@ViewBag.InternalPct%)</strong>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-info" style="width: @(ViewBag.InternalPct)%;"></div>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Gjithsej</span>
                        <strong>@ViewBag.Total dokumente</strong>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }

    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }

    .border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }

    .border-left-danger {
        border-left: 0.25rem solid #e74a3b !important;
    }

    .text-xs {
        font-size: .7rem;
    }
</style>