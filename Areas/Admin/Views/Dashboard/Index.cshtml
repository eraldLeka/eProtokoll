@{
    ViewData["Title"] = "Dashboard Administratori";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- Statistics Cards -->
<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Përdoruesit
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalUsers</div>
                        <small class="text-muted">
                            <i class="bi bi-arrow-up text-success"></i> +@ViewBag.UsersThisMonth këtë muaj
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-people-fill text-primary" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Dokumentet
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalDocuments</div>
                        <small class="text-muted">
                            <i class="bi bi-arrow-up text-success"></i> +@ViewBag.DocumentsToday sot
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-file-earmark-text-fill text-success" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Institucionet
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalInstitutions</div>
                        <small class="text-muted">
                            <i class="bi bi-arrow-up text-success"></i> +@ViewBag.InstitutionsThisMonth këtë muaj
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-building text-warning" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                            Afatet Aktive
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.ActiveDeadlines</div>
                        <small class="text-muted">
                            <i class="bi bi-exclamation-circle text-danger"></i> Në pritje
                        </small>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-alarm-fill text-danger" style="font-size: 2rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row mb-4">
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-graph-up"></i> Dokumentet - Vlerësim Mujor
                </h6>
            </div>
            <div class="card-body">
                <div class="chart-area">
                    <canvas id="myAreaChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-5">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-pie-chart"></i> Shpërndarja e Dokumenteve
                </h6>
            </div>
            <div class="card-body">
                <div class="chart-pie">
                    <canvas id="myPieChart"></canvas>
                </div>
                <div class="mt-4 text-center small">
                    <span class="mr-2">
                        <i class="bi bi-circle-fill text-primary"></i> Hyrëse
                    </span>
                    <span class="mr-2">
                        <i class="bi bi-circle-fill text-success"></i> Dalëse
                    </span>
                    <span class="mr-2">
                        <i class="bi bi-circle-fill text-info"></i> Të brendshme
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Content Row -->
<div class="row">
    <!-- Activity Table -->
    <div class="col-lg-8 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-activity"></i> Aktiviteti i Fundit
                </h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Koha</th>
                                <th>Përdoruesi</th>
                                <th>Veprimi</th>
                                <th>Statusi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentActivity != null)
                            {
                                @foreach (var activity in ViewBag.RecentActivity)
                                {
                                    <tr>
                                        <td><small class="text-muted">@activity.Time</small></td>
                                        <td>
                                            <i class="bi bi-person-circle text-primary"></i> @activity.UserName
                                        </td>
                                        <td>
                                            @switch (activity.DocumentType)
                                            {
                                                case 1:
                                                    <text>Dokument hyrës</text>
                                                    break;
                                                case 2:
                                                    <text>Dokument dalës</text>
                                                    break;
                                                case 3:
                                                    <text>Dokument brendshëm</text>
                                                    break;
                                            }
                                            <strong>@activity.ProtocolNumber</strong>
                                        </td>
                                        <td>
                                            @switch (activity.Status)
                                            {
                                                case 1: // Draft
                                                        <span class="badge bg-secondary">Draft</span>
                                                    break;
                                                case 2: // Registered
                                                        <span class="badge bg-success">Regjistruar</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-info">Aktiv</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">Nuk ka aktivitet të fundit</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <a href="#" class="btn btn-sm btn-link">Shiko të gjitha <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <!-- Notifications -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-bell"></i> Njoftimet
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1"><i class="bi bi-clock text-danger"></i> Afat i ri</h6>
                            <small class="text-muted">5 min</small>
                        </div>
                        <p class="mb-1 small">Dokument H-0142/2024 ka afat deri më 30/12/2024</p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1"><i class="bi bi-person-plus text-success"></i> Përdorues i ri</h6>
                            <small class="text-muted">1 orë</small>
                        </div>
                        <p class="mb-1 small">User 'test@example.com' është regjistruar</p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1"><i class="bi bi-file-earmark text-info"></i> Dokument i ri</h6>
                            <small class="text-muted">2 orë</small>
                        </div>
                        <p class="mb-1 small">Dokument hyrës H-0141/2024 nga Ministria e Financave</p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1"><i class="bi bi-gear text-warning"></i> Cilësim i ndryshuar</h6>
                            <small class="text-muted">3 orë</small>
                        </div>
                        <p class="mb-1 small">Protokolli vjetor është rivendosur për 2025</p>
                    </a>
                </div>
            </div>
            <div class="card-footer text-center">
                <a href="#" class="small">Shiko të gjitha njoftimet</a>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-speedometer"></i> Statistika të Shpejta
                </h6>
            </div>
            <div class="card-body">
                <h4 class="small font-weight-bold">
                    Dokumentet e Procesuar
                    <span class="float-right">80%</span>
                </h4>
                <div class="progress mb-3">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 80%"></div>
                </div>
                <h4 class="small font-weight-bold">
                    Afatet e Përfunduara
                    <span class="float-right">60%</span>
                </h4>
                <div class="progress mb-3">
                    <div class="progress-bar bg-info" role="progressbar" style="width: 60%"></div>
                </div>
                <h4 class="small font-weight-bold">
                    Aprovime në Pritje
                    <span class="float-right">40%</span>
                </h4>
                <div class="progress mb-3">
                    <div class="progress-bar bg-warning" role="progressbar" style="width: 40%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }

    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }

    .border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }

    .border-left-danger {
        border-left: 0.25rem solid #e74a3b !important;
    }

    .text-xs {
        font-size: .7rem;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function(){
            try {
                const areaEl = document.getElementById('myAreaChart');
                if (areaEl) {
                    const monthlyData = @Html.Raw(Json.Serialize(ViewBag.MonthlyData ?? new int[0]));
                    const len = monthlyData.length || 0;
                    const labels = [];
                    for (let i = 0; i < len; i++) {
                        const d = new Date();
                        d.setMonth(d.getMonth() - (len - 1 - i));
                        labels.push(d.toLocaleString('default', { month: 'short' }));
                    }

                    const data = monthlyData.map(v => Number(v || 0));

                    new Chart(areaEl, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Dokumentet',
                                data: data,
                                borderColor: '#4e73df',
                                backgroundColor: 'rgba(78,115,223,0.05)',
                                tension: 0.4,
                                fill: true
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: true }
                    });
                }

                const pieEl = document.getElementById('myPieChart');
                if (pieEl) {
                    const types = @Html.Raw(Json.Serialize(ViewBag.DocumentTypes ?? new { Incoming = 0, Outgoing = 0, Internal = 0 }));
                    const incoming = Number(types.Incoming || 0);
                    const outgoing = Number(types.Outgoing || 0);
                    const internalCount = Number(types.Internal || 0);

                    new Chart(pieEl, {
                        type: 'doughnut',
                        data: {
                            labels: ['Hyrëse','Dalëse','Të brendshme'],
                            datasets: [{
                                data: [incoming, outgoing, internalCount],
                                backgroundColor: ['#4e73df','#1cc88a','#36b9cc'],
                                borderColor: '#fff',
                                borderWidth: 1
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: true }
                    });
                }
            }
            catch (err) { console.error('Dashboard charts init error:', err); }
        })();
    </script>
}