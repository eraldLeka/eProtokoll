@model IEnumerable<eProtokoll.Models.Users>

@{
    ViewData["Title"] = "Menaxhimi i Përdoruesve";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Përdoruesit</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-people-fill me-2"></i>
                Menaxhimi i Përdoruesve
            </h2>
            <p class="text-muted mt-2">Menaxho të gjithë përdoruesit e sistemit</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Admin" asp-controller="UserManagement" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Shto Përdorues të Ri
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Përdorues</h6>
                            <h3 class="mb-0">@Model.Count()</h3>
                        </div>
                        <div class="text-primary">
                            <i class="bi bi-people" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Administratorë</h6>
                            <h3 class="mb-0 text-danger">@Model.Count(u => u.Role == eProtokoll.Models.Users.UserRole.Administrator)</h3>
                        </div>
                        <div class="text-danger">
                            <i class="bi bi-shield-fill-check" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Menaxherë</h6>
                            <h3 class="mb-0 text-warning">@Model.Count(u => u.Role == eProtokoll.Models.Users.UserRole.Manager)</h3>
                        </div>
                        <div class="text-warning">
                            <i class="bi bi-person-badge" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Punonjës</h6>
                            <h3 class="mb-0 text-success">@Model.Count(u => u.Role == eProtokoll.Models.Users.UserRole.Employee)</h3>
                        </div>
                        <div class="text-success">
                            <i class="bi bi-person" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">Lista e Përdoruesve</h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Përdoruesi</th>
                                <th>Email</th>
                                <th>Roli</th>
                                <th>Telefoni</th>
                                <th>Statusi</th>
                                <th>Data Krijimit</th>
                                <th class="text-end">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-primary text-white me-2">
                                                @user.FirstName.Substring(0, 1)@user.LastName.Substring(0, 1)
                                            </div>
                                            <div>
                                                <strong>@user.FullName</strong><br />
                                                <small class="text-muted">@@@user.UserName</small>
                                                @if (!string.IsNullOrEmpty(user.Position))
                                                {
                                                    <br />
                                                    <small class="text-muted"><i class="bi bi-briefcase"></i> @user.Position</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="mailto:@user.Email" class="text-decoration-none">
                                            <i class="bi bi-envelope"></i> @user.Email
                                        </a>
                                    </td>
                                    <td>
                                        @switch (user.Role)
                                        {
                                            case eProtokoll.Models.Users.UserRole.Administrator:
                                                <span class="badge bg-danger"><i class="bi bi-shield-fill-check"></i> Admin</span>
                                                break;
                                            case eProtokoll.Models.Users.UserRole.Manager:
                                                <span class="badge bg-warning text-dark"><i class="bi bi-person-badge"></i> Menaxher</span>
                                                break;
                                            case eProtokoll.Models.Users.UserRole.Employee:
                                                <span class="badge bg-success"><i class="bi bi-person"></i> Punonjës</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                        {
                                            <small><i class="bi bi-telephone"></i> @user.PhoneNumber</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Aktiv</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-x-circle-fill"></i> Joaktiv</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @(user.CreatedDate != default ? user.CreatedDate.ToString("dd/MM/yyyy") : "-")
                                        </small>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-area="Admin" asp-controller="UserManagement" asp-action="Edit"
                                               asp-route-id="@user.Id"
                                               class="btn btn-outline-primary" title="Modifiko">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <form asp-area="Admin" asp-controller="UserManagement" asp-action="ToggleStatus"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit"
                                                        class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        title="@(user.IsActive ? "Çaktivizo" : "Aktivizo")">
                                                    <i class="bi @(user.IsActive ? "bi-person-slash" : "bi-person-check")"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka përdorues të regjistruar</h4>
                    <p class="text-muted">Kliko butonin "Shto Përdorues të Ri" për të filluar</p>
                    <a asp-area="Admin" asp-controller="UserManagement" asp-action="Create" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle me-1"></i> Shto Përdorues të Ri
                    </a>
                </div>
            }
        </div>
        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-white">
                <span class="text-muted">
                    Duke shfaqur <strong>@Model.Count()</strong> përdorues
                </span>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .avatar-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
            flex-shrink: 0;
        }
    </style>
}
