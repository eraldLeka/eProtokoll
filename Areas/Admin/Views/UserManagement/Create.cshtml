@model eProtokoll.Models.Users

@{
    ViewData["Title"] = "Shto Përdorues të Ri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="UserManagement" asp-action="Index">Përdoruesit</a></li>
            <li class="breadcrumb-item active" aria-current="page">Shto të Ri</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0">
                <i class="bi bi-person-plus-fill me-2 text-primary"></i>
                Shto Përdorues të Ri
            </h2>
            <p class="text-muted mt-2">Regjistro një përdorues të ri në sistem</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="UserName" class="form-label">
                                        <i class="bi bi-at text-primary"></i>
                                        Emri i Përdoruesit <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="UserName" class="form-control" placeholder="p.sh. erald.hoxha" />
                                    <span asp-validation-for="UserName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">
                                        <i class="bi bi-envelope text-primary"></i>
                                        Email <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Email" class="form-control" type="email" placeholder="erald.hoxha@example.com" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="Password" class="form-label">
                                        <i class="bi bi-key text-primary"></i>
                                        Fjalëkalimi <span class="text-danger">*</span>
                                    </label>
                                    <input type="password" name="Password" id="Password" class="form-control" />
                                    @if (TempData["PasswordError"] != null)
                                    {
                                        <span class="text-danger d-block mt-1">@TempData["PasswordError"]</span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="ConfirmPassword" class="form-label">
                                        <i class="bi bi-key-fill text-primary"></i>
                                        Konfirmo Fjalëkalimin <span class="text-danger">*</span>
                                    </label>
                                    <input type="password" name="ConfirmPassword" id="ConfirmPassword" class="form-control" />
                                    @if (TempData["ConfirmPasswordError"] != null)
                                    {
                                        <span class="text-danger d-block mt-1">@TempData["ConfirmPasswordError"]</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="FirstName" class="form-label">
                                        <i class="bi bi-person text-success"></i>
                                        Emri <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="FirstName" class="form-control" placeholder="p.sh. Erald" />
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="LastName" class="form-label">
                                        <i class="bi bi-person-fill text-success"></i>
                                        Mbiemri <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="LastName" class="form-control" placeholder="p.sh. Hoxha" />
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Position" class="form-label">
                                        <i class="bi bi-briefcase text-success"></i>
                                        Pozicioni
                                    </label>
                                    <input asp-for="Position" class="form-control" placeholder="p.sh. Sekretar i Përgjithshëm" />
                                    <span asp-validation-for="Position" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Department" class="form-label">
                                        <i class="bi bi-building text-success"></i>
                                        Departmenti
                                    </label>
                                    <input asp-for="Department" class="form-control" placeholder="p.sh. Protokolli" />
                                    <span asp-validation-for="Department" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">
                                <i class="bi bi-telephone text-success"></i>
                                Telefoni
                            </label>
                            <input asp-for="PhoneNumber" class="form-control" type="tel" placeholder="+355 69 123 4567" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label">
                                <i class="bi bi-person-badge text-warning"></i>
                                Roli në Sistem <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Role" class="form-select"
                                    asp-items="Html.GetEnumSelectList<eProtokoll.Models.Users.UserRole>()">
                                <option value="">-- Zgjidh Rolin --</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>

                        <div class="form-check form-switch mt-3">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">
                                <i class="bi bi-toggle-on text-success"></i>
                                Aktiv (përdoruesi mund të hyjë në sistem)
                            </label>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i> Anulo
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i> Ruaj Përdoruesin
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .alert {
            border-left: 4px solid;
        }

        .alert-danger {
            border-left-color: #dc3545;
        }

        .alert-warning {
            border-left-color: #ffc107;
        }

        .alert-success {
            border-left-color: #198754;
        }

        .alert-info {
            border-left-color: #0dcaf0;
        }
    </style>
}
