@model IEnumerable<eProtokoll.Models.Institution>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-building me-2"></i>
                Menaxhimi i Institucioneve
            </h2>
            <p class="text-muted mt-2">Menaxho institucionet e jashtme që komunikojnë me sistemin</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Admin" asp-controller="Institution" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Shto Institucion të Ri
            </a>
        </div>
    </div>

    <!-- Institutions Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">Lista e Institucioneve</h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Emri</th>
                                <th>Lloji</th>
                                <th>Adresa</th>
                                <th>Kontakti</th>
                                <th>Email</th>
                                <th class="text-end">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var institution in Model)
                            {
                                <tr class="@(institution.IsActive ? string.Empty : "table-secondary")">
                                    <td>
                                        <strong>@institution.Name</strong>
                                        @if (!string.IsNullOrEmpty(institution.ShortName))
                                        {
                                            <br />
                                            <small class="text-muted">(@institution.ShortName)</small>
                                        }
                                    </td>
                                    <td>
                                        @switch (institution.Type)
                                        {
                                            case eProtokoll.Models.InstitutionType.Government:
                                                <span class="badge bg-primary"><i class="bi bi-bank me-1"></i>Shtetëror</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Municipality:
                                                <span class="badge bg-info"><i class="bi bi-building me-1"></i>Bashki/Komunë</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Ministry:
                                                <span class="badge bg-success"><i class="bi bi-bank2 me-1"></i>Ministri</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Private:
                                                <span class="badge bg-warning text-dark"><i class="bi bi-briefcase me-1"></i>Private</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.NGO:
                                                <span class="badge bg-secondary"><i class="bi bi-people me-1"></i>OJF/OJQ</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.International:
                                                <span class="badge bg-danger"><i class="bi bi-globe me-1"></i>Ndërkombëtare</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Educational:
                                                <span class="badge bg-primary"><i class="bi bi-book me-1"></i>Arsimor</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Healthcare:
                                                <span class="badge bg-danger"><i class="bi bi-hospital me-1"></i>Shëndetësor</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Media:
                                                <span class="badge bg-dark"><i class="bi bi-broadcast me-1"></i>Media</span>
                                                break;
                                            case eProtokoll.Models.InstitutionType.Other:
                                                <span class="badge bg-secondary"><i class="bi bi-three-dots me-1"></i>Tjetër</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(institution.Adress))
                                        {
                                            <small>
                                                <i class="bi bi-geo-alt text-muted"></i> @institution.Adress
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(institution.Phone))
                                        {
                                            <small><i class="bi bi-telephone text-primary"></i> @institution.Phone</small>
                                        }
                                        @if (!string.IsNullOrEmpty(institution.ContactPerson))
                                        {
                                            <br />
                                            <small class="text-muted"><i class="bi bi-person"></i> @institution.ContactPerson</small>
                                        }
                                        @if (string.IsNullOrEmpty(institution.Phone) && string.IsNullOrEmpty(institution.ContactPerson))
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(institution.Email))
                                        {
                                            <small>
                                                <a href="mailto:@institution.Email" class="text-decoration-none">
                                                    <i class="bi bi-envelope text-info"></i> @institution.Email
                                                </a>
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-area="Admin" asp-controller="Institution" asp-action="Edit"
                                               asp-route-id="@institution.InstitutionId"
                                               class="btn btn-outline-primary" title="Modifiko">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            @if (institution.IsActive)
                                            {
                                                <form asp-area="Admin" asp-controller="Institution" asp-action="Deactivate" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@institution.InstitutionId" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-warning"
                                                            title="Caktivizo"
                                                            onclick="return confirm('A jeni të sigurt që dëshironi të caktivizoni institucionin \'@institution.Name\'?')">
                                                        <i class="bi bi-slash-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-area="Admin" asp-controller="Institution" asp-action="Activate" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@institution.InstitutionId" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-success"
                                                            title="Aktivizo"
                                                            onclick="return confirm('A jeni të sigurt që dëshironi të aktivizoni institucionin \'@institution.Name\'?')">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-building text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka institucione të regjistruara</h4>
                    <p class="text-muted">Kliko butonin "Shto Institucion të Ri" për të filluar</p>
                    <a asp-area="Admin" asp-controller="Institution" asp-action="Create" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle me-1"></i> Shto Institucion të Ri
                    </a>
                </div>
            }
        </div>
        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-white">
                <span class="text-muted">
                    Duke shfaqur <strong>@Model.Count()</strong> institucione
                </span>
            </div>
        }
    </div>
</div>
