@model eProtokoll.Areas.Admin.Controllers.ReportDashboardViewModel
@{
    ViewData["Title"] = "Raportet dhe Statistikat";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
        </li>
        <li class="breadcrumb-item active">Raportet</li>
    </ol>
</nav>

<!-- Dokumentet -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Dokumente</h6>
                        <h2 class="mb-0">@Model.TotalDocuments</h2>
                        <small class="text-success">
                            +@Model.CurrentMonthDocuments këtë muaj
                        </small>
                    </div>
                    <i class="bi bi-file-earmark-text text-primary" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Dokumente Hyrëse</h6>
                        <h2 class="mb-0 text-info">@Model.TotalIncomingDocuments</h2>
                        <small class="text-muted">
                            @(Model.TotalDocuments > 0
                                                        ? Math.Round((double)Model.TotalIncomingDocuments / Model.TotalDocuments * 100, 1)
                                                        : 0)%
                        </small>
                    </div>
                    <i class="bi bi-arrow-down-circle text-info" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Dokumente Dalëse</h6>
                        <h2 class="mb-0 text-warning">@Model.TotalOutgoingDocuments</h2>
                        <small class="text-muted">
                            @(Model.TotalDocuments > 0
                                                        ? Math.Round((double)Model.TotalOutgoingDocuments / Model.TotalDocuments * 100, 1)
                                                        : 0)%
                        </small>
                    </div>
                    <i class="bi bi-arrow-up-circle text-warning" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Dokumente Brendshme</h6>
                        <h2 class="mb-0 text-success">@Model.TotalInternalDocuments</h2>
                        <small class="text-muted">
                            @(Model.TotalDocuments > 0
                                                        ? Math.Round((double)Model.TotalInternalDocuments / Model.TotalDocuments * 100, 1)
                                                        : 0)%
                        </small>
                    </div>
                    <i class="bi bi-arrow-left-right text-success" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tracking Statusi -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-geo-alt me-2"></i> Gjurmimi i Dokumenteve
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="text-center p-3 border rounded">
                            <h4 class="text-warning">@Model.ActiveTrackings</h4>
                            <p class="mb-0 small text-muted">Në Proces</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-center p-3 border rounded">
                            <h4 class="text-success">@Model.CompletedTrackings</h4>
                            <p class="mb-0 small text-muted">Të Përfunduara</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Prioriteti dhe Aktiviteti -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i> Dokumente sipas Prioritetit
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>I Ulët</span>
                        <strong>@Model.LowPriorityDocuments</strong>
                    </div>
                    <div class="progress" style="height:20px;">
                        <div class="progress-bar bg-secondary" role="progressbar"
                             style="width:@(Model.TotalDocuments > 0 ? (double)Model.LowPriorityDocuments / Model.TotalDocuments * 100 : 0)%">
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Normal</span>
                        <strong>@Model.NormalPriorityDocuments</strong>
                    </div>
                    <div class="progress" style="height:20px;">
                        <div class="progress-bar bg-primary" role="progressbar"
                             style="width:@(Model.TotalDocuments > 0 ? (double)Model.NormalPriorityDocuments / Model.TotalDocuments * 100 : 0)%">
                        </div>
                    </div>
                </div>
                <div class="mb-0">
                    <div class="d-flex justify-content-between mb-1">
                        <span>I Lartë</span>
                        <strong>@Model.HighPriorityDocuments</strong>
                    </div>
                    <div class="progress" style="height:20px;">
                        <div class="progress-bar bg-warning" role="progressbar"
                             style="width:@(Model.TotalDocuments > 0 ? (double)Model.HighPriorityDocuments / Model.TotalDocuments * 100 : 0)%">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-calendar-week me-2"></i> Aktiviteti i Fundit
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <i class="bi bi-calendar-day text-primary me-2"></i> Sot
                    </div>
                    <h4 class="mb-0">@Model.TodayDocuments</h4>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <i class="bi bi-calendar-week text-info me-2"></i> Këtë Javë
                    </div>
                    <h4 class="mb-0">@Model.CurrentWeekDocuments</h4>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-calendar-month text-success me-2"></i> Këtë Muaj
                    </div>
                    <h4 class="mb-0">@Model.CurrentMonthDocuments</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Institucionet -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-building me-2"></i> Institucione
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>Total Institucione</span>
                    <h3 class="mb-0">@Model.TotalInstitutions</h3>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-success">Institucione Aktive</span>
                    <h4 class="mb-0 text-success">@Model.ActiveInstitutions</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-link me-2"></i> Lidhje të Shpejta
                </h5>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-area="Admin" asp-controller="Report" asp-action="AuditLog"
                   class="btn btn-outline-primary">
                    <i class="bi bi-shield-lock me-1"></i> Shiko Audit Log
                </a>
            </div>
        </div>
    </div>
</div>
 