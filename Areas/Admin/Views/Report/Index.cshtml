@model eProtokoll.Areas.Admin.Controllers.ReportDashboardViewModel
@{
    ViewData["Title"] = "Raportet dhe Statistikat";
    int currentYear = DateTime.Now.Year;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
        </li>
        <li class="breadcrumb-item active">Raportet</li>
    </ol>
</nav>

<!-- Dokumentet -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Dokumente</h6>
                        <h2 class="mb-0">@Model.TotalDocuments</h2>
                        <small class="text-success">+@Model.CurrentMonthDocuments këtë muaj</small>
                    </div>
                    <i class="bi bi-file-earmark-text text-primary" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Dokumente Hyrëse</h6>
                        <h2 class="mb-0 text-info">@Model.TotalIncomingDocuments</h2>
                        <small class="text-muted">
                            @(Model.TotalDocuments > 0 ? Math.Round((double)Model.TotalIncomingDocuments / Model.TotalDocuments * 100, 1) : 0)%
                        </small>
                    </div>
                    <i class="bi bi-arrow-down-circle text-info" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Dokumente Dalëse</h6>
                        <h2 class="mb-0 text-warning">@Model.TotalOutgoingDocuments</h2>
                        <small class="text-muted">
                            @(Model.TotalDocuments > 0 ? Math.Round((double)Model.TotalOutgoingDocuments / Model.TotalDocuments * 100, 1) : 0)%
                        </small>
                    </div>
                    <i class="bi bi-arrow-up-circle text-warning" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Dokumente Brendshme</h6>
                        <h2 class="mb-0 text-success">@Model.TotalInternalDocuments</h2>
                        <small class="text-muted">
                            @(Model.TotalDocuments > 0 ? Math.Round((double)Model.TotalInternalDocuments / Model.TotalDocuments * 100, 1) : 0)%
                        </small>
                    </div>
                    <i class="bi bi-arrow-left-right text-success" style="font-size:2.5rem;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Grafiku 12 Muaj -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i> Dokumentet sipas Muajit</h5>
        <div class="d-flex gap-1">
            @for (int y = currentYear; y >= currentYear - 3; y--)
            {
                <a href="@Url.Action("Index", new { year = y })"
                   class="btn btn-sm @(Model.SelectedYear == y ? "btn-primary" : "btn-outline-secondary")">@y</a>
            }
        </div>
    </div>
    <div class="card-body pt-4 pb-3">
        @if (Model.MonthlyData.All(m => m.Count == 0))
        {
            <p class="text-muted text-center py-3">Nuk ka dokumente për vitin @Model.SelectedYear.</p>
        }
        else
        {
            <div style="display:flex; align-items:flex-end; gap:6px; height:180px; padding:0 4px;">
                @foreach (var m in Model.MonthlyData)
                {
                    int heightPct = Model.MaxMonthlyCount > 0
                    ? (int)Math.Round((double)m.Count / Model.MaxMonthlyCount * 100)
                    : 0;
                    bool isCurrent = (m.Month == DateTime.Now.Month && Model.SelectedYear == currentYear);

                    <div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; height:100%; justify-content:flex-end;">
                        <span style="font-size:11px; color:#6c757d;">@(m.Count > 0 ? m.Count.ToString() : "")</span>
                        <div style="width:100%; height:@(heightPct == 0 ? 3 : heightPct)%; background-color:@(isCurrent ? "#0d6efd" : "#9ec5fe"); border-radius:4px 4px 0 0; min-height:3px;"></div>
                        <span style="font-size:10px; color:#6c757d; white-space:nowrap;">@m.MonthName.Substring(0, 3)</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Top 5 Institucionet + Top 5 Perdoruesit -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-building me-2 text-info"></i> Top 5 Institucionet</h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.TopInstitutions.Any())
                {
                    <p class="text-muted text-center py-4">Nuk ka të dhëna.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Institucioni</th>
                                <th class="text-center"><i class="bi bi-arrow-down-circle text-info" title="Hyrëse"></i></th>
                                <th class="text-center"><i class="bi bi-arrow-up-circle text-warning" title="Dalëse"></i></th>
                                <th class="text-center">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int instRank = 1;
                            }
                            @foreach (var inst in Model.TopInstitutions)
                            {
                                <tr>
                                    <td class="text-muted">@instRank</td>
                                    <td>@inst.Name</td>
                                    <td class="text-center">@inst.Incoming</td>
                                    <td class="text-center">@inst.Outgoing</td>
                                    <td class="text-center"><strong>@inst.TotalDocuments</strong></td>
                                </tr>
                                instRank++;
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-people me-2 text-success"></i> Top 5 Përdoruesit</h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.TopUsers.Any())
                {
                    <p class="text-muted text-center py-4">Nuk ka të dhëna.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Emri</th>
                                <th>Roli</th>
                                <th class="text-center">Dokumente</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int userRank = 1;
                            }
                            @foreach (var user in Model.TopUsers)
                            {
                                <tr>
                                    <td class="text-muted">@userRank</td>
                                    <td>@user.FullName</td>
                                    <td>
                                        <span class="badge @(user.Role == "Administrator" ? "bg-danger" : user.Role == "Manager" ? "bg-warning text-dark" : "bg-secondary")">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td class="text-center"><strong>@user.TotalDocuments</strong></td>
                                </tr>
                                userRank++;
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
