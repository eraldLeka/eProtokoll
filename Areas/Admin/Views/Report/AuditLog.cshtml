@model IEnumerable<eProtokoll.Models.DocumentTracking>

@{
    ViewData["Title"] = "Audit Log - Historiku i Veprimeve";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Report" asp-action="Index">Raportet</a></li>
            <li class="breadcrumb-item active" aria-current="page">Audit Log</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-shield-lock-fill me-2 text-danger"></i>
                Audit Log - Historiku i Veprimeve
            </h2>
            <p class="text-muted mt-2">Gjurmimi i të gjitha veprimeve në sistem</p>
        </div>
    </div>

    <!-- Statistika -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Veprime</h6>
                            <h3 class="mb-0">@Model.Count()</h3>
                        </div>
                        <div class="text-primary">
                            <i class="bi bi-activity" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Të Përfunduara</h6>
                            <h3 class="mb-0 text-success">@Model.Count(t => t.CompletedDate.HasValue)</h3>
                        </div>
                        <div class="text-success">
                            <i class="bi bi-check-circle-fill" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Në Proces</h6>
                            <h3 class="mb-0 text-warning">@Model.Count(t => !t.CompletedDate.HasValue && t.IsActive)</h3>
                        </div>
                        <div class="text-warning">
                            <i class="bi bi-hourglass-split" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Të Vonuara</h6>
                            <h3 class="mb-0 text-danger">@Model.Count(t => t.DueDate.HasValue && t.DueDate < DateTime.Now && !t.CompletedDate.HasValue)</h3>
                        </div>
                        <div class="text-danger">
                            <i class="bi bi-exclamation-triangle-fill" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtrat -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="bi bi-funnel me-2"></i>
                Filtro Rezultatet
            </h5>
        </div>
        <div class="card-body">
            <form method="get" asp-action="AuditLog">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Data Fillimit</label>
                        <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Data Përfundimit</label>
                        <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Përdoruesi</label>
                        <select name="userId" class="form-select">
                            <option value="">Të gjithë</option>
                            @foreach (var user in (List<dynamic>)ViewBag.Users)
                            {
                                <option value="@user.Id" selected="@(ViewBag.SelectedUserId == user.Id)">
                                    @user.UserName
                                </option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>
                            Kërko
                        </button>
                        <a asp-action="AuditLog" class="btn btn-secondary">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>
                            Rivendos
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabela e Audit Log -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="bi bi-list-ul me-2"></i>
                Historiku i Detajuar
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">Data & Ora</th>
                                <th style="width: 18%;">Dokumenti</th>
                                <th style="width: 15%;">Caktuar Nga</th>
                                <th style="width: 15%;">Caktuar Për</th>
                                <th style="width: 12%;">Statusi</th>
                                <th style="width: 10%;">Prioriteti</th>
                                <th style="width: 18%;">Shënime / Afati</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td>
                                        <small>
                                            <strong>@log.CreatedDate.ToString("dd/MM/yyyy")</strong><br />
                                            @log.CreatedDate.ToString("HH:mm")
                                        </small>
                                    </td>
                                    <td>
                                        @if (log.Document != null)
                                        {
                                            <span class="badge bg-info">@log.Document.ProtocolNumber</span>
                                            <br />
                                            @if (!string.IsNullOrEmpty(log.Document.Subject))
                                            {
                                                <small class="text-muted">
                                                    @(log.Document.Subject.Length > 40 ? log.Document.Subject.Substring(0, 40) + "..." : log.Document.Subject)
                                                </small>
                                            }
                                        }
                                    </td>
                                    <td>
                                        <i class="bi bi-person-circle text-primary"></i>
                                        @if (log.AssignedByUser != null)
                                        {
                                            <small>@log.AssignedByUser.FirstName @log.AssignedByUser.LastName</small>
                                        }
                                        else
                                        {
                                            <small>System</small>
                                        }
                                    </td>
                                    <td>
                                        <i class="bi bi-person-check text-success"></i>
                                        @if (log.AssignedToUser != null)
                                        {
                                            <small>@log.AssignedToUser.FirstName @log.AssignedToUser.LastName</small>
                                        }
                                        else
                                        {
                                            <small>-</small>
                                        }
                                    </td>
                                    <td>
                                        @if (log.CompletedDate.HasValue)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle-fill"></i> Përfunduar
                                            </span>
                                            <br />
                                            <small class="text-muted">@log.CompletedDate.Value.ToString("dd/MM/yyyy")</small>
                                        }
                                        else if (!log.IsActive)
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle"></i> Joaktiv
                                            </span>
                                        }
                                        else if (log.DueDate.HasValue && log.DueDate < DateTime.Now)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-exclamation-triangle-fill"></i> I Vonuar
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-hourglass-split"></i> Në Proces
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @switch (log.Priority)
                                        {
                                            case eProtokoll.Models.Priority.Low:
                                                <span class="badge bg-secondary">I Ulët</span>
                                                break;
                                            case eProtokoll.Models.Priority.Normal:
                                                <span class="badge bg-primary">Normal</span>
                                                break;
                                            case eProtokoll.Models.Priority.High:
                                                <span class="badge bg-warning text-dark">I Lartë</span>
                                                break;
                                            case eProtokoll.Models.Priority.Urgent:
                                                <span class="badge bg-danger">Urgjent</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.Notes))
                                        {
                                            <small class="text-muted">
                                                <i class="bi bi-sticky"></i>
                                                @(log.Notes.Length > 50 ? log.Notes.Substring(0, 50) + "..." : log.Notes)
                                            </small>
                                        }
                                        @if (log.DueDate.HasValue)
                                        {
                                            <br />
                                            <small class="@(log.DueDate < DateTime.Now && !log.CompletedDate.HasValue ? "text-danger" : "text-info")">
                                                <i class="bi bi-calendar-event"></i>
                                                Afat: @log.DueDate.Value.ToString("dd/MM/yyyy")
                                            </small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka të dhëna për këtë periudhë</h4>
                    <p class="text-muted">Provo të ndryshosh filtrat për të parë më shumë rezultate</p>
                </div>
            }
        </div>
        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted">
                        Duke shfaqur <strong>@Model.Count()</strong> veprime
                    </span>
                    <small class="text-muted">
                        Periudha: @ViewBag.StartDate deri @ViewBag.EndDate
                    </small>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .table-hover tbody tr:hover {
            background-color: rgba(0, 123, 255, 0.05);
        }

        .badge {
            font-weight: 500;
            padding: 0.35em 0.65em;
        }

        @@media print {
            .btn, .card-header, nav, .breadcrumb {
                display: none !important;
            }

            .card {
                border: none !important;
                box-shadow: none !important;
            }
        }
    </style>
}