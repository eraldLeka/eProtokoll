@model List<eProtokoll.Models.DocumentTracking>
@{
    ViewData["Title"] = "Audit Log - Historiku i Veprimeve";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Report" asp-action="Index">Raportet</a>
        </li>
        <li class="breadcrumb-item active">Audit Log</li>
    </ol>
</nav>

<!-- Statistika të shpejta nga modeli -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Veprime</h6>
                        <h3 class="mb-0">@Model.Count</h3>
                    </div>
                    <i class="bi bi-activity text-primary" style="font-size:2rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Të Përfunduara</h6>
                        <h3 class="mb-0 text-success">@Model.Count(t => t.CompletedDate.HasValue)</h3>
                    </div>
                    <i class="bi bi-check-circle-fill text-success" style="font-size:2rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Në Proces</h6>
                        <h3 class="mb-0 text-warning">
                            @Model.Count(t => !t.CompletedDate.HasValue && t.IsActive)
                        </h3>
                    </div>
                    <i class="bi bi-hourglass-split text-warning" style="font-size:2rem;"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Të Vonuara</h6>
                        <h3 class="mb-0 text-danger">
                            @Model.Count(t => t.DueDate.HasValue
                                                        && t.DueDate < DateTime.Now
                                                        && !t.CompletedDate.HasValue)
                        </h3>
                    </div>
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:2rem;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabela -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0">
            <i class="bi bi-list-ul me-2"></i> Historiku i Detajuar
        </h5>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Data &amp; Ora</th>
                            <th>Dokumenti</th>
                            <th>Tipi</th>
                            <th>Caktuar Nga</th>
                            <th>Caktuar Për</th>
                            <th>Statusi</th>
                            <th>Prioriteti</th>
                            <th>Afati / Shënime</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            var isCompleted = log.CompletedDate.HasValue;
                            var isOverdue = log.DueDate.HasValue
                            && log.DueDate < DateTime.Now
                            && !isCompleted;

                            <tr>
                                <td>
                                    <strong>@log.CreatedDate.ToString("dd/MM/yyyy")</strong><br />
                                    <small class="text-muted">@log.CreatedDate.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    <code>@(log.DocumentProtocolNumber ?? "—")</code><br />
                                    <small class="text-muted">
                                        @(log.DocumentSubject?.Length > 40
                                                                        ? log.DocumentSubject.Substring(0, 40) + "..."
                                                                        : log.DocumentSubject ?? "—")
                                    </small>
                                </td>
                                <td>
                                    @{
                                        var tipi = log.DocumentDiscriminator switch
                                        {
                                                            "IncomingDocument" => ("bg-info text-dark", "Hyrës"),
                                                            "OutgoingDocument" => ("bg-success", "Dalës"),
                                                            "InternalDocument" => ("bg-warning text-dark", "Brendshëm"),
                                            _ => ("bg-secondary", "—")
                                        };
                                    }
                                    <span class="badge @tipi.Item1">@tipi.Item2</span>
                                </td>
                                <td>
                                    <i class="bi bi-person-circle text-primary"></i>
                                    <small>@(log.AssignedByUser?.FullName ?? "—")</small>
                                </td>
                                <td>
                                    <i class="bi bi-person-check text-success"></i>
                                    <small>@(log.AssignedToUser?.FullName ?? "—")</small>
                                </td>
                                <td>
                                    @if (isCompleted)
                                    {
                                        <span class="badge bg-success">Përfunduar</span>
                                        <br />
                                        <small class="text-muted">
                                            @log.CompletedDate!.Value.ToString("dd/MM/yyyy")
                                        </small>
                                    }
                                    else if (!log.IsActive)
                                    {
                                        <span class="badge bg-secondary">Anuluar</span>
                                    }
                                    else if (isOverdue)
                                    {
                                        <span class="badge bg-danger">I Vonuar</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Në Proces</span>
                                    }
                                </td>
                                <td>
                                    @switch (log.Priority)
                                    {
                                        case eProtokoll.Models.Priority.High:
                                            <span class="badge bg-warning text-dark">I Lartë</span>
                                            break;
                                        case eProtokoll.Models.Priority.Normal:
                                            <span class="badge bg-primary">Normal</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">I Ulët</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (log.DueDate.HasValue)
                                    {
                                        <small class="@(isOverdue ? "text-danger" : "text-muted")">
                                            <i class="bi bi-calendar-event"></i>
                                            @log.DueDate.Value.ToString("dd/MM/yyyy")
                                        </small>
                                        <br />
                                    }
                                    @if (!string.IsNullOrEmpty(log.Notes))
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-sticky"></i>
                                            @(log.Notes.Length > 40
                                                                            ? log.Notes.Substring(0, 40) + "..."
                                                                            : log.Notes)
                                        </small>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white">
                <small class="text-muted">
                    Duke shfaqur <strong>@Model.Count</strong> veprime gjithsej
                </small>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                Nuk ka të dhëna në audit log.
            </div>
        }
    </div>
</div>
