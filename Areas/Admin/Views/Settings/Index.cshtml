@model IEnumerable<eProtokoll.Models.ProtocolSettings>

@{
    ViewData["Title"] = "Parametrat e Protokollit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Parametrat</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="bi bi-gear-fill me-2 text-primary"></i>
                Parametrat e Protokollit
            </h2>
            <p class="text-muted mt-2">Menaxhimi i parametrave për numërimin e dokumenteve</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="ProtocolSettings" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Parametra të Rinj
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Active Settings Card -->
    @{
        var activeSettings = Model.FirstOrDefault(s => s.IsActive);
    }

    @if (activeSettings != null)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-success shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            Parametrat Aktive - Viti @activeSettings.Year
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <h6 class="text-success"><i class="bi bi-arrow-down-circle"></i> Dokumente Hyrëse</h6>
                                <p class="mb-1"><strong>Prefiksi:</strong> @activeSettings.IncomingPrefix</p>
                                <p class="mb-1"><strong>Numri Aktual:</strong> <span class="badge bg-primary">@activeSettings.IncomingCurrentNumber</span></p>
                                <p class="mb-0"><strong>Shembull:</strong> <code>@activeSettings.IncomingPrefix-@activeSettings.IncomingCurrentNumber.ToString("D" + activeSettings.NumberPadding)/@activeSettings.Year</code></p>
                            </div>
                            <div class="col-md-4">
                                <h6 class="text-warning"><i class="bi bi-arrow-up-circle"></i> Dokumente Dalëse</h6>
                                <p class="mb-1"><strong>Prefiksi:</strong> @activeSettings.OutgoingPrefix</p>
                                <p class="mb-1"><strong>Numri Aktual:</strong> <span class="badge bg-primary">@activeSettings.OutgoingCurrentNumber</span></p>
                                <p class="mb-0"><strong>Shembull:</strong> <code>@activeSettings.OutgoingPrefix-@activeSettings.OutgoingCurrentNumber.ToString("D" + activeSettings.NumberPadding)/@activeSettings.Year</code></p>
                            </div>
                            <div class="col-md-4">
                                <h6 class="text-info"><i class="bi bi-arrow-left-right"></i> Dokumente të Brendshme</h6>
                                <p class="mb-1"><strong>Prefiksi:</strong> @activeSettings.InternalPrefix</p>
                                <p class="mb-1"><strong>Numri Aktual:</strong> <span class="badge bg-primary">@activeSettings.InternalCurrentNumber</span></p>
                                <p class="mb-0"><strong>Shembull:</strong> <code>@activeSettings.InternalPrefix-@activeSettings.InternalCurrentNumber.ToString("D" + activeSettings.NumberPadding)/@activeSettings.Year</code></p>
                            </div>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-muted">
                                    <i class="bi bi-calendar"></i> Krijuar: @activeSettings.CreatedDate.ToString("dd/MM/yyyy") nga @(activeSettings.CreatedBy ?? "System")
                                </small>
                            </div>
                            <div>
                                <a asp-action="ProtocolSettings" asp-route-id="@activeSettings.ProtocolSettingsId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Modifiko
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- All Settings Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="bi bi-list-ul me-2"></i>
                Të Gjitha Parametrat
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Viti</th>
                                <th>Hyrëse</th>
                                <th>Dalëse</th>
                                <th>Brendshme</th>
                                <th>Formati</th>
                                <th class="text-center">Statusi</th>
                                <th class="text-center">Krijuar</th>
                                <th class="text-center">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var setting in Model)
                            {
                                <tr class="@(setting.IsActive ? "table-success" : setting.IsClosed ? "table-secondary" : "")">
                                    <td>
                                        <strong>@setting.Year</strong>
                                        @if (setting.IsActive)
                                        {
                                            <span class="badge bg-success ms-2">Aktiv</span>
                                        }
                                        @if (setting.IsClosed)
                                        {
                                            <span class="badge bg-secondary ms-2">Mbyllur</span>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            <strong>@setting.IncomingPrefix</strong>-<span class="text-primary">@setting.IncomingCurrentNumber</span>
                                            @if (setting.IncomingEndNumber.HasValue)
                                            {
                                                <span class="text-muted">/@setting.IncomingEndNumber</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        <small>
                                            <strong>@setting.OutgoingPrefix</strong>-<span class="text-warning">@setting.OutgoingCurrentNumber</span>
                                            @if (setting.OutgoingEndNumber.HasValue)
                                            {
                                                <span class="text-muted">/@setting.OutgoingEndNumber</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        <small>
                                            <strong>@setting.InternalPrefix</strong>-<span class="text-info">@setting.InternalCurrentNumber</span>
                                            @if (setting.InternalEndNumber.HasValue)
                                            {
                                                <span class="text-muted">/@setting.InternalEndNumber</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        <code class="small">@setting.ProtocolNumberFormat</code>
                                    </td>
                                    <td class="text-center">
                                        @if (setting.AutoResetYearly)
                                        {
                                            <i class="bi bi-arrow-clockwise text-success" title="Rivendosje automatike"></i>
                                        }
                                        @if (setting.AllowManualEdit)
                                        {
                                            <i class="bi bi-pencil-square text-primary" title="Modifikim manual"></i>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <small class="text-muted">
                                            @setting.CreatedDate.ToString("dd/MM/yyyy")<br />
                                            <span class="badge bg-light text-dark">@(setting.CreatedBy ?? "System")</span>
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        @if (!setting.IsActive && !setting.IsClosed)
                                        {
                                            <form asp-action="Activate" method="post" class="d-inline" onsubmit="return confirm('Aktivizo këto parametra?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@setting.ProtocolSettingsId" />
                                                <button type="submit" class="btn btn-sm btn-success" title="Aktivizo">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                        }

                                        <a asp-action="ProtocolSettings" asp-route-id="@setting.ProtocolSettingsId"
                                           class="btn btn-sm btn-outline-primary" title="Modifiko">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (setting.IsActive && !setting.IsClosed)
                                        {
                                            <form asp-action="Close" method="post" class="d-inline" onsubmit="return confirm('Mbyll këto parametra? Nuk do të mund të përdoren më për dokumente të reja.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@setting.ProtocolSettingsId" />
                                                <button type="submit" class="btn btn-sm btn-warning" title="Mbyll">
                                                    <i class="bi bi-lock"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (!setting.IsActive)
                                        {
                                            <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Fshi këto parametra? Ky veprim nuk mund të kthehet!');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@setting.ProtocolSettingsId" />
                                                <button type="submit" class="btn btn-sm btn-danger" title="Fshi" @(setting.IsClosed ? "disabled" : "")>
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-muted">Nuk ka parametra</h4>
                    <p class="text-muted">Fillo duke krijuar parametrat e parë për protokollimin e dokumenteve</p>
                    <a asp-action="ProtocolSettings" class="btn btn-primary mt-2">
                        <i class="bi bi-plus-circle me-1"></i>
                        Krijo Parametra
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Info Cards -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card border-info shadow-sm">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Informacion i Dobishëm
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="small mb-0">
                        <li class="mb-2">Vetëm një set parametrash mund të jetë aktiv në të njëjtën kohë</li>
                        <li class="mb-2">Parametrat aktivë përdoren për të gjeneruar numrat e protokollit</li>
                        <li class="mb-2">Mbyllni parametrat e vitit të kaluar kur të fillojë viti i ri</li>
                        <li class="mb-2">Nuk mund të fshihen parametra që kanë dokumente të regjistruara</li>
                        <li>Rekomandohet të krijohen parametra të rinj në fillim të çdo viti</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-warning shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Vërejtje të Rëndësishme
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="small mb-0">
                        <li class="mb-2">Ndryshimi i parametrave aktiv ndikon në të gjitha dokumentet e reja</li>
                        <li class="mb-2">Numrat aktual të protokollit rriten automatikisht me çdo dokument</li>
                        <li class="mb-2">Mos modifikoni numrat aktual nëse nuk jeni të sigurt</li>
                        <li class="mb-2">Mbyllni parametrat e vjetër për të parandaluar përdorimin aksidental</li>
                        <li>Bëni backup të databazës para se të fshini parametra</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table-success {
            background-color: rgba(25, 135, 84, 0.1) !important;
        }

        .table-secondary {
            background-color: rgba(108, 117, 125, 0.1) !important;
            opacity: 0.7;
        }

        code {
            background-color: #f8f9fa;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 0.875rem;
        }

        .card:hover {
            transform: translateY(-2px);
            transition: all 0.3s ease;
        }
    </style>
}