@model eProtokoll.Models.InternalDocument
@using eProtokoll.Models

@{
    ViewData["Title"] = "Regjistro Dokument Brendshëm";

    var accessUsers = ViewBag.AccessUsers as IEnumerable<eProtokoll.Models.Users> ?? Enumerable.Empty<eProtokoll.Models.Users>();
    var selectedIds = ViewBag.SelectedAccessUserIds as List<int> ?? new List<int>();
    bool isConfidential = Model.Classification == Classification.Confidential;
    int confidentialValue = (int)Classification.Confidential;
    var isResponse = Model?.IsResponse == true;
}

<div class="container-fluid">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="InternalDocument" asp-action="Index">Dokumente Brendshme</a>
            </li>
            <li class="breadcrumb-item active">Regjistro të Ri</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-12">

            <form asp-controller="InternalDocument"
                  asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()
                @if (ViewBag.TrackingId != null)
                {
                    <input type="hidden" name="trackingId" value="@ViewBag.TrackingId" />
                }

                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-arrow-left-right me-2"></i>
                            Regjistro Dokument Brendshëm të Ri
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger mb-3" asp-validation-summary="All"></div>
                        }

                        <div class="mb-3">
                            <div class="mb-3">
                                <label asp-for="Subject" class="form-label"></label>
                                <input asp-for="Subject" class="form-control" placeholder="Subjekti i dokumentit" />
                                <span asp-validation-for="Subject" class="text-danger"></span>
                            </div>
                            <hr/>
                            <h6 class="text-success mb-3">
                                <i class="bi bi-building me-2"></i> Informacioni i Qarkullimit
                            </h6>
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label asp-for="FromDepartment" class="form-label"></label>
                                    <input asp-for="FromDepartment"
                                           class="form-control"
                                           placeholder="Departamenti dërgues"
                                           readonly="@(isResponse ? "readonly" : null)" />
                                    <span asp-validation-for="FromDepartment" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ToDepartment" class="form-label"></label>
                                    <input asp-for="ToDepartment"
                                           class="form-control"
                                           placeholder="Departamenti marrës"
                                           readonly="@(isResponse ? "readonly" : null)" />
                                    <span asp-validation-for="ToDepartment" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <div class="mb-3">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-shield-lock me-2"></i> Klasifikimi dhe Detajet
                            </h6>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label asp-for="Classification" class="form-label">Klasifikimi</label>
                                    <select asp-for="Classification"
                                            class="form-select"
                                            asp-items="ViewBag.Classifications as List<SelectListItem>"
                                            onchange="toggleAccessUsers(this.value)"
                                            disabled="@(isResponse ? "disabled" : null)">
                                        <option value="">-- Zgjidh klasifikimin --</option>
                                    </select>
                                    @if (isResponse)
                                    {
                                        <input type="hidden" asp-for="Classification" />
                                    }
                                    <span asp-validation-for="Classification" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Priority" class="form-label">Prioriteti</label>
                                    <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<Priority>()"></select>
                                    <span asp-validation-for="Priority" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    @if (!isResponse)
                                    {
                                        <div class="form-check mt-1">
                                            <input class="form-check-input" type="checkbox"
                                                   asp-for="RequiresResponse" id="requiresResponse" />
                                            <label class="form-check-label fw-semibold" for="requiresResponse">
                                                <i class="bi bi-reply-fill me-1 text-warning"></i>
                                                Kërkon Përgjigje
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div id="accessUsersSection" style="display: @(isConfidential ? "block" : "none")">
                                <hr class="my-3" />
                                <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                                    <i class="bi bi-lock-fill fs-5"></i>
                                    <span>Dokumenti është <strong>I Kufizuar</strong>. Zgjidh përdoruesit që do kenë qasje.</span>
                                </div>

                                @if (!string.IsNullOrEmpty(ViewData.ModelState["accessUserIds"]?.Errors.FirstOrDefault()?.ErrorMessage))
                                {
                                    <div class="text-danger mb-2">
                                        @ViewData.ModelState["accessUserIds"]!.Errors.First().ErrorMessage
                                    </div>
                                }

                                <div class="mb-0">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-people-fill me-1"></i> Përdoruesit me Qasje
                                    </label>

                                    @if (!accessUsers.Any())
                                    {
                                        <p class="text-muted fst-italic">Nuk ka përdorues aktiv.</p>
                                    }
                                    else
                                    {
                                        <div class="border rounded p-3" style="max-height: 220px; overflow-y: auto;">
                                            @foreach (var user in accessUsers)
                                            {
                                                var isChecked = selectedIds.Contains(user.Id);
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           name="accessUserIds"
                                                           value="@user.Id"
                                                           id="user_@user.Id"
                                                    @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label" for="user_@user.Id">
                                                        @user.FirstName @user.LastName
                                                        <span class="text-muted small">(@user.UserName)</span>
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                        <div class="form-text">Zgjidh një ose më shumë përdorues.</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <h6 class="text-secondary mb-3">
                                <i class="bi bi-paperclip me-2"></i> Bashkëngjit Dokument
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label class="form-label">Ngarko Skedarin (PDF)</label>
                                    <input type="file" name="attachmentFile" class="form-control" accept=".pdf" />
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label">Ose Merr nga Skaneri</label>
                                    <div class="d-flex gap-2">
                                        <select id="scannerSelect" class="form-select" disabled>
                                            <option value="">-- Duke kërkuar skanerët... --</option>
                                        </select>
                                        <button type="button" class="btn btn-outline-secondary" onclick="loadScanners()">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                        <button type="button" class="btn btn-primary" id="scanBtn" onclick="startScan()" disabled>
                                            <i class="bi bi-scanner me-1"></i> Skano
                                        </button>
                                    </div>
                                    <div id="scanStatus" class="form-text mt-1"></div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            @if (isResponse)
                            {
                                <div class="mb-3">
                                    <h6 class="text-primary mb-3">
                                        <i class="bi bi-link-45deg me-2"></i> Lidhje me Dokument Brendshëm
                                    </h6>
                                    <input type="text" class="form-control" value="@ViewBag.OriginalInternalDisplay" readonly />
                                    <input type="hidden" asp-for="OriginalInternalDocumentId" />
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-controller="InternalDocument" asp-action="Index" class="btn btn-outline-secondary">
                                Kthehu
                            </a>
                            <input type="hidden" id="scanSessionKey" name="scanSessionKey" />
                            <button type="submit" class="btn btn-success px-5">
                                Ruaj Dokumentin
                            </button>
                        </div>

                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    var confidentialValue = '@confidentialValue';

    function toggleAccessUsers(val) {
        var section = document.getElementById('accessUsersSection');
        section.style.display = (val === confidentialValue) ? 'block' : 'none';
    }

    function toggleInternalResponse(val) {
        const section = document.getElementById('internalResponseSection');
        if (!section) return;
        section.style.display = val ? 'block' : 'none';
    }
</script>