@model eProtokoll.Models.OutgoingDocument
@using eProtokoll.Models

@{
    ViewData["Title"] = "Regjistro Dokument Dalës";

    var accessUsers = ViewBag.AccessUsers as IEnumerable<Users> ?? Enumerable.Empty<Users>();
    var selectedIds = ViewBag.SelectedAccessUserIds as List<int> ?? new List<int>();

    bool isConfidential = Model != null && Model.Classification == Classification.Confidential;
    int confidentialValue = (int)Classification.Confidential;
}

<div class="container-fluid">

    <!-- BREADCRUMB -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="OutgoingDocument" asp-action="Index">Dokumente Dalëse</a>
            </li>
            <li class="breadcrumb-item active">Regjistro të Ri</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-12">

            <form asp-controller="OutgoingDocument"
                  asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()
                @if (ViewBag.TrackingId != null)
                {
                    <input type="hidden" name="trackingId" value="@ViewBag.TrackingId" />
                }

                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-plus me-2"></i>
                            Regjistro Dokument Dalës të Ri
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger mb-3" asp-validation-summary="All"></div>
                        }

                        <div class="mb-3">
                            <h6 class="text-info mb-3">
                                <i class="bi bi-building me-2"></i> Informacioni i Marrësit
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="InstitutionId" class="form-label">Institucioni Marrës</label>
                                    <select asp-for="InstitutionId" class="form-select" asp-items="ViewBag.Institutions">
                                        <option value="">-- Zgjidh Institucionin --</option>
                                    </select>
                                    <span asp-validation-for="InstitutionId" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="RecipientName" class="form-label">Emri i Marrësit</label>
                                    <input asp-for="RecipientName" class="form-control" />
                                    <span asp-validation-for="RecipientName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <h6 class="text-secondary mb-3">
                                <i class="bi bi-file-text me-2"></i> Përmbajtja e Dokumentit
                            </h6>
                            <div class="mb-3">
                                <label asp-for="Subject" class="form-label">Subjekti</label>
                                <input asp-for="Subject" class="form-control" />
                            </div>
                            <div class="mb-0">
                                <label asp-for="Content" class="form-label">Përshkrimi</label>
                                <textarea asp-for="Content" class="form-control" rows="5"></textarea>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-link-45deg me-2"></i> Lidhje me Dokument Hyrës
                            </h6>
                            <div class="form-check mb-2">
                                <input asp-for="IsResponse" class="form-check-input" type="checkbox" onchange="toggleIncoming(this.checked)" />
                                <label class="form-check-label">Është përgjigje</label>
                            </div>
                            <div id="incomingSection" style="display:@(Model != null && Model.IsResponse ? "block" : "none")">
                                <select asp-for="OriginalIncomingDocumentId" class="form-select" asp-items="ViewBag.IncomingDocuments">
                                    <option value="">-- Zgjidh Dokument Hyrës --</option>
                                </select>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-tags me-2"></i> Klasifikimi dhe Detajet
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="Classification" class="form-label">Klasifikimi</label>
                                    <select asp-for="Classification" class="form-select" asp-items="ViewBag.Classifications" onchange="toggleAccess(this.value)">
                                        <option value="">-- Zgjidh --</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Priority" class="form-label">Prioriteti</label>
                                    <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<Priority>()"></select>
                                </div>
                            </div>

                            <div id="accessSection" style="display:@(isConfidential ? "block" : "none")" class="mt-3">
                                <div class="alert alert-warning d-flex align-items-center gap-2">
                                    <i class="bi bi-lock-fill fs-5"></i>
                                    <span>Dokument i kufizuar</span>
                                </div>

                                <div class="border rounded p-3" style="max-height:220px; overflow-y:auto;">
                                    @foreach (var u in accessUsers)
                                    {
                                        var checkedUser = selectedIds.Contains(u.Id);

                                        <div class="form-check mb-2">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="accessUserIds"
                                                   value="@u.Id"
                                            @(checkedUser ? "checked" : "") />

                                            <label class="form-check-label">
                                                @u.FirstName @u.LastName
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <h6 class="text-secondary mb-3">
                                <i class="bi bi-paperclip me-2"></i> Bashkëngjitja e Dokumentit
                            </h6>

                            <div class="mb-3">
                                <label class="form-label">Ngarko Skedarin</label>
                                <input type="file" name="attachmentFile" class="form-control" accept=".pdf" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Ose Merr nga Skaneri</label>

                                <div class="d-flex gap-2 align-items-center">
                                    <select id="scannerSelect" class="form-select" disabled>
                                        <option value="">-- Duke kërkuar skanerët... --</option>
                                    </select>

                                    <button type="button" class="btn btn-outline-secondary" onclick="loadScanners()">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>

                                    <button type="button" class="btn btn-primary" id="scanBtn" onclick="startScan()" disabled>
                                        <i class="bi bi-scanner me-1"></i>
                                        Skano
                                    </button>
                                </div>

                                <div id="scanStatus" class="form-text mt-1"></div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-controller="OutgoingDocument" asp-action="Index" class="btn btn-outline-secondary">
                                Kthehu
                            </a>

                            <input type="hidden" id="scanSessionKey" name="scanSessionKey" />

                            <button type="submit" class="btn btn-info px-5">
                                Ruaj Dokumentin
                            </button>
                        </div>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
            function toggleIncoming(val) {
                const section = document.getElementById('incomingSection');
                if (!section) return;
                section.style.display = val ? 'block' : 'none';
            }
    </script>
    <script src="~/js/scanner.js" asp-append-version="true"></script>
    <script>initScanner('outgoing');</script>
}