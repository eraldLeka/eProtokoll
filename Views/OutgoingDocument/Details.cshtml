@model eProtokoll.Models.OutgoingDocument

@{
    var area = ViewData["area"]?.ToString() ?? "Manager";
    var showDelete = (bool)(ViewData["showDelete"] ?? true);
    Layout = area == "Employee" ? "~/Views/Shared/_EmployeeLayout.cshtml" : "~/Views/Shared/_ManagerLayout.cshtml";
    ViewData["Title"] = "Detajet e Dokumentit";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="OutgoingDocument" asp-action="Index">Dokumente Dalëse</a>
            </li>
            <li class="breadcrumb-item active">@Model.ProtocolNumber</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-2">
                <i class="bi bi-file-earmark-arrow-up me-2 text-success"></i>
                @Model.Subject
            </h2>
            <div class="d-flex gap-2 flex-wrap">
                <span class="badge bg-success fs-6">@Model.ProtocolNumber</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <!-- INFORMACIONI I MARRËSIT -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-building me-2"></i>
                        Informacioni i Marrësit
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">Institucioni Marrës</small>
                            <h6>
                                <i class="bi bi-bank text-info"></i>
                                @(Model.Institution?.Name ?? "N/A")
                            </h6>
                            @if (!string.IsNullOrEmpty(Model.Institution?.Adress))
                            {
                                <small class="text-muted">
                                    <i class="bi bi-geo-alt"></i> @Model.Institution.Adress
                                </small>
                            }
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Emri i Marrësit</small>
                            <h6>
                                <i class="bi bi-person text-info"></i>
                                @Model.RecipientName
                            </h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PËRGJIGJE PËR DOKUMENT HYRËS -->
            @if (Model.IsResponse && Model.OriginalIncomingDocumentId.HasValue)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-arrow-return-left me-2"></i>
                            Përgjigje për Dokument Hyrës
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Ky dokument është përgjigje për dokumentin hyrës:</strong>
                            <br />
                            <a asp-area="@area" asp-controller="IncomingDocument" asp-action="Details"
                               asp-route-id="@Model.OriginalIncomingDocumentId"
                               class="btn btn-sm btn-info mt-2">
                                <i class="bi bi-box-arrow-up-right"></i> Shiko Dokumentin Origjinal
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- INFORMACION -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Informacion</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <small class="text-muted">Klasifikimi</small>
                            <h6>
                                <i class="bi bi-shield-lock text-warning"></i>
                                @Html.DisplayFor(model => model.Classification)
                            </h6>
                        </div>
                        <div class="col-md-4 mb-3">
                            <small class="text-muted">Prioriteti</small>
                            <h6>
                                @switch (Model.Priority)
                                {
                                    case Priority.High:
                                        <span class="badge bg-warning text-dark">I Lartë</span>
                                        break;
                                    case Priority.Normal:
                                        <span class="badge bg-info">Normal</span>
                                        break;
                                    case Priority.Low:
                                        <span class="badge bg-secondary">I Ulët</span>
                                        break;
                                }
                            </h6>
                        </div>
                        <div class="col-md-4 mb-3">
                            <small class="text-muted">Bashkëngjitje</small>
                            <h6>
                                @if (Model.HasAttachments && Model.Attachments != null && Model.Attachments.Any())
                                {
                                    <i class="bi bi-check-circle text-success"></i>
                                    <span>@Model.Attachments.Count file</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted"></i>
                                    <span>Asnjë</span>
                                }
                            </h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BASHKËNGJITJET -->
            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-paperclip"></i>
                            Bashkëngjitjet (@Model.Attachments.Count)
                        </h5>
                    </div>
                    @foreach (var att in Model.Attachments)
                    {
                        <div class="list-group-item d-flex align-items-center">

                            <div class="me-3">
                                @if (att.FileExtension == ".pdf")
                                {
                                    <i class="bi bi-file-pdf-fill text-danger" style="font-size:2rem;"></i>
                                }
                                else if (att.FileExtension == ".docx" || att.FileExtension == ".doc")
                                {
                                    <i class="bi bi-file-word-fill text-primary" style="font-size:2rem;"></i>
                                }
                                else if (att.FileExtension == ".xlsx" || att.FileExtension == ".xls")
                                {
                                    <i class="bi bi-file-excel-fill text-success" style="font-size:2rem;"></i>
                                }
                                else if (att.FileExtension == ".jpg" || att.FileExtension == ".jpeg" || att.FileExtension == ".png")
                                {
                                    <i class="bi bi-file-image-fill text-info" style="font-size:2rem;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-file-fill text-secondary" style="font-size:2rem;"></i>
                                }
                            </div>

                            <div class="flex-grow-1">

                                <h6 class="mb-1">
                                    @att.OriginalFileName
                                </h6>

                                <small class="text-muted">
                                    @att.FileSizeMB MB |
                                    Ngarkuar: @att.UploadedDate.ToString("dd/MM/yyyy HH:mm") |
                                    Nga: @(Model.Creator?.FullName ?? "N/A")
                                </small>

                            </div>

                            <div class="btn-group btn-group-sm">

                                <a href="@att.FilePath" target="_blank" class="btn btn-outline-primary">
                                    <i class="bi bi-eye"></i> Shiko
                                </a>

                                <a href="@att.FilePath" download class="btn btn-outline-success">
                                    <i class="bi bi-download"></i>
                                </a>

                            </div>

                        </div>
                    }
                </div>
            }

            <!-- METADATA -->
            <div class="card shadow-sm mb-4 bg-light">
                <div class="card-body small">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Krijuar nga:</strong> @(Model.Creator!.FullName)<br />
                            <strong>Data e Krijimit:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 12px;
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            font-weight: 600;
        }

        @@media print {
            .btn, .breadcrumb, .modal, nav {
                display: none !important;
            }
        }
    </style>
}