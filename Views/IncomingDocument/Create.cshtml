@model eProtokoll.Models.IncomingDocument
@using eProtokoll.Models

@{
    var area = ViewData["area"]?.ToString() ?? "Manager";
    Layout = area == "Employee"
        ? "~/Views/Shared/_EmployeeLayout.cshtml"
        : "~/Views/Shared/_ManagerLayout.cshtml";

    ViewData["Title"] = "Regjistro Dokument Hyrës";

    var accessUsers = ViewBag.AccessUsers as IEnumerable<eProtokoll.Models.Users> ?? Enumerable.Empty<eProtokoll.Models.Users>();
    var selectedIds = ViewBag.SelectedAccessUserIds as List<int> ?? new List<int>();
    bool isConfidential = Model.Classification == Classification.Confidential;
    int confidentialValue = (int)Classification.Confidential;
}

<div class="container-fluid">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="IncomingDocument" asp-action="Index">Dokumente Hyrëse</a>
            </li>
            <li class="breadcrumb-item active">Regjistro të Ri</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0">
                <i class="bi bi-file-earmark-plus me-2 text-info"></i>
                Regjistro Dokument Hyrës të Ri
            </h2>
            <p class="text-muted mt-2">
                Plotëso të dhënat e dokumentit që vjen nga institucioni i jashtëm
            </p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">

            <form asp-area="@area"
                  asp-controller="IncomingDocument"
                  asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                }

                <!-- Sender -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-building me-2"></i>
                            Informacioni i Dërguesit
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="InstitutionId" class="form-label">Institucioni Dërgues</label>
                                    <select asp-for="InstitutionId"
                                            class="form-select"
                                            asp-items="ViewBag.Institutions">
                                        <option value="">-- Zgjidh Institucionin --</option>
                                    </select>
                                    <span asp-validation-for="InstitutionId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SenderName" class="form-label">Emri i Dërguesit</label>
                                    <input asp-for="SenderName"
                                           class="form-control"
                                           placeholder="Emri i plotë i dërguesit" />
                                    <span asp-validation-for="SenderName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Content -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Përmbajtja e Dokumentit</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">Subjekti</label>
                            <input asp-for="Subject"
                                   class="form-control"
                                   placeholder="Subjekti i dokumentit" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">Përshkrimi</label>
                            <textarea asp-for="Content" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="OriginalDocumentNumber" class="form-label">
                                Nr. Origjinal i Dokumentit
                            </label>
                            <input asp-for="OriginalDocumentNumber" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Classification -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning">
                        <h5 class="mb-0">Klasifikimi dhe Detajet</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Classification" class="form-label">Klasifikimi</label>
                                    <select asp-for="Classification"
                                            id="classificationSelect"
                                            name="Classification"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<Classification>()"
                                            onchange="toggleAccessUsers(this.value)">
                                        <option value="">-- Zgjidh Klasifikimin --</option>
                                    </select>
                                    <span asp-validation-for="Classification" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="ReceivedDate" class="form-label">Data e Marrjes</label>
                                    <input asp-for="ReceivedDate" type="date" class="form-control" />
                                    <span asp-validation-for="ReceivedDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="Priority" class="form-label">Prioriteti</label>
                                    <select asp-for="Priority" class="form-select"
                                            asp-items="Html.GetEnumSelectList<Priority>()">
                                    </select>
                                    <span asp-validation-for="Priority" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-center mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           asp-for="RequiresResponse" id="requiresResponse" />
                                    <label class="form-check-label fw-semibold" for="requiresResponse">
                                        <i class="bi bi-reply-fill me-1 text-warning"></i>
                                        Kërkon Përgjigje
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- who can see document if restricted -->
                        <div id="accessUsersSection" style="display: @(isConfidential ? "block" : "none")">
                            <hr />
                            <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-lock-fill fs-5"></i>
                                <span>
                                    Dokumenti është <strong>I Kufizuar</strong>.
                                    Zgjidh përdoruesit që do kenë qasje.
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(ViewData.ModelState["accessUserIds"]?.Errors.FirstOrDefault()?.ErrorMessage))
                            {
                                <div class="text-danger mb-2">
                                    @ViewData.ModelState["accessUserIds"]!.Errors.First().ErrorMessage
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-people-fill me-1"></i>
                                    Përdoruesit me Qasje
                                </label>

                                @if (!accessUsers.Any())
                                {
                                    <p class="text-muted fst-italic">Nuk ka përdorues aktiv.</p>
                                }
                                else
                                {
                                    <div class="border rounded p-3" style="max-height: 220px; overflow-y: auto;">
                                        @foreach (var user in accessUsers)
                                        {
                                            var isChecked = selectedIds.Contains(user.Id);
                                            <div class="form-check mb-2">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="accessUserIds"
                                                       value="@user.Id"
                                                       id="user_@user.Id"
                                                @(isChecked ? "checked" : "") />
                                                <label class="form-check-label" for="user_@user.Id">
                                                    @user.FirstName @user.LastName
                                                    <span class="text-muted small">(@user.UserName)</span>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                    <div class="form-text">Zgjidh një ose më shumë përdorues.</div>
                                }
                            </div>
                        </div>

                    </div>
                </div>

                <!-- File -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Bashkëngjitja e Dokumentit</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Ngarko Skedarin</label>
                            <input type="file"
                                   name="attachmentFile"
                                   id="attachmentFile"
                                   class="form-control"
                                   accept=".pdf" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ose Merr nga Skaneri</label>
                            <div class="d-flex gap-2">
                                <select id="scannerSelect" class="form-select" disabled>
                                    <option value="">-- Duke kërkuar skanerët... --</option>
                                </select>
                                <button type="button" class="btn btn-outline-secondary" onclick="loadScanners()">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                                <button type="button" class="btn btn-primary" id="scanBtn" onclick="startScan()" disabled>
                                    <i class="bi bi-scanner me-1"></i> Skano
                                </button>
                            </div>
                            <div id="scanStatus" class="form-text mt-1"></div>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body d-flex justify-content-between">
                        <a asp-area="@area"
                               asp-controller="IncomingDocument"
                               asp-action="Index"
                               class="btn btn-outline-secondary">
                            Kthehu
                        </a>
                        <input type="hidden" id="scanSessionKey" name="scanSessionKey" value="" />
                        <button type="submit" class="btn btn-info btn-lg px-5">
                            Ruaj Dokumentin
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    var confidentialValue = '@confidentialValue';
    var currentScanKey = null;

    function toggleAccessUsers(val) {
        var section = document.getElementById('accessUsersSection');
        section.style.display = (val === confidentialValue) ? 'block' : 'none';
    }

        async function loadScanners() {
        try {
            const status = document.getElementById('scanStatus');
            const select = document.getElementById('scannerSelect');

            status.textContent = 'Duke kërkuar skanerët...';

            const response = await fetch('http://localhost:7331/scanners');
            const scanners = await response.json();

            select.innerHTML = '';

            scanners.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                select.appendChild(opt);
            });

            select.disabled = false;
            document.getElementById('scanBtn').disabled = false;

            status.textContent = scanners.length + ' skaner gjetur.';
        }
        catch (e) {
            document.getElementById('scanStatus').textContent =
                'Shërbimi i skanerit nuk është aktiv.';
        }
    }

    async function startScan() {
        const scanner = document.getElementById('scannerSelect').value;

        const status = document.getElementById('scanStatus');
        const btn = document.getElementById('scanBtn');

        status.textContent = 'Duke skanuar...';
        btn.disabled = true;

        try {
            const res = await fetch(
                'http://localhost:7331/scan?subfolder=outgoing&scanner=' +
                encodeURIComponent(scanner),
                { method: 'POST' }
            );

            const result = await res.json();

            if (result.success) {
                currentScanKey = result.sessionKey;
                document.getElementById('scanSessionKey').value = result.sessionKey;

                status.textContent = 'Skanimi u krye me sukses!';
            }
        }
        catch (e) {
            status.textContent = 'Gabim gjatë skanimit.';
        }
        finally {
            btn.disabled = false;
        }
    }

    async function cancelScan() {
        if (currentScanKey) {
            navigator.sendBeacon('/api/scan/cancel?key=' + currentScanKey);
            currentScanKey = null;
        }
    }

    window.addEventListener('beforeunload', cancelScan);

    loadScanners();
</script>