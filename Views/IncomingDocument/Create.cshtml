@model eProtokoll.Models.IncomingDocument
@using eProtokoll.Models

@{
    var area = ViewData["area"]?.ToString() ?? "Manager";
    Layout = area == "Employee"
        ? "~/Views/Shared/_EmployeeLayout.cshtml"
        : "~/Views/Shared/_ManagerLayout.cshtml";

    ViewData["Title"] = "Regjistro Dokument Hyrës";

    var accessUsers = ViewBag.AccessUsers as IEnumerable<eProtokoll.Models.Users> ?? Enumerable.Empty<eProtokoll.Models.Users>();
    var selectedIds = ViewBag.SelectedAccessUserIds as List<int> ?? new List<int>();
    bool isConfidential = Model.Classification == Classification.Confidential;
    int confidentialValue = (int)Classification.Confidential;
}

<div class="container-fluid py-2">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="IncomingDocument" asp-action="Index">Dokumente Hyrëse</a>
            </li>
            <li class="breadcrumb-item active">Regjistro të Ri</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-12">

            <form asp-area="@area"
                  asp-controller="IncomingDocument"
                  asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-plus me-2"></i>
                            Regjistro Dokument Hyrës të Ri
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger mb-3" asp-validation-summary="All"></div>
                        }

                        <!-- Dërguesi -->
                        <div class="mb-3">
                            <div class="mb-3">
                                <label asp-for="Subject" class="form-label">Subjekti</label>
                                <input asp-for="Subject" class="form-control" placeholder="Subjekti i dokumentit" />
                                <span asp-validation-for="Subject" class="text-danger"></span>
                            </div>
                            <div class="mb-0">
                                <label asp-for="OriginalDocumentNumber" class="form-label">Nr. Origjinal i Dokumentit</label>
                                <input asp-for="OriginalDocumentNumber" class="form-control" />
                            </div>
                            <hr />
                            <h6 class="text-info mb-3">
                                <i class="bi bi-building me-2"></i> Informacioni i Dërguesit
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="InstitutionId" class="form-label">Institucioni Dërgues</label>
                                    <select asp-for="InstitutionId" class="form-select" asp-items="ViewBag.Institutions">
                                        <option value="">-- Zgjidh Institucionin --</option>
                                    </select>
                                    <span asp-validation-for="InstitutionId" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SenderName" class="form-label">Emri i Dërguesit</label>
                                    <input asp-for="SenderName" class="form-control" placeholder="Emri i plotë i dërguesit" />
                                    <span asp-validation-for="SenderName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <hr />

                        <!-- Klasifikimi -->
                        <div class="mb-3">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-tags me-2"></i> Klasifikimi dhe Detajet
                            </h6>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label asp-for="Classification" class="form-label">Klasifikimi</label>
                                    <select asp-for="Classification"
                                            id="classificationSelect"
                                            name="Classification"
                                            class="form-select"
                                            asp-items="ViewBag.Classifications"
                                            onchange="toggleAccessUsers(this.value)">
                                        <option value="">-- Zgjidh Klasifikimin --</option>
                                    </select>
                                    <span asp-validation-for="Classification" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="ReceivedDate" class="form-label">Data e Marrjes</label>
                                    <input asp-for="ReceivedDate" type="date" class="form-control" />
                                    <span asp-validation-for="ReceivedDate" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Priority" class="form-label">Prioriteti</label>
                                    <select asp-for="Priority" class="form-select"
                                            asp-items="Html.GetEnumSelectList<Priority>()"></select>
                                    <span asp-validation-for="Priority" class="text-danger"></span>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-check mt-1">
                                        <input class="form-check-input" type="checkbox" asp-for="RequiresResponse" id="requiresResponse" />
                                        <label class="form-check-label fw-semibold" for="requiresResponse">
                                            <i class="bi bi-reply-fill me-1 text-warning"></i> Kërkon Përgjigje
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div id="accessUsersSection" style="display: @(isConfidential ? "block" : "none")">
                                <hr class="my-3" />
                                <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                                    <i class="bi bi-lock-fill fs-5"></i>
                                    <span>Dokumenti është <strong>I Kufizuar</strong>. Zgjidh përdoruesit që do kenë qasje.</span>
                                </div>

                                @if (!string.IsNullOrEmpty(ViewData.ModelState["accessUserIds"]?.Errors.FirstOrDefault()?.ErrorMessage))
                                {
                                    <div class="text-danger mb-2">
                                        @ViewData.ModelState["accessUserIds"]!.Errors.First().ErrorMessage
                                    </div>
                                }

                                <div class="mb-0">
                                    <label class="form-label fw-semibold">
                                        <i class="bi bi-people-fill me-1"></i> Përdoruesit me Qasje
                                    </label>
                                    @if (!accessUsers.Any())
                                    {
                                        <p class="text-muted fst-italic">Nuk ka përdorues aktiv.</p>
                                    }
                                    else
                                    {
                                        <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                                            @foreach (var user in accessUsers)
                                            {
                                                var isChecked = selectedIds.Contains(user.Id);
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           name="accessUserIds"
                                                           value="@user.Id"
                                                           id="user_@user.Id"
                                                    @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label" for="user_@user.Id">
                                                        @user.FirstName @user.LastName
                                                        <span class="text-muted small">(@user.UserName)</span>
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                        <div class="form-text">Zgjidh një ose më shumë përdorues.</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Bashkëngjitja -->
                        <div class="mb-3">
                            <h6 class="text-secondary mb-3">
                                <i class="bi bi-paperclip me-2"></i> Bashkëngjitja e Dokumentit
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label class="form-label">Ngarko Skedarin (PDF)</label>
                                    <input type="file" name="attachmentFile" id="attachmentFile" class="form-control" accept=".pdf" />
                                </div>
                                <div class="col-md-7">
                                    <label class="form-label">Ose Merr nga Skaneri</label>
                                    <div class="d-flex gap-2">
                                        <select id="scannerSelect" class="form-select" disabled>
                                            <option value="">-- Duke kërkuar skanerët... --</option>
                                        </select>
                                        <button type="button" class="btn btn-outline-secondary" onclick="loadScanners()" title="Rifresko">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                        <button type="button" class="btn btn-primary" id="scanBtn" onclick="startScan()" disabled>
                                            <i class="bi bi-scanner me-1"></i> Skano
                                        </button>
                                    </div>
                                    <div id="scanStatus" class="form-text mt-1"></div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Footer Buttons -->
                        <div class="d-flex justify-content-between">
                            <a asp-area="@area" asp-controller="IncomingDocument" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Kthehu
                            </a>
                            <input type="hidden" id="scanSessionKey" name="scanSessionKey" value="" />
                            <button type="submit" class="btn btn-info px-5">
                                <i class="bi bi-floppy me-1"></i> Ruaj Dokumentin
                            </button>
                        </div>

                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var confidentialValue = '@confidentialValue';

        function toggleAccessUsers(val) {
            var section = document.getElementById('accessUsersSection');
            section.style.display = (val === confidentialValue) ? 'block' : 'none';
        }
    </script>
    <script src="~/js/scanner.js" asp-append-version="true"></script>
    <script>initScanner('incoming');</script>
}