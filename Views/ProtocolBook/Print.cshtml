@model IEnumerable<eProtokoll.Models.Document>
@using eProtokoll.Models

@{
    Layout = null;
    var area = ViewData["area"]?.ToString() ?? "Manager";
}

<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <title>Libri i Protokollit</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #000;
            background: #fff;
            padding: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
        }

        .header h1 {
            font-size: 18px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .header p {
            font-size: 11px;
            color: #444;
            margin-top: 4px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        thead th {
            background-color: #f0f0f0;
            border: 1px solid #999;
            padding: 5px 6px;
            text-align: left;
            font-size: 10px;
            font-weight: bold;
            text-transform: uppercase;
        }

        tbody td {
            border: 1px solid #ccc;
            padding: 4px 6px;
            vertical-align: top;
        }

        tbody tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .footer {
            margin-top: 20px;
            font-size: 10px;
            color: #666;
            text-align: right;
        }

        @@media print {
            body { padding: 0; }
            .no-print { display: none; }
            thead { display: table-header-group; }
            tbody tr { page-break-inside: avoid; }
        }
    </style>
</head>
<body onload="window.print()">

    <!-- Butoni për print (fshihet gjatë printimit) -->
    <div class="no-print" style="margin-bottom:15px;">
        <button onclick="window.print()" style="padding:6px 16px;font-size:12px;cursor:pointer;">
            <b>🖨 Printo</b>
        </button>
    </div>

    <div class="header">
        <h1>Libri i Protokollit</h1>
        <p>Gjeneruar më: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        <p>Gjithsej: @Model.Count() dokumente</p>
    </div>

    <table>
        <thead>
            <tr>
                <th style="width:11%">Nr. Protokollit</th>
<th style="width:9%">Lloji</th>
<th style="width:32%">Subjekti</th>
<th style="width:11%">Data</th>
<th style="width:11%">Klasifikimi</th>
<th style="width:10%">Prioriteti</th>
<th style="width:16%">Krijuar Nga</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model)
            {
                <tr>
                    <td><strong>@doc.ProtocolNumber</strong></td>
                    <td>
                        @switch (doc.DocumentType)
                        {
                            case DocumentType.Incoming:  <text>Hyrës</text>  break;
                            case DocumentType.Outgoing:  <text>Dalës</text>  break;
                            case DocumentType.Internal:  <text>Brendshëm</text> break;
                        }
                    </td>
                    <td>@doc.Subject</td>
                    <td>@doc.CreatedDate.ToString("dd/MM/yyyy")</td>
                    <td>@doc.Classification</td>
                    <td>
                        @switch (doc.Priority)
                        {
                            case Priority.High:   <text>I Lartë</text>  break;
                            case Priority.Normal: <text>Normal</text>   break;
                            case Priority.Low:    <text>I Ulët</text>   break;
                        }
                    </td>
                    <td>@doc.Creator?.FullName</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="footer">
        eProtokoll &mdash; @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
    </div>

</body>
</html>