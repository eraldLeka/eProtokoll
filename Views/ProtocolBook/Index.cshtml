@model IEnumerable<eProtokoll.Models.Document>
@using eProtokoll.Models

@{
    var area = ViewData["area"]?.ToString() ?? "Manager";
    Layout = area == "Employee"
        ? "~/Views/Shared/_EmployeeLayout.cshtml"
        : area == "Admin"
            ? "~/Views/Shared/_AdminLayout.cshtml"
            : "~/Views/Shared/_ManagerLayout.cshtml";

    ViewData["Title"] = "Libri i Protokollit";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item active">Libri i Protokollit</li>
        </ol>
    </nav>

   <div class="row mb-4">
    <div class="col-md-8">
        <h2><i class="bi bi-book text-primary"></i> Libri i Protokollit</h2>
        <p class="text-muted">Regjistri i plotë i të gjitha dokumenteve</p>
    </div>
    <div class="col-md-4 d-flex align-items-center justify-content-end">
        <a asp-controller="ProtocolBook" asp-action="Print"
           target="_blank" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-printer"></i> Printo Librin
        </a>
    </div>
</div>

    <!-- Protocol Book Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-list"></i> Regjistri (@ViewBag.TotalItems)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:10%">Protokolli</th>
                                <th style="width:8%">Lloji</th>
                                <th style="width:25%">Subjekti</th>
                                <th style="width:8%">Data</th>
                                <th style="width:8%">Klasifikimi</th>
                                <th style="width:8%">Prioriteti</th>
                                <th style="width:10%">Kërkon Përgjigje</th>
                                <th style="width:10%">Krijuar Nga</th>
                                <th style="width:5%">Veprime</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model)
                            {
                                var attachment = doc.Attachments?.FirstOrDefault();
                                <tr>
                                    <td>
                                        <strong class="
                                            @(doc.DocumentType == DocumentType.Incoming ? "text-info" :
                                              doc.DocumentType == DocumentType.Outgoing ? "text-success" : "text-warning")">
                                            @doc.ProtocolNumber
                                        </strong>
                                    </td>
                                    <td>
                                        @switch (doc.DocumentType)
                                        {
                                            case DocumentType.Incoming:
                                                <span class="badge bg-info"><i class="bi bi-arrow-down-circle"></i> Hyrës</span>
                                                break;
                                            case DocumentType.Outgoing:
                                                <span class="badge bg-success"><i class="bi bi-arrow-up-circle"></i> Dalës</span>
                                                break;
                                            case DocumentType.Internal:
                                                <span class="badge bg-warning text-dark"><i class="bi bi-arrow-left-right"></i> Brendshëm</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width:300px" title="@doc.Subject">@doc.Subject</div>
                                    </td>
                                    <td><small>@doc.CreatedDate.ToString("dd/MM/yyyy")<br />@doc.CreatedDate.ToString("HH:mm")</small></td>
                                    <td><small>@Html.DisplayFor(_ => doc.Classification)</small></td>
                                    <td>
                                        @switch (doc.Priority)
                                        {
                                            case Priority.High:
                                                <span class="badge bg-danger">I Lartë</span>
                                                break;
                                            case Priority.Normal:
                                                <span class="badge bg-secondary">Normal</span>
                                                break;
                                            case Priority.Low:
                                                <span class="badge bg-light text-dark">I Ulët</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (doc.RequiresResponse)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-reply-fill me-1"></i>Po
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Jo</span>
                                        }
                                    </td>
                                    <td><small>@doc.Creator?.FullName</small></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            @if (attachment != null)
                                            {
                                                <a asp-controller="DocumentFile" asp-action="View"
                                                   asp-route-id="@attachment.AttachmentId"
                                                   asp-route-fileName="@attachment.OriginalFileName"
                                                   target="_blank" class="btn btn-outline-primary" title="Shiko">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a asp-controller="DocumentFile" asp-action="Download"
                                                   asp-route-id="@attachment.AttachmentId"
                                                   asp-route-fileName="@attachment.OriginalFileName"
                                                   class="btn btn-outline-success" title="Shkarko">
                                                    <i class="bi bi-download"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-secondary" disabled title="Nuk ka skedar">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary" disabled title="Nuk ka skedar">
                                                    <i class="bi bi-download"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (ViewBag.TotalPages > 1)
                {
                    <div class="card-footer bg-white">
                        <nav>
                            <ul class="pagination pagination-sm mb-0 justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new {
                                        searchTerm = ViewBag.SearchTerm,
                                        page = ViewBag.CurrentPage - 1
                                    })">Mbrapa</a>
                                </li>
                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new {
                                            searchTerm = ViewBag.SearchTerm,
                                            page = i
                                        })">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new {
                                        searchTerm = ViewBag.SearchTerm,
                                        page = ViewBag.CurrentPage + 1
                                    })">Përpara</a>
                                </li>
                            </ul>
                        </nav>
                        <div class="text-center mt-2">
                            <small class="text-muted">Faqja @ViewBag.CurrentPage nga @ViewBag.TotalPages (@ViewBag.TotalItems dokumente)</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size:4rem"></i>
                    <h4 class="mt-3 text-muted">Nuk ka dokumente</h4>
                </div>
            }
        </div>
    </div>
</div>