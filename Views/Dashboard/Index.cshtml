@using eProtokoll.Models
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-house-door me-2 text-info"></i>
                Mirë se vini, @User.Identity?.Name
            </h2>
            <p class="text-muted mb-0">
                Përmbledhja e aktivitetit - @DateTime.Now.ToString("dd MMMM yyyy")
            </p>
        </div>
    </div>

    <!-- MAIN ROW -->
    <div class="row mb-4">

        <!-- RECENT DOCUMENTS -->
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2 text-info"></i>
                        Dokumentet e Fundit
                    </h5>

                    <a asp-controller="ProtocolBook"
                           asp-action="Index"
                           class="btn btn-sm btn-outline-info">
                        Libër Protokolli
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="card-body p-0">

                    @if (ViewBag.RecentDocuments != null)
                    {
                        var docs = ViewBag.RecentDocuments as IEnumerable<Document>;

                        if (docs != null && docs.Any())
                        {
                            <table class="table table-hover align-middle mb-0">

                                <thead class="table-light">
                                    <tr>
                                        <th>Protokolli</th>
                                        <th>Subjekti</th>
                                        <th>Lloji</th>
                                        <th>Data</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var doc in docs)
                                    {
                                        <tr>
                                            <td><strong>@doc.ProtocolNumber</strong></td>

                                            <td>
                                                <div class="text-truncate" style="max-width:350px;">
                                                    @doc.Subject
                                                </div>
                                            </td>

                                            <td>
                                                @switch (doc.DocumentType)
                                                {
                                                    case DocumentType.Incoming:
                                                        <span class="badge bg-info">Hyrës</span>
                                                        break;

                                                    case DocumentType.Outgoing:
                                                        <span class="badge bg-success">Dalës</span>
                                                        break;

                                                    case DocumentType.Internal:
                                                        <span class="badge bg-warning text-dark">Brendshëm</span>
                                                        break;
                                                }
                                            </td>

                                            <td>
                                                <small>@doc.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>

                            </table>
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size:3rem"></i>
                                <p class="mt-2">Nuk ka dokumente</p>
                            </div>
                        }
                    }

                </div>

            </div>

        </div>

        <!-- QUICK ACTIONS -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm">

                <div class="card-header text-white" style="background-color:#0aa2c0;">
                    <h5 class="mb-0">
                        <i class="bi bi-lightning-charge me-2"></i>
                        Veprime të Shpejta
                    </h5>
                </div>

                <div class="card-body">

                    <div class="d-grid gap-2">

                        <a asp-controller="IncomingDocument"
                               asp-action="Create"
                               class="btn btn-info">
                            <i class="bi bi-arrow-down-circle me-2"></i>
                            Dokument Hyrës
                        </a>

                        <a asp-controller="OutgoingDocument"
                               asp-action="Create"
                               class="btn btn-success">
                            <i class="bi bi-arrow-up-circle me-2"></i>
                            Dokument Dalës
                        </a>

                        <a asp-controller="InternalDocument"
                               asp-action="Create"
                               class="btn btn-warning">
                            <i class="bi bi-arrow-left-right me-2"></i>
                            Dokument Brendshëm
                        </a>

                        <hr />

                        <a asp-controller="ProtocolBook"
                               asp-action="Index"
                               class="btn btn-outline-info">
                            <i class="bi bi-book me-2"></i>
                            Libër Protokolli
                        </a>

                        <a asp-controller="Report"
                               asp-action="Index"
                               class="btn btn-outline-secondary">
                            <i class="bi bi-bar-chart me-2"></i>
                            Raporte
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- ACTIVITY CHART -->
    <div class="row">

        <div class="col-12">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white">
                    <h5 class="mb-0">
                        <i class="bi bi-bar-chart-line me-2 text-info"></i>
                        Aktiviteti 7 Ditëve të Fundit
                    </h5>
                </div>

                <div class="card-body">

                    @{
                        var dailyStats = ViewBag.DailyStats as IEnumerable<dynamic>;
                    }

                    @if (dailyStats != null && dailyStats.Any())
                    {
                        <div class="d-flex align-items-end gap-3" style="height:180px;">

                            @{
                                var maxVal = dailyStats.Max(d => (int)d.Count);
                                if (maxVal == 0) maxVal = 1;
                            }

                            @foreach (var day in dailyStats)
                            {
                                var height = (int)day.Count * 100 / maxVal;

                                <div class="flex-fill d-flex flex-column align-items-center justify-content-end h-100">

                                    <small class="text-muted">@day.Count</small>

                                    <div style="
                                        width:60%;
                                        height:@(Math.Max(height, 3))%;
                                        background:#0aa2c0;
                                        border-radius:4px 4px 0 0;">
                                    </div>

                                    <small class="text-muted mt-2" style="font-size:11px;">
                                        @day.Date
                                    </small>

                                </div>
                            }

                        </div>
                    }
                    else
                    {
                        <p class="text-center text-muted">Nuk ka të dhëna.</p>
                    }

                </div>

            </div>

        </div>

    </div>

</div>