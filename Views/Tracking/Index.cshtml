@model List<eProtokoll.Models.DocumentTracking>

@{
    ViewData["Title"] = "Gjurmimi i Dokumenteve";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalItems = (int)(ViewBag.TotalItems ?? 0);
    var showActionsColumn = User.IsInRole("Employee");
    var emptyColspan = showActionsColumn ? 9 : 8;
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <span class="text-muted">
        Gjithsej: <strong>@totalItems</strong> gjurmime
    </span>

    @* ONLY Manager + Admin can see Assign *@
    @if (User.IsInRole("Manager") || User.IsInRole("Administrator"))
    {
        <a asp-controller="Tracking"
               asp-action="Assign"
               class="btn btn-sm"
               style="background-color:#6f42c1; color:white;">
            <i class="bi bi-plus-circle me-1"></i> Cakto Dokument
        </a>
    }

</div>

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nr. Protokollit</th>
                    <th>Subjekti</th>
                    <th>Caktuar Për</th>
                    <th>Caktuar Nga</th>
                    <th>Data Caktimit</th>
                    <th>Afati</th>
                    <th>Prioriteti</th>
                    <th>Statusi</th>
                    @if (showActionsColumn)
                    {
                        <th>Veprime</th>
                    }
                </tr>
            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@emptyColspan" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            Nuk ka gjurmime.
                        </td>
                    </tr>
                }

                @foreach (var tracking in Model)
                {
                    var isCompleted = tracking.CompletedDate.HasValue;

                    var isOverdue = tracking.DueDate.HasValue
                                    && tracking.DueDate.Value < DateTime.Now
                                    && !isCompleted;

                    <tr class="@(isOverdue ? "table-danger" : "")">

                        <td><code>@tracking.DocumentProtocolNumber</code></td>

                        <td>
                            @(tracking.DocumentSubject?.Length > 50
                                ? tracking.DocumentSubject.Substring(0, 50) + "..."
                                : tracking.DocumentSubject ?? "—")
                        </td>

                        <td>@(tracking.AssignedToUser?.FullName ?? "—")</td>

                        <td>@(tracking.AssignedByUser?.FullName ?? "—")</td>

                        <td>@tracking.AssignedDate.ToString("dd/MM/yyyy")</td>

                        <td>
                            @if (tracking.DueDate.HasValue)
                            {
                                <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                    @tracking.DueDate.Value.ToString("dd/MM/yyyy")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>

                        <td>
                            @switch (tracking.Priority)
                            {
                                case eProtokoll.Models.Priority.High:
                                    <span class="badge bg-warning text-dark">I Lartë</span>
                                    break;

                                case eProtokoll.Models.Priority.Normal:
                                    <span class="badge bg-info text-dark">Normal</span>
                                    break;

                                default:
                                    <span class="badge bg-secondary">I Ulët</span>
                                    break;
                            }
                        </td>

                        <td>
                            @if (isCompleted)
                            {
                                <span class="badge bg-success">Përfunduar</span>
                            }
                            else if (isOverdue)
                            {
                                <span class="badge bg-danger">Vonuar</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Aktiv</span>
                            }
                        </td>

                        @if (showActionsColumn)
                        {
                            <td>
                                @if (!isCompleted &&
                                     (tracking.DocumentType == eProtokoll.Models.DocumentType.Incoming ||
                                      tracking.DocumentType == eProtokoll.Models.DocumentType.Internal))
                                {
                                    <a asp-controller="Tracking"
                                       asp-action="Respond"
                                       asp-route-id="@tracking.TrackingId"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Përgjigju">
                                        <i class="bi bi-reply-fill"></i>
                                    </a>
                                }
                            </td>
                        }

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-controller="Tracking"
                       asp-action="Index"
                       asp-route-page="@(currentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-controller="Tracking"
                       asp-action="Index"
                       asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link"
                       asp-controller="Tracking"
                       asp-action="Index"
                       asp-route-page="@(currentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>

        </ul>
    </nav>
}