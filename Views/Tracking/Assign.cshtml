@model eProtokoll.Models.DocumentTracking

@{
    ViewData["Title"] = "Cakto Dokument";
    var document = ViewBag.Document as eProtokoll.Models.Document;
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mb-3">
        @TempData["ErrorMessage"]
    </div>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Tracking" asp-action="Index">Gjurmimi</a>
        </li>
        <li class="breadcrumb-item active">Cakto Dokument</li>
    </ol>
</nav>

<h4 class="mb-4">
    <i class="bi bi-person-plus-fill me-2" style="color:#6f42c1;"></i>
    Cakto Dokument
</h4>

@if (document != null)
{
    <div class="alert alert-info mb-4">
        <i class="bi bi-file-earmark-text me-2"></i>
        <strong>@document.ProtocolNumber</strong> — @document.Subject
    </div>
}

<form asp-controller="Tracking" asp-action="Assign" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header text-white" style="background-color:#6f42c1;">
            <h5 class="mb-0">
                <i class="bi bi-info-circle me-2"></i>
                Informacioni i Caktimit
            </h5>
        </div>

        <div class="card-body">

            @if (document == null)
            {
                <div class="mb-3">
                    <label asp-for="DocumentId" class="form-label fw-semibold">
                        Dokumenti <span class="text-danger">*</span>
                    </label>

                    <select asp-for="DocumentId"
                            class="form-select"
                            asp-items="ViewBag.Documents"
                            required>
                        <option value="">-- Zgjidhni dokumentin --</option>
                    </select>

                    <span asp-validation-for="DocumentId" class="text-danger"></span>
                </div>
            }
            else
            {
                <input asp-for="DocumentId" type="hidden" />
            }

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="AssignedToUserId" class="form-label fw-semibold">
                        Cakto Për <span class="text-danger">*</span>
                    </label>

                    <select asp-for="AssignedToUserId"
                            class="form-select"
                            asp-items="ViewBag.Employees"
                            required>
                        <option value="">-- Zgjidhni punonjësin --</option>
                    </select>

                    <span asp-validation-for="AssignedToUserId" class="text-danger"></span>
                </div>

                <div class="col-md-3 mb-3">
                    <label asp-for="AssignedDate" class="form-label fw-semibold">
                        Data e Caktimit <span class="text-danger">*</span>
                    </label>

                    <input asp-for="AssignedDate"
                           class="form-control"
                           type="datetime-local"
                           required />

                    <span asp-validation-for="AssignedDate" class="text-danger"></span>
                </div>

                <div class="col-md-3 mb-3">
                    <label asp-for="DueDate" class="form-label fw-semibold">
                        Afati Kohor
                    </label>

                    <input asp-for="DueDate"
                           class="form-control"
                           type="date" />

                    <span asp-validation-for="DueDate" class="text-danger"></span>
                    <small class="text-muted">Opsionale</small>
                </div>

            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label asp-for="Priority" class="form-label fw-semibold">
                        Prioriteti
                    </label>

                    <select asp-for="Priority"
                            class="form-select"
                            asp-items="Html.GetEnumSelectList<eProtokoll.Models.Priority>()">
                    </select>

                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>

                <div class="col-md-8 mb-3">
                    <label asp-for="Notes" class="form-label fw-semibold">
                        Shënime / Udhëzime
                    </label>

                    <textarea asp-for="Notes"
                              class="form-control"
                              rows="3"
                                  placeholder="Shkruani udhëzime ose shënime për punonjësin...">
                    </textarea>

                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                </div>

            </div>
        </div>

        <div class="d-flex justify-content-between">

            <a asp-controller="Tracking"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i> Anulo
            </a>

            <button type="submit"
                    class="btn btn-lg px-5 text-white"
                    style="background-color:#6f42c1;">
                <i class="bi bi-check-circle-fill me-1"></i>
                Cakto Dokumentin
            </button>

        </div>

    </form>

    @section Styles {
        <style>
            .text-purple {
                color: #6f42c1 !important;
            }
        </style>
    }