@using System.Security.Claims
@inject eProtokoll.Repositories.ITrackingRepository TrackingRepository
@inject eProtokoll.Repositories.Documents.IDocumentRepository DocumentRepository
@{
    var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "Employee";
    var userId = int.TryParse(userIdClaim, out var parsedUserId) ? parsedUserId : 0;

    var overdueCount = userId > 0
        ? await TrackingRepository.GetOverdueCountAsync(userId)
        : 0;

    var totalNotifications = overdueCount;

    var newDocumentsCount = userId > 0
        ? await DocumentRepository.GetNewVisibleDocumentsCountAsync(userId, role)
        : 0;

    var notificationItems = userId > 0
        ? await TrackingRepository.GetNotificationItemsAsync(userId, 10)
        : new List<eProtokoll.Models.DocumentTracking>();

    var overdueNotificationItems = notificationItems
        .Where(n => n.DueDate.HasValue && n.DueDate.Value < DateTime.Now)
        .ToList();

    var newDocuments = userId > 0
        ? await DocumentRepository.GetNewVisibleDocumentsAsync(userId, role, 10)
        : new List<eProtokoll.Models.Document>();

    totalNotifications += newDocumentsCount;

    var notificationSignatureParts = new List<string>();

    foreach (var n in overdueNotificationItems)
    {
        notificationSignatureParts.Add($"T-{n.TrackingId}-{n.AssignedDate.Ticks}");
    }

    foreach (var d in newDocuments)
    {
        notificationSignatureParts.Add($"D-{d.DocumentId}-{d.CreatedDate.Ticks}");
    }

    var notificationSignature = string.Join("|", notificationSignatureParts);
}

<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eProtokoll Punonjës</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            overflow: hidden;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            height: 56px;
            background-color: #0aa2c0 !important;
        }

        .wrapper {
            display: flex;
            height: calc(100vh - 56px);
            margin-top: 56px;
        }

        .sidebar {
            width: 16.666%;
            min-width: 200px;
            height: 100%;
            overflow-y: auto;
            background-color: #f8f9fa;
            box-shadow: inset -1px 0 0 rgba(0,0,0,.1);
            flex-shrink: 0;
        }

        .sidebar-heading {
            font-size: .75rem;
            text-transform: uppercase;
        }

        .sidebar .nav-link {
            font-weight: 500;
            color: #333;
            padding: 0.75rem 1rem;
            border-left: 3px solid transparent;
        }

            .sidebar .nav-link:hover {
                color: #0aa2c0;
                background-color: #f8f9fa;
                border-left-color: #0aa2c0;
            }

            .sidebar .nav-link.active {
                color: #0aa2c0;
                border-left-color: #0aa2c0;
                background-color: #cff4fc;
            }

            .sidebar .nav-link i {
                margin-right: 0.5rem;
            }

        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 0 1.5rem 1.5rem 1.5rem;
        }

        .navbar-brand {
            font-weight: bold;
        }

        .alert-auto {
            animation: alertFadeOut 0.6s ease 4.4s forwards;
        }

        .notification-menu {
            min-width: 320px;
            max-width: 380px;
            max-height: 380px;
            overflow-y: auto;
        }

        .notification-item {
            white-space: normal;
            padding: 0.6rem 0.9rem;
            border-bottom: 1px solid #f1f1f1;
            text-decoration: none;
            display: block;
            color: #212529;
        }

        .notification-item:hover {
            background-color: #f8f9fa;
            color: #212529;
        }

        .notification-item.notification-unread {
            background-color: #e9ecef;
        }

        .notification-item.notification-unread:hover {
            background-color: #dee2e6;
        }

        .notification-title {
            font-weight: 600;
            font-size: 0.9rem;
        }

        .notification-meta {
            font-size: 0.8rem;
            color: #6c757d;
        }

        @@keyframes alertFadeOut {
            to {
                opacity: 0;
                height: 0;
                padding: 0;
                margin: 0;
                overflow: hidden;
                border: none;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- TOP NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">

            <a class="navbar-brand" asp-area="Employee" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-file-earmark-text"></i> eProtokoll - Punonjës
            </a>

            <ul class="navbar-nav ms-auto align-items-center">

                <!-- Notifications -->
                <li class="nav-item dropdown me-3" id="employeeNotificationsDropdown">
                    <a class="nav-link position-relative"
                       href="#"
                       id="employeeNotifications"
                       data-user-id="@userId"
                       data-notification-signature="@notificationSignature"
                       role="button"
                       data-bs-toggle="dropdown"
                       aria-expanded="false"
                       title="Njoftimet">
                        <i class="bi bi-bell-fill"></i>
                        @if (totalNotifications > 0)
                        {
                            <span id="employeeNotificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @totalNotifications
                            </span>
                        }
                    </a>

                    <div class="dropdown-menu dropdown-menu-end notification-menu" aria-labelledby="employeeNotifications">
                        <div class="px-3 py-2 border-bottom">
                            <div class="fw-semibold">Njoftimet</div>
                            <small class="text-muted">Vonesa: @overdueCount • Shkresa të reja: @newDocumentsCount</small>
                        </div>

                        @if (overdueNotificationItems.Any())
                        {
                            @foreach (var n in overdueNotificationItems)
                            {
                                var overdueNotificationKey = $"T-{n.TrackingId}";
                                <a class="notification-item"
                                   data-notification-key="@overdueNotificationKey"
                                   asp-area="Employee"
                                   asp-controller="Tracking"
                                   asp-action="Index">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="notification-title">@n.DocumentProtocolNumber</span>
                                        <span class="badge bg-danger">Vonuar</span>
                                    </div>
                                    <div class="notification-meta">@(n.DocumentSubject ?? "Pa subjekt")</div>
                                </a>
                            }
                        }
                        else if (!newDocuments.Any())
                        {
                            <div class="px-3 py-3 text-muted">Nuk ka njoftime.</div>
                        }

                        @if (newDocuments.Any())
                        {
                            <div class="px-3 py-2 border-top border-bottom bg-light">
                                <small class="fw-semibold text-muted">Shkresa të reja</small>
                            </div>

                            @foreach (var d in newDocuments)
                            {
                                var controller = d.DocumentType switch
                                {
                                    eProtokoll.Models.DocumentType.Incoming => "IncomingDocument",
                                    eProtokoll.Models.DocumentType.Outgoing => "OutgoingDocument",
                                    eProtokoll.Models.DocumentType.Internal => "InternalDocument",
                                    _ => "ProtocolBook"
                                };
                                var newDocumentNotificationKey = $"D-{d.DocumentId}";

                                <a class="notification-item"
                                   data-notification-key="@newDocumentNotificationKey"
                                   asp-area="Employee"
                                   asp-controller="@controller"
                                   asp-action="Index">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="notification-title">@d.ProtocolNumber</span>
                                    </div>
                                    <div class="notification-meta">@(d.Subject ?? "Pa subjekt")</div>
                                </a>
                            }
                        }

                    </div>
                </li>

                <!-- User -->
                <li class="nav-item me-3">
                    <span class="nav-link">
                        <i class="bi bi-person-circle"></i>
                        @User.Identity?.Name
                    </span>
                </li>

                <!-- Logout -->
                <li class="nav-item">
                    <form asp-area=""
                          asp-controller="Account"
                          asp-action="Logout"
                          method="post">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-outline-light btn-sm">
                            <i class="bi bi-box-arrow-right"></i> Dilni
                        </button>

                    </form>
                </li>

            </ul>

        </div>
    </nav>


    <!-- WRAPPER -->
    <div class="wrapper">

        <!-- SIDEBAR -->
        <nav id="sidebar" class="sidebar">
            <div class="pt-3">

                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                    AKTIVITETET
                </h6>

                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="Dashboard"
                           asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="Tracking"
                           asp-action="Index">
                            <i class="bi bi-geo-alt"></i>
                            Gjurmimi i Dokumenteve
                        </a>
                    </li>

                </ul>


                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                    MENAXHIM DOKUMENTESH
                </h6>

                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="IncomingDocument"
                           asp-action="Index">
                            <i class="bi bi-arrow-down-circle"></i>
                            Dokumente Hyrëse
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="OutgoingDocument"
                           asp-action="Index">
                            <i class="bi bi-arrow-up-circle"></i>
                            Dokumente Dalëse
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="InternalDocument"
                           asp-action="Index">
                            <i class="bi bi-arrow-left-right"></i>
                            Dokumente të Brendshme
                        </a>
                    </li>

                </ul>


                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                    PROTOKOLLI & RAPORTE
                </h6>

                <ul class="nav flex-column mb-2">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="ProtocolBook"
                           asp-action="Index">
                            <i class="bi bi-book"></i>
                            Libër Protokolli
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Employee"
                           asp-controller="Report"
                           asp-action="Index">
                            <i class="bi bi-bar-chart"></i>
                            Raporte Statistikore
                        </a>
                    </li>

                </ul>

            </div>
        </nav>


        <!-- MAIN CONTENT -->
        <main class="main-content">

            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">@ViewData["Title"]</h1>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-auto">
                    <i class="bi bi-check-circle"></i>
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-auto">
                    <i class="bi bi-exclamation-triangle"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            @if (TempData["WarningMessage"] != null)
            {
                <div class="alert alert-warning alert-auto">
                    <i class="bi bi-exclamation-circle"></i>
                    @TempData["WarningMessage"]
                </div>
            }

            @if (TempData["InfoMessage"] != null)
            {
                <div class="alert alert-info alert-auto">
                    <i class="bi bi-info-circle"></i>
                    @TempData["InfoMessage"]
                </div>
            }

            @RenderBody()

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dropdown = document.getElementById('employeeNotificationsDropdown');
            const badge = document.getElementById('employeeNotificationBadge');
            const bell = document.getElementById('employeeNotifications');

            if (!dropdown || !bell) return;

            const userId = bell.dataset.userId;
            const itemsStorageKey = `employee_notifications_items_seen_${userId}`;
            const bellSeenKeysStorageKey = `employee_notifications_bell_seen_keys_${userId}`;

            let seenItemKeys = [];
            try {
                const rawSeen = localStorage.getItem(itemsStorageKey);
                seenItemKeys = rawSeen ? JSON.parse(rawSeen) : [];
            } catch {
                seenItemKeys = [];
            }

            const seenSet = new Set(seenItemKeys);
            const notificationLinks = document.querySelectorAll('.notification-item[data-notification-key]');
            const currentKeys = Array.from(notificationLinks)
                .map(link => link.getAttribute('data-notification-key'))
                .filter(key => !!key);

            let bellSeenKeys = [];
            try {
                const rawBellSeen = localStorage.getItem(bellSeenKeysStorageKey);
                bellSeenKeys = rawBellSeen ? JSON.parse(rawBellSeen) : [];
            } catch {
                bellSeenKeys = [];
            }

            const bellSeenSet = new Set(bellSeenKeys);
            const newSinceBellClickCount = currentKeys.filter(key => !bellSeenSet.has(key)).length;

            notificationLinks.forEach(function (link) {
                const key = link.getAttribute('data-notification-key');
                if (!key) return;

                if (!seenSet.has(key)) {
                    link.classList.add('notification-unread');
                }

                link.addEventListener('click', function () {
                    seenSet.add(key);
                    localStorage.setItem(itemsStorageKey, JSON.stringify(Array.from(seenSet)));
                    link.classList.remove('notification-unread');
                });
            });

            if (badge) {
                if (newSinceBellClickCount > 0) {
                    badge.textContent = newSinceBellClickCount;
                    badge.classList.remove('d-none');
                } else {
                    badge.classList.add('d-none');
                }
            }

            dropdown.addEventListener('shown.bs.dropdown', function () {
                localStorage.setItem(bellSeenKeysStorageKey, JSON.stringify(currentKeys));

                if (badge) {
                    badge.classList.add('d-none');
                }
            });
        });
    </script>

</body>
</html>