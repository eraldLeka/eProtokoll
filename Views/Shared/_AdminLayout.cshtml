<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eProtokoll Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            overflow: hidden;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            height: 56px;
        }

        .wrapper {
            display: flex;
            height: calc(100vh - 56px);
            margin-top: 56px;
        }

        .sidebar {
            width: 16.666%;
            min-width: 200px;
            height: 100%;
            overflow-y: auto;
            background-color: #f8f9fa;
            box-shadow: inset -1px 0 0 rgba(0,0,0,.1);
            flex-shrink: 0;
        }

        .sidebar-heading {
            font-size: .75rem;
            text-transform: uppercase;
        }

        .sidebar .nav-link {
            font-weight: 500;
            color: #333;
            padding: 0.75rem 1rem;
            border-left: 3px solid transparent;
        }

            .sidebar .nav-link:hover {
                color: #0d6efd;
                background-color: #f8f9fa;
                border-left-color: #0d6efd;
            }

            .sidebar .nav-link.active {
                color: #0d6efd;
                border-left-color: #0d6efd;
                background-color: #e7f1ff;
            }

            .sidebar .nav-link i {
                margin-right: 0.5rem;
            }

        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 0 1.5rem 1.5rem 1.5rem;
        }

        .navbar-brand {
            font-weight: bold;
        }

        .alert-auto {
            animation: alertFadeOut 0.6s ease 4.4s forwards;
        }

        @@keyframes alertFadeOut {
            to {
                opacity: 0;
                height: 0;
                padding: 0;
                margin: 0;
                overflow: hidden;
                border: none;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- TOP NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">

            <a class="navbar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-file-earmark-text"></i> eProtokoll - Admin
            </a>

            <ul class="navbar-nav ms-auto align-items-center">

                <!-- User -->
                <li class="nav-item me-3">
                    <span class="nav-link">
                        <i class="bi bi-person-circle"></i>
                        @User.Identity?.Name
                    </span>
                </li>

                <!-- Logout -->
                <li class="nav-item">
                    <form asp-area=""
                          asp-controller="Account"
                          asp-action="Logout"
                          method="post">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-outline-light btn-sm">
                            <i class="bi bi-box-arrow-right"></i> Dilni
                        </button>

                    </form>
                </li>

            </ul>

        </div>
    </nav>


    <!-- WRAPPER -->
    <div class="wrapper">

        <!-- SIDEBAR -->
        <nav id="sidebar" class="sidebar">
            <div class="pt-3">

                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                    MENAXHIM
                </h6>

                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="Dashboard"
                           asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="UserManagement"
                           asp-action="Index">
                            <i class="bi bi-people"></i>
                            Përdoruesit
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="Institution"
                           asp-action="Index">
                            <i class="bi bi-building"></i>
                            Institucionet
                        </a>
                    </li>

                </ul>
                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                    RAPORTE
                </h6>

                <ul class="nav flex-column mb-2">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="Report"
                           asp-action="Index">
                            <i class="bi bi-bar-chart"></i>
                            Raporte Statistikore
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="AuditLog"
                           asp-action="Index">
                            <i class="bi bi-journal-text"></i>
                            Log i Aktiviteteve
                        </a>
                    </li>

                </ul>

            </div>
        </nav>


        <!-- MAIN CONTENT -->
        <main class="main-content">

            <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">@ViewData["Title"]</h1>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-auto">
                    <i class="bi bi-check-circle"></i>
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-auto">
                    <i class="bi bi-exclamation-triangle"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            @RenderBody()

        </main>

    </div>

</body>
</html>